{"sections":{"gp_section_615160210553570007":{"settings":{"checksum":"0c1f266a3a395cee09dd50c3f6fbc1aceb094c50f71ae696e223db385c8da299_1_1_1_0__1","ggDA8mPIWGA_srcSet_desktop_src":"https://ucarecdn.com/ee6d5074-1640-4cc7-8933-47c8589c3dee/-/format/auto/","ggOTTuxCJ4q_text":"\u003cstrong\u003eWaarom Gewone Gewrichtssupplementen Falen Bij IVDD\u003c/strong\u003e","gghflutN3h8_srcSet_desktop_src":"https://ucarecdn.com/ee6d5074-1640-4cc7-8933-47c8589c3dee/-/format/auto/","ggvgccPnuoJ_text":"\u003cp\u003eDe meeste supplementen zijn ontwikkeld voor artrose. Artrose zit altijd in de \u003cspan style=\"color:#000000;\"\u003e\u003cstrong\u003e\u003cu\u003egewrichten\u003c/u\u003e\u003c/strong\u003e\u003c/span\u003e.\u003c/p\u003e\u003cp\u003e\u0026nbsp;\u003c/p\u003e\u003cp\u003eMaar een tussenwervelschijf? Dat is geen gewricht.\u003c/p\u003e\u003cp\u003e\u0026nbsp;\u003c/p\u003e\u003cp\u003eHet is een gel-achtige schokdemper tussen de wervels van een teckel - voor 80% gemaakt van water en collageen-matrix.\u003c/p\u003e\u003cp\u003e\u0026nbsp;\u003c/p\u003e\u003cp\u003eBij IVDD verliest die schijf vocht en verzwakken de schijven. Dit zorgt voor de gewrichtsklachten.\u0026nbsp;\u003c/p\u003e\u003cp\u003e\u0026nbsp;\u003c/p\u003e\u003cp\u003e\u003cspan style=\"color:#000000;\"\u003e\u003cstrong\u003eDaarom werken injecties, pijnstillers of zelfs glucosamine die los word gegeven niet.\u003c/strong\u003e\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u0026nbsp;\u003c/p\u003e\u003cp\u003eJe hebt een formule nodig die specifiek die schijf voedt. En dat vraagt om vier zeer gerichte ingrediënten.\u003c/p\u003e"},"type":"gp-section-615160210553570007"},"gp_section_615160210553635543":{"settings":{"checksum":"1bcd7f45d7beafbd8e3a4306548108547b2a46d23e8882a309619625bfd39e6d_1_1_1_0__1","ggRGKtBkaRW_label":"\u003cp\u003e\u003cspan style=\"font-size:16px;\"\u003e\u003cstrong\u003eKrijg korting \u0026amp; controleer de beschikbaarheid\u003c/strong\u003e\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u0026nbsp;\u003c/p\u003e","ggUKThbdGis_srcSet_desktop_src":"https://ucarecdn.com/ee6d5074-1640-4cc7-8933-47c8589c3dee/-/format/auto/","ggUMdsUrNjC_text":"\u003cp\u003eOm gewrichten soepel, sterk en pijnvrij te houden, heb je een \u003cspan style=\"color:#000000;\"\u003e\u003cstrong\u003ecombinatie van ondersteuning\u003c/strong\u003e\u003c/span\u003e nodig:\u003c/p\u003e\u003cul\u003e\u003cli\u003e\u003cspan style=\"color:#000000;\"\u003e\u003cstrong\u003eGlucosamine\u003c/strong\u003e\u003c/span\u003e om de schijven te beschermen en te herstellen\u003c/li\u003e\u003cli\u003e\u003cspan style=\"color:#000000;\"\u003e\u003cstrong\u003eCollageen\u003c/strong\u003e\u003c/span\u003e om bindweefsel en gewrichtsbanden sterk te houden\u003c/li\u003e\u003cli\u003e\u003cspan style=\"color:#000000;\"\u003e\u003cstrong\u003eMSM\u003c/strong\u003e\u003c/span\u003e om de flexibiliteit te verbeteren en de gewrichtsvloeistof gezond te houden\u003c/li\u003e\u003cli\u003e\u003cspan style=\"color:#000000;\"\u003e\u003cstrong\u003eHyaluronzuur\u003c/strong\u003e\u003c/span\u003e helpt de gewrichten soepel te laten bewegen door de smering en schokdemping tussen de schijven te ondersteunen.\u003c/li\u003e\u003cli\u003e\u003cspan style=\"color:#000000;\"\u003e\u003cstrong\u003eNatuurlijke ontstekingsremmers\u003c/strong\u003e\u003c/span\u003e zoals Groenlipmossel en Boswellia om stijfheid en pijn te verlichten\u003c/li\u003e\u003c/ul\u003e\u003cp\u003ePas als al deze ingrediënten samenwerken, krijgt je teckel de juiste ondersteuning om weer vrij te kunnen bewegen.\u003c/p\u003e","ggZ-TtgzOUz_srcSet_desktop_src":"https://ucarecdn.com/ee6d5074-1640-4cc7-8933-47c8589c3dee/-/format/auto/","ggvmpED_QzS_text":"\u003cstrong\u003eDe Vier Schijf-Versterkers\u003c/strong\u003e"},"type":"gp-section-615160210553635543"},"gp_section_615160210553701079":{"settings":{"checksum":"988d467f6720aced50779d2c378b228587a0aa4a375ec8613bcba0c401114857_1_1_1_0__1","ggAGKkrq2bn_label":"\u003cp\u003e\u003cstrong\u003eProbeer PetCura 90 dagen zonder risico \u0026amp; met korting\u003c/strong\u003e\u003c/p\u003e","ggDjzD9VWQc_srcSet_desktop_src":"https://ucarecdn.com/ee6d5074-1640-4cc7-8933-47c8589c3dee/-/format/auto/","ggFDQz94Tsg_text":"\u003cstrong\u003eHeeft Jouw Teckel Ook Die Subtiele Signalen?\u003c/strong\u003e","ggVQk1q4bF0_srcSet_desktop_src":"https://ucarecdn.com/ee6d5074-1640-4cc7-8933-47c8589c3dee/-/format/auto/","ggkvSPTrgKG_text":"\u003cp\u003eAls je die subtiele signalen ziet.\u0026nbsp;\u003c/p\u003e\u003cp\u003e\u0026nbsp;\u003c/p\u003e\u003cp\u003eAls jouw teckel last heeft van stijve of gevoelige gewrichten?\u003c/p\u003e\u003cp\u003e\u0026nbsp;\u003c/p\u003e\u003cp\u003eAls je arts \"typische rugpijn\" zei maar verder niets deed.\u003c/p\u003e\u003cp\u003e\u0026nbsp;\u003c/p\u003e\u003cp\u003eDan zit je waarschijnlijk nog in de \"groene\" fase.\u003c/p\u003e\u003cp\u003e\u0026nbsp;\u003c/p\u003e\u003cp\u003eEn dan is \u003ca href=\"https://petcura.nl/products/gewrichtssnacks\"\u003e\u003cspan style=\"color:#E08E14;\"\u003e\u003cu\u003ePetCura\u003c/u\u003e\u003c/span\u003e\u003c/a\u003e wat ik zou gebruiken.\u003c/p\u003e\u003cp\u003e\u0026nbsp;\u003c/p\u003e\u003cp\u003eNiet omdat het de goedkoopste optie is.\u0026nbsp;\u003c/p\u003e\u003cp\u003e\u0026nbsp;\u003c/p\u003e\u003cp\u003eNiet omdat het de populairste is.\u003c/p\u003e\u003cp\u003e\u0026nbsp;\u003c/p\u003e\u003cp\u003eMaar omdat het de vier ingrediënten bevat in de juiste doseringen voor tussenwervelschijf-regeneratie—met een smaak die zelfs kieskeurige Teckels lekker vinden.\u003c/p\u003e\u003cp\u003e\u0026nbsp;\u003c/p\u003e\u003cp\u003e\u003cstrong\u003eEn omdat je 90 dagen de tijd hebt om het verschil te zien.\u003c/strong\u003e\u003c/p\u003e\u003cp\u003e\u0026nbsp;\u003c/p\u003e\u003cp\u003eAls jouw Teckel na 3 weken niet merkbaar soepeler loopt, makkelijker beweegt, of blijer lijkt krijg je het volledige aankoopbedrag retour.\u003c/p\u003e\u003cp\u003e\u0026nbsp;\u003c/p\u003e\u003cp\u003eGeen vragen. Geen gedoe.\u003c/p\u003e\u003cp\u003e\u0026nbsp;\u003c/p\u003e\u003cp\u003eWant ik weet wat ik de afgelopen 15 jaar heb gezien bij 500+ Teckels.\u003c/p\u003e\u003cp\u003e\u0026nbsp;\u003c/p\u003e\u003cp\u003eEn ik weet dat jij over 5 maanden niet wilt terugkijken met spijt.\u003c/p\u003e"},"type":"gp-section-615160210553701079"},"gp_section_615160210553766615":{"settings":{"checksum":"df25cafd81aa1680800261925468a2e6f734025b699091807414baca1abc3a4b_1_1_1_0__1","ggIbci2G_T1_srcSet_desktop_src":"https://cdn.shopify.com/s/files/1/0775/4671/7507/files/Gemini_Generated_Image_n8io3on8io3on8io_-_Edited.png","ggIbci2G_T1_srcSet_mobile_src":"https://cdn.shopify.com/s/files/1/0775/4671/7507/files/Gemini_Generated_Image_n8io3on8io3on8io_-_Edited.png","ggIbci2G_T1_srcSet_tablet_src":"https://cdn.shopify.com/s/files/1/0775/4671/7507/files/Gemini_Generated_Image_n8io3on8io3on8io_-_Edited.png","ggfs8iITdXE_label":"\u003cp\u003e\u003cspan style=\"font-size:16px;\"\u003e\u003cstrong\u003eKrijg korting \u0026amp; controleer de beschikbaarheid\u003c/strong\u003e\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u0026nbsp;\u003c/p\u003e"},"type":"gp-section-615160210553766615"},"gp_section_615160210553832151":{"settings":{"checksum":"2c4b3002a4bae9ec89c7df04ecf14e42c67ceeb200b0925377eecbabb0c41d1f_1_1_1_0__1","ggLGD3h0O9W_srcSet_desktop_src":"https://ucarecdn.com/ee6d5074-1640-4cc7-8933-47c8589c3dee/-/format/auto/","ggVTUGx0hQq_label":"\u003cp\u003e\u003cspan style=\"font-size:16px;\"\u003e\u003cstrong\u003eKrijg korting \u0026amp; controleer de beschikbaarheid\u003c/strong\u003e\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u0026nbsp;\u003c/p\u003e","ggh11ZkBvFq_text":"\u003cp\u003eEerste week: Max's baasje zag hem makkelijker opstaan. Minder krom lopen.\u003c/p\u003e\u003cp\u003e\u0026nbsp;\u003c/p\u003e\u003cp\u003eTweede week: Hij liep de trap op. Voor het eerst in maanden zonder aarzeling.\u003c/p\u003e\u003cp\u003e\u0026nbsp;\u003c/p\u003e\u003cp\u003eWeek vier: Rende door de tuin. Sprong in en uit de auto. Speelde met zijn bal.\u003c/p\u003e\u003cp\u003e\u0026nbsp;\u003c/p\u003e\u003cp\u003e\"Hij doet dingen die hij in maanden niet gedaan heeft. Waarom heeft niemand me dit verteld?\"\u003c/p\u003e\u003cp\u003e\u0026nbsp;\u003c/p\u003e\u003cp\u003eEn dat is exact waarom ik dit nu deel.\u003c/p\u003e\u003cp\u003e\u0026nbsp;\u003c/p\u003e\u003cp\u003eNiet als verkoper - ik ben dierenarts.\u003c/p\u003e\u003cp\u003e\u0026nbsp;\u003c/p\u003e\u003cp\u003eMaar omdat ik te vaak hoor: \u003cspan style=\"color:#000000;\"\u003e\u003cstrong\u003e\"Had ik dit maar 5 maanden geleden geweten.\"\u003c/strong\u003e\u003c/span\u003e\u003c/p\u003e","ggkuH6uFDE0_text":"\u003cstrong\u003eWat Er Gebeurde In 5 Weken\u003c/strong\u003e"},"type":"gp-section-615160210553832151"},"gp_section_615160210553897687":{"settings":{"checksum":"a3a314ccb541d7fcb4007b2c1ebf8991803620e82f0a6324f9554981d3cadc7c_1_1_1_0__1","ggZ6K2q11zu_text":"\u003cp\u003eWat ik Max's baasje gaf was geen standaard gewrichtssupplement.\u003c/p\u003e\u003cp\u003e\u0026nbsp;\u003c/p\u003e\u003cp\u003eHet was een formule die ik specifiek gebruik voor \u003cspan style=\"color:#000000;\"\u003e\u003cstrong\u003etussenwervelschijf-ondersteuning\u003c/strong\u003e\u003c/span\u003e\u003cstrong\u003e - \u003c/strong\u003eontwikkeld voor exact die kritieke maanden waarin de schijf verzwakt is, maar nog niet gebarsten.\u003c/p\u003e\u003cp\u003e\u0026nbsp;\u003c/p\u003e\u003cp\u003eEn het verschil zit in vier zeer specifieke bouwstoffen die samen doen wat pijnstillers niet kunnen:\u003c/p\u003e\u003cp\u003e\u0026nbsp;\u003c/p\u003e\u003cp\u003e\u003cspan style=\"color:#000000;\"\u003e\u003cstrong\u003eDe schijf zelf versterken. Van binnenuit.\u003c/strong\u003e\u003c/span\u003e\u003c/p\u003e"},"type":"gp-section-615160210553897687"},"gp_section_615160210570347223":{"settings":{"checksum":"2a2e3bb190fc805654c9612a6b8c4b29eda25d6632f466c6259a0e87bef5c612_1_1_1_0__1","gg0EsgX6eb6_text":"\u003cp\u