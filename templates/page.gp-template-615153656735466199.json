507/files/Als_dierenarts_kan_ik_u_vertellen_dat_u_dit_bedrijf_kunt_vertrouwen_om_uw_hond_met_gewrichtsklachten_te_helpen._Ze_hebben_alles_in_het_werk_gesteld_om_ervoor_te_zorgen_dat_dit_product_18130f87-fdb5-4888-a5ac-b6da85f95f16.png","gg0hP7Hs10z_srcSet_tablet_src":"https://cdn.shopify.com/s/files/1/0775/4671/7507/files/Als_dierenarts_kan_ik_u_vertellen_dat_u_dit_bedrijf_kunt_vertrouwen_om_uw_hond_met_gewrichtsklachten_te_helpen._Ze_hebben_alles_in_het_werk_gesteld_om_ervoor_te_zorgen_dat_dit_product_18130f87-fdb5-4888-a5ac-b6da85f95f16.png","gg0hP7Hs10z_title":"Image Title","gg1Tu8XsSXu_label":"\u003cp\u003eGa verder\u003c/p\u003e","ggzHKmRm7Yd_text":"...en meer dan 53.000 katten in Nederland en België"},"type":"gp-section-615153656769086167"},"gp_section_615153656769151703":{"settings":{"checksum":"45791bae9a62f69aab26038906b109879c8f9b36387335684163b5b4eb21721d_1_1_1_0__1","ggErpLt-R-4_text":"Waarom verstopte aanklieren steeds terugkomen","ggL5rTk_Ndv_label":"\u003cp\u003eWat is de oplossing?\u003c/p\u003e","ggLCu59OvWq_srcSet_desktop_src":"https://ucarecdn.com/ee6d5074-1640-4cc7-8933-47c8589c3dee/-/format/auto/","ggSAyU-f0za_srcSet_desktop_src":"https://ucarecdn.com/ee6d5074-1640-4cc7-8933-47c8589c3dee/-/format/auto/","ggapXb7y6dd_text":"\u003cp\u003eJe gaat naar de dierenarts. Ze legen de anaalklieren. Je kat voelt zich beter. \u003cstrong\u003eMaar drie weken later? Het begint opnieuw.\u003c/strong\u003e\u003c/p\u003e\u003cp\u003eWeer schuren. Weer likken. Weer die geur.\u003c/p\u003e\u003cp\u003eDit is het patroon waar duizenden kattenbaasjes in vastzitten.\u003c/p\u003e\u003cp\u003e\u0026nbsp;\u003c/p\u003e\u003cp\u003e\u003cstrong\u003eWaarom? \u003c/strong\u003eOmdat de \u003cstrong\u003eonderliggende oorzaak\u003c/strong\u003e niet wordt aangepakt. Anaalklieren raken niet \"zomaar\" verstopt. Ze raken verstopt omdat \u003cstrong\u003ede ontlasting niet stevig genoeg is\u003c/strong\u003e om ze natuurlijk te legen. Bij een gezonde kat met stevige, goed gevormde ontlasting worden die klieren automatisch uitgeknepen bij elke ontlasting.\u003c/p\u003e\u003cp\u003e\u0026nbsp;\u003c/p\u003e\u003cp\u003eMaar bij katten met zachte of wisselende ontlasting gebeurt dat niet. De klieren blijven vol zitten. En je kat blijft schuren, likken en stinken.\u003c/p\u003e"},"type":"gp-section-615153656769151703"},"gp_section_615153656769217239":{"settings":{"checksum":"5dbde12d12606063fb7f40d73f63619fb70560f281566f0ac3e7587173ff7703_1_1_1_0__1","gg6VSeCptfT_text":"\u003cspan style=\"color:rgb(0,0,0);\"\u003e\u003cstrong\u003eStop verstopte anaalklieren met deze natuurlijke probiotica formule\u003c/strong\u003e\u003c/span\u003e","ggJFP-afoph_text":"\u003cp\u003ePak de darmgezondheid aan. Geef je kat wat zijn lichaam nodig heeft om weer stevige ontlasting te maken. Dan legen die klieren zichzelf weer – zoals het hoort.\u003c/p\u003e\u003cp\u003e\u0026nbsp;\u003c/p\u003e\u003cp\u003eOntdek \u003ca href=\"https://petcura.nl/products/probiotica-voor-katten\"\u003e\u003cspan style=\"color:#0010FF;\"\u003e\u003cstrong\u003e\u003cu\u003eAnti-Jeuk Probiotica Support\u003c/u\u003e\u003c/strong\u003e\u003c/span\u003e\u003c/a\u003e – bekroond tot \u003ci\u003eProduct van het Jaar 2025\u003c/i\u003e. Dit 100% natuurlijke snoepje pakt de kern van het probleem aan. De unieke combinatie van pre-, pro- en postbiotica ondersteunt de darmflora en zorgt voor een stevigere ontlasting.\u003c/p\u003e\u003cp\u003e\u0026nbsp;\u003c/p\u003e\u003cp\u003eHet resultaat? Geen geschuur meer, geen obsessief gelik, geen vieze geur en anaalklieren die zichzelf eindelijk weer kunnen legen. Een kat die zich weer comfortabel, ontspannen en gewoon gelukkig voelt.\u003c/p\u003e\u003cp\u003e\u0026nbsp;\u003c/p\u003e\u003cp\u003eDagelijks een snoepje aan je kat geven is alles wat nodig is om van schuren, likken en maandelijkse dierenarts af te komen.\u003c/p\u003e","ggc-hXlDbnh_label":"\u003cp\u003eVerder lezen\u003c/p\u003e","ggc6oxoP_GU_srcSet_desktop_src":"https://ucarecdn.com/ee6d5074-1640-4cc7-8933-47c8589c3dee/-/format/auto/","ggto5BDDAP7_srcSet_desktop_src":"https://ucarecdn.com/ee6d5074-1640-4cc7-8933-47c8589c3dee/-/format/auto/"},"type":"gp-section-615153656769217239"},"gp_section_615153656769282775":{"settings":{"checksum":"9f132728109bd2d25f38a7f8657007740206e5d48e27d50e70631d859db7dc25_1_1_1_0__1","gg4pcDmJCrV_label":"\u003cp\u003eJa\u003c/p\u003e","ggGdScwqmvD_label":"\u003cp\u003eNee\u003c/p\u003e","gglY5KypUZm_text":"Heeft jouw kat last van zachte ontlasting, likken of een vieze geur?"},"type":"gp-section-615153656769282775"},"gp_section_615153656769348311":{"settings":{"checksum":"6ff3b3d3eca9392373ec37acd3afecbd67d5ee3ad1413c1c622560ce26c3b4c2_1_1_1_0__1","gXsCgGzwMDgrA_srcSet_desktop_src":"https://ucarecdn.com/ee6d5074-1640-4cc7-8933-47c8589c3dee/-/format/auto/","ggIlK5Je1WJ_childItem_0":"\u003cp\u003eSchuren over de vloer\u003c/p\u003e","ggIlK5Je1WJ_childItem_1":"\u003cp\u003eObsessief likken of bijten\u003c/p\u003e","ggIlK5Je1WJ_childItem_2":"\u003cp\u003eVreemde geur\u003c/p\u003e","ggIlK5Je1WJ_childItem_3":"\u003cp\u003eOngemak bij poepen\u003c/p\u003e","ggIlK5Je1WJ_childItem_4":"\u003cp\u003eZachte of wisselende ontlasting\u003c/p\u003e","ggIlK5Je1WJ_childItem_5":"\u003cp\u003eRoodheid of zwelling\u003c/p\u003e","ggatK3cQYU9_label":"\u003cp\u003eWat is de oorzaak?\u003c/p\u003e","goToBlleMERcf_text":"\u003cp\u003eDit zijn enkele belangrijke signalen van anaalklierenproblemen om op te letten:\u003c/p\u003e","gqFjvJCejjKlI_text":"Wat zijn de signalen?"},"type":"gp-section-615153656769348311"},"gp_section_615153656785797847":{"settings":{"checksum":"8b40c32c3f72f1c18b45c1fe83107bc93bf344a256c15994b21d1d76ac5c5bce_1_1_1_0__1","gg2hTXzBNCq_childItem_0":"\u003cp\u003e\u003cstrong\u003eBewezen werking:\u003c/strong\u003e Ondersteunt stevigere ontlasting voor natuurlijke lediging binnen 2-4 weken\u003c/p\u003e","gg2hTXzBNCq_childItem_1":"\u003cp\u003e✓ \u003cstrong\u003eDierenartsen aanbevolen:\u003c/strong\u003e Een d