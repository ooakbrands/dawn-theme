srcSet_mobile_src":"https://cdn.shopify.com/s/files/1/0775/4671/7507/files/Untitled_design_9_fd391219-8f18-4248-9b67-bc080ca9ae80.png","gggQvx_joyX_title":"Image Title","ggksgXLYRUk_text":"\u003cp\u003e\u003cspan style=\"background-color:rgb(255,255,255);color:rgb(51,51,51);font-size:medium;\"\u003e\"Ik voelde me zo schuldig over zijn pijn. Petcura veranderde dat. Mijn hond gebruikt nu niks schadelijks van de dierenarts meer en loopt nu geen enkel risico op bijwerkingen. Heel erg edankt PetCura!\u003c/span\u003e\u003c/p\u003e","ggl7E-Cpe5s_alt":"Alt Image","ggl7E-Cpe5s_srcSet_desktop_src":"https://cdn.shopify.com/s/files/1/0775/4671/7507/files/470798981_447099738449540_3510331012471046264_n.jpg","ggl7E-Cpe5s_srcSet_mobile_src":"https://cdn.shopify.com/s/files/1/0775/4671/7507/files/Mask_group_6342f839-13c6-43a1-99fc-f7943c050b61.png","ggl7E-Cpe5s_srcSet_tablet_src":"https://cdn.shopify.com/s/files/1/0775/4671/7507/files/470798981_447099738449540_3510331012471046264_n.jpg","ggl7E-Cpe5s_title":"Image Title","gglfPXlHdnm_text":"\u003cp\u003eGeverifieerde koper\u003c/p\u003e","ggobGmkfZLb_text":"\u003cp\u003eGeverifieerde koper\u003c/p\u003e","ggvVWOR3Upw_text":"\u003cp\u003e\u003ci\u003e\"Mijn hond werd suffig van de pijnstillers. Met Petcura is hij weer helder, vrolijk en – het belangrijkste – hij rent weer achter zijn bal aan alsof hij 4 is in plaats van 10. Ik ben om.\"\u003c/i\u003e\u003c/p\u003e","ggxbawdc7ts_text":"\u003cp\u003e\u003ci\u003e\"We stonden op de nominatie voor zware medicatie. Nu, 2 maanden aan de Petcura, zegt de dierenarts dat zijn beweging zo goed is dat we de medicijnen kunnen laten staan.\u003c/i\u003e\u003c/p\u003e"},"type":"gp-section-615160316300362455"},"gp_section_615160316300427991":{"settings":{"checksum":"7f8f6a67fb8a53b4cbf303da557d0c8d009648ad742869406ccf7bada9631cd4_1_1_1_0__1","gg0hP7Hs10z_alt":"Alt Image","gg0hP7Hs10z_srcSet_desktop_src":"https://cdn.shopify.com/s/files/1/0775/4671/7507/files/Black_White_Letter_MD_Logo_Instagram_Post_2.png","gg0hP7Hs10z_srcSet_mobile_src":"https://cdn.shopify.com/s/files/1/0775/4671/7507/files/Black_White_Letter_MD_Logo_Instagram_Post_2.png","gg0hP7Hs10z_srcSet_tablet_src":"https://cdn.shopify.com/s/files/1/0775/4671/7507/files/Untitled_design_8_7a7e9e17-5148-498e-bfb8-ae94b40156ca.png","gg0hP7Hs10z_title":"Image Title","gg1Tu8XsSXu_label":"\u003cp\u003eGa verder\u003c/p\u003e","ggzHKmRm7Yd_text":"...en meer dan 53.000 honden in Nederland en België"},"type":"gp-section-615160316300427991"},"gp_section_615160316300493527":{"settings":{"checksum":"3fc05389f51395ff31efb9602762dc9526d9352b311bd95bc3d8d47f9fbbc41c_1_1_1_0__1","ggYpFJ_vjq5_label":"\u003cp\u003eVerder lezen\u003c/p\u003e"},"type":"gp-section-615160316300493527"},"gp_section_615160316317139671":{"settings":{"checksum":"3a65a5b997b7dad1c5c32d77ddcca0ba8ccee443dd84f36026559449497bc893_1_1_1_0__1","gEdEkFTXhMFOn_text":"\u003cp\u003eVeel baasjes denken dat hun hond geholpen is zodra hij een pilletje krijgt en niet meer piept. En ja, medicatie dempt de pijn - het maakt het leven even draaglijker.\u003c/p\u003e\u003cp\u003e\u0026nbsp;\u003c/p\u003e\u003cp\u003e\u003cstrong\u003eMaar wat niemand je vertelt: Pijnstillers herstellen geen beschadigd kraakbeen.\u003c/strong\u003e\u003c/p\u003e\u003cp\u003e\u0026nbsp;\u003c/p\u003e\u003cp\u003eAls je hond stijf is door ouderdom of slijtage, is er schade in het gewricht. Het kraakbeen is versleten. De 'schokdemper' is weg. Pijnstillers plakken slechts het waarschuwingslampje af. En zonder de juiste voeding blijft die schade... zelfs met medicatie.\u003c/p\u003e","gIITBefyzjeNd_text":"Waarom alleen pijnstilling niet genoeg is","ggITW51nwTc_label":"\u003cp\u003eWat zijn de signalen?\u003c/p\u003e","gyPFGnvZMtFTs_srcSet_desktop_src":"https://ucarecdn.com/ee6d5074-1640-4cc7-8933-47c8589c3dee/-/format/auto/"},"type":"gp-section-615160316317139671"},"gp_section_615160316317205207":{"settings":{"checksum":"ed3129bb389d525f6de9e6f4f172decf70431f7bc022b0c6c3ef6fa9f88ff912_1_1_1_0__1","ggj7vSO3ZkC_label":"\u003cp\u003eVerder lezen\u003c/p\u003e"},"type":"gp-section-615160316317205207"},"gp_section_615160316317270743":{"settings":{"checksum":"397bdb8f34950fca99c2780fd5643e7c812fac287073b10019be4fdc80dc4163_1_1_1_0__1","gDoEryfUXRmpA_text":"\u003cstrong\u003eWat is de #1 fout bij de behandeling van stijve gewrichten?\u003c/strong\u003e","gg0y1wZXy6c_label":"\u003cp\u003eWat is de oplossing?\u003c/p\u003e","ggCiKNWjLbN_html5Url":"https://cdn.shopify.com/videos/c/o/v/946c860f9a0944ae9f1d09d7d87b5e4f.mp4","ggCiKNWjLbN_vimeoUrl":"https://vimeo.com/1095883398","ggCiKNWjLbN_youtubeUrl":"https://www.youtube.com/watch?v=drIt4RH_kyQ","gzUhVmmLVBUDt_text":"\u003cp\u003eVeel baasjes (en helaas ook dierenartsen) grijpen te snel naar de \"chemische hamer\". We wachten tot het gewricht versleten is, om het vervolgens plat te spuiten. Maar wist je dat langdurig gebruik van zware pijnstillers de lever en nieren kan belasten?\u003c/p\u003e\u003cp\u003e\u0026nbsp;\u003c/p\u003e\u003cp\u003e\u003cstrong\u003eHet probleem is mechanisch, niet chemisch.\u003c/strong\u003e Wanneer een hond ouder wordt, neemt de aanmaak van synoviaal vocht (gewrichtsolie) af. Het kraakbeen - dat als schokdemper werkt - droogt uit en slijt af. Het wordt bot-op-bot.\u003c/p\u003e\u003cp\u003e\u0026nbsp;\u003c/p\u003e\u003cp\u003eZonder de juiste voeding kan dit kraakbeen zich niet herstellen. Het gevolg? Je hond blijft slijten, terwijl hij verdoofd is. Omdat de onderliggende schade niet is aangepakt.\u003c/p\u003e"},"type":"gp-section-615160316317270743"},"gp_section_615160316317336279":{"settings":{"checksum":"28f1ce6e738b583bbc7e115b5a7f9917385e4125d1a2ee94904c5a0ed450a606_1_1_1_0__1","gXsCgGzwMDgrA_srcSet_desktop_src":"https://ucarecdn.com/ee6d5074-1640-4cc7-8933-47c8589c3dee/-/format/auto/","ggIlK5Je1WJ_childItem_0":"\u003cp\u003eAarzeling bij bewegen\u003c/p\u003e","ggIlK5Je1WJ_childItem_1":"\u003cp\u003eTrap vermijden\u003c/p\u003e","ggIlK5Je1WJ_childItem_2":"\u003cp\u003eMinder energie\u003c/p\u003e","ggIlK5Je1WJ_childItem_3":"\u003cp\u003ePijn bij aanraking\u003c/p\u003e","ggrAhMPxd8j_label":"\u003cp\u003eWat is de oorzaak?\u003c/p\u003e","goToBlleMERcf_text":"\u003cp\u003eMisschien denk je dat het \"normaal\" is. Maar let op deze subtiele signalen die aangeven dat de gewrichten om hulp roepen (en niet om verdoving):\u003c/p\u003e","gqFjvJCejjKlI_text":"Wat zijn de signalen?"},"type":"gp-section-615160316317336279"},"gp_section_615160316317401815":{"settings":{"checksum":"cf79f4b582535b291e2d83ab970b5bacb20e6373db9bd59f233232287cba2fd3_1_1_1_0__1","gFFMEOtFwbmoB_text":"Bekend van","gg-h8MU3002_srcSet_desktop_src":"https://cdn.shopify.com/s/files/1/0775/4671/7507/files/ee186576-8e6e-42a9-8eed-7b9d96c3596d.png","gg-h8MU3002_srcSet_mobile_src":"https://cdn.shopify.com/s/files/1/0775/4671/7507/files/ee186576-8e6e-42a9-8eed-7b9d96c3596d.png","ggP11Y45ddQ_srcSet_desktop_src":"https://cdn.shopify.com/s/files/1/0775/4671/7507/files/92e6d0ed-3cd9-41da-87a6-0187810cc854.png","ggP11Y45ddQ_srcSet_mobile_src":"https://cdn.shopify.com/s/files/1/0775/4671/7507/files/92e6d0ed-3cd9-41da-87a6-0187810cc854.png","ggvFnvwlzL9_srcSet_desktop_src":"https://cdn.shopify.com/s/files/1/0775/4671/7507/files/5ad0b0d1-4a95-43db-907b-056c0e54e68d.png","ggvFnvwlzL9_srcSet_mobile_src":"https://cdn.shopify.com/s/files/1/0775/4671/7507/files/5ad0b0d1-4a95-43db-907b-056c0e54e68d.png"},"type":"gp-section-615160316317401815"},"gp_section_615160316317467351":{"settings":{"checksum":"052faf2c9a78bc9c56f390c84957ff150a7aeb29febef1f1b566e355292f45fe_1_1_1_0__1","ggEHnX6K0jI_srcSet_desktop_src":"https://cdn.shopify.com/s/files/1/0775/4671/7507/files/Green_Modern_Veterinary_Clinic_Logo_2_01079002-66d1-428c-a089-9398c2053c25.png","ggEHnX6K0jI_srcSet_mobile_src":"https://cdn.shopify.com/s/files/1/0775/4671/7507/files/Green_Modern_Veterinary_Clinic_Logo_2_01079002-66d1-428c-a089-9398c2053c25.png","ggEHnX6K0jI_srcSet_tablet_src":"https://cdn.shopify.com/s/files/1/0775/4671/7507/files/Group_1171276939.png","section_preload":"true"},"type":"gp-section-615160316317467351"},"gp_section_615160316317532887":{"settings":{"checksum":"0cd94925ecb29fb471f989de99237baf13ffb6996db8552a33c1d468a4448a3c_1_1_1_0__1","gg4pcDmJCrV_label":"\u003cp\u003eJa\u003c/p\u003e","ggGdScwqmvD_label":"\u003cp\u003eNee\u003c/p\u003e","gglY5KypUZm_text":"\u003cspan style=\"color:rgb(0,0,0);\"\u003e\u003cstrong\u003eVertoont jouw hond signalen van gewrichtsproblemen?\u003c/strong\u003e\u003c/span\u003e"},"type":"gp-section-615160316317532887"},"gp_section_615160316317598423":{"settings":{"checksum":"0eedf6720142ed60cd8d706e6305ff686df002929ea68d1db6b64f2bec6d6893_1_1_1_0__1","gg82vwa4wju_label":"\u003cp\u003eMeer dan 30 kg\u003c/p\u003e","ggLiBSvVQCY_label":"\u003cp\u003e21 - 30 kg\u003c/p\u003e","ggi6FYJOoju_label":"\u003cp\u003e0 - 10 kg\u003c/p\u003e","ggwdL8yAOYe_text":"\u003cspan style=\"color:rgb(0,0,0);\"\u003eHoeveel weegt jouw hond?\u003c/span\u003e","ggyBugXSGYz_label":"\u003cp\u003e11 - 20 kg\u003c/p\u003e"},"type":"gp-section-615160316317598423"},"gp_section_615160316317663959":{"settings":{"checksum":"e4dba4c71566ec0246ac8879ac0f2647426d11e53d13a52da0d59eede1966994_1_1_1_0__1","gDWaRBDEqKIsF_text":"Een nieuwe aanpak: Voeden in plaats van Verdoven","gLuJehAHewyvT_text":"\u003cp\u003eIk stond op het punt om weer een recept uit te schrijven voor Max, een 7-jarige Border Collie. Tot zijn eigenaresse vroeg: \u003ci\u003e\"Dokter, wat doet dit met zijn lever op de lange termijn?\"\u003c/i\u003e\u003cbr\u003e\u0026nbsp;\u003c/p\u003e\u003cp\u003eDat was het moment dat ik stopte met de symptoombestrijding. Ik zocht een oplossing die de \u003cstrong\u003eoorzaak\u003c/strong\u003e aanpakt.\u003cbr\u003e\u0026nbsp;\u003c/p\u003e\u003cp\u003eEen Nederlands team genaamd \u003cstrong\u003ePetcura\u003c/strong\u003e heeft een natuurlijke snack ontwikkeld die precies doet wat medicijnen niet kunnen: Het brengt de bouwstoffen (zoals Hyaluronzuur en Glucosamine) DAADWERKELIJK in het gewricht.\u003c/p\u003e","gatWucvdAgAjp_srcSet_desktop_src":"https://ucarecdn.com/ee6d5074-1640-4cc7-8933-47c8589c3dee/-/format/auto/","ggD7DXkv7H9_label":"\u003cp\u003eVerder lezen\u003c/p\u003e"},"type":"gp-section-615160316317663959"},"gp_section_615160316317729495":{"settings":{"checksum":"fdd3c19545d5a5b042af0f10a5031fe03b8611b879b3ebd55c6525040d2a161c_1_1_1_0__1","gKzMAPUvtOMTB_srcSet_desktop_src":"https://ucarecdn.com/ee6d5074-1640-4cc7-8933-47c8589c3dee/-/format/auto/","gg-H9gDEzFH_label":"\u003cp\u003eVerder lezen\u003c/p\u003e","ggJXDsQw_w2_text":"\u003cp\u003eDr. Anouk de Vries - Haarlem\u003c/p\u003e","ggUoJxICnh9_text":"\u003cspan style=\"color:rgb(0,0,0);\"\u003e\u003cstrong\u003eAanbevolen door dierenartsen\u003c/strong\u003e\u003c/span\u003e","grwUUuFoXBbvW_text":"\u003cp\u003e\u003cstrong\u003e\"Ik raad PetCura aan als slimme aanvulling voor de gewrichtsgezondheid van honden. \u003c/strong\u003eHet ondersteunt de smering van de gewrichten en helpt het kraakbeen te voeden, wat belangrijk is voor comfortabel bewegen.\"\u003c/p\u003e"},"type":"gp-section-615160316317729495"}},"order":["gp_section_615160316317467351","gp_section_615160316283585239","gp_section_615160316317401815","gp_section_615160316317139671","gp_section_615160316317336279","gp_section_615160316317270743","gp_section_615160316317663959","gp_section_615160316317205207","gp_section_615160316300493527","gp_section_615160316317729495","gp_section_615160316300362455","gp_section_615160316300427991","gp_section_615160316317598423","gp_section_615160316317532887"],"layout":"theme.gempages.blank"}