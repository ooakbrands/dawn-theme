{% if upsell_product != blank %}
  <div class="upsell-product-container" id="upsell-slide-{{ block_id }}">
    <div class="upsell-product-card-{{ block_id }}">
      {% if show_best_seller_tag and best_seller_text != blank %}
        <div class="upsell-best-seller-tag-{{ block_id }}">
          {% if upsell_custom_bestseller_svg != blank %}
            {{ upsell_custom_bestseller_svg }}
          {% else %}
            <svg
              class="bestseller-icon"
              width="10"
              height="10"
              viewBox="0 0 54.558 54.559"
              fill="currentColor"
            >
              <path d="M27.28,3.911c-8.024,0-14.553,6.528-14.553,14.552s6.528,14.553,14.553,14.553c8.024,0,14.552-6.529,14.552-14.553 S35.304,3.911,27.28,3.911z M27.28,31.016c-6.921,0-12.553-5.631-12.553-12.553c0-6.921,5.631-12.552,12.553-12.552 c6.921,0,12.552,5.631,12.552,12.552C39.832,25.384,34.201,31.016,27.28,31.016z" />
              <path d="M27.28,7.704c-0.552,0-1,0.448-1,1c0,0.552,0.448,1,1,1c4.83,0,8.758,3.929,8.758,8.759c0,0.552,0.448,1,1,1s1-0.448,1-1 C38.038,12.53,33.212,7.704,27.28,7.704z" />
              <path d="M35.966,47.441c-0.285-0.012-0.57,0.095-0.771,0.302l-3.896,4.004l-2.944-7.543l3.021-7.741 c0.34-0.076,0.674-0.171,1.006-0.268c0.08-0.021,0.159-0.038,0.237-0.062c0.513-0.154,1.017-0.334,1.513-0.533 c0.139-0.056,0.272-0.119,0.409-0.176c0.366-0.158,0.728-0.326,1.083-0.507c0.152-0.078,0.305-0.155,0.454-0.237 c0.101-0.055,0.206-0.103,0.306-0.16l5.164,13.229L35.966,47.441z" />
              <path d="M23.262,51.747l-3.897-4.004c-0.189-0.194-0.448-0.304-0.717-0.304 c-0.018,0-0.037,0-0.055,0.002l-5.579,0.306l5.163-13.228c0.019,0.011,0.039,0.02,0.058,0.029 c0.225,0.127,0.457,0.239,0.686,0.355c0.184,0.095,0.365,0.195,0.552,0.283c0.082,0.039,0.167,0.07,0.249,0.106 c1.544,0.698,3.171,1.181,4.85,1.429c0.008,0.002,0.016,0.004,0.024,0.004c0.365,0.053,0.734,0.09,1.104,0.121 c0.096,0.008,0.191,0.021,0.288,0.027c0.294,0.02,0.59,0.025,0.886,0.032c0.136,0.003,0.271,0.015,0.406,0.015 c0.041,0,0.082-0.006,0.123-0.006c0.513-0.005,1.027-0.027,1.545-0.077c0.039-0.003,0.077-0.003,0.115-0.007 c0.006,0,0.013,0,0.021-0.001l-2.735,7.004c0,0,0,0.001,0,0.002L23.262,51.747z" />
            </svg>
          {% endif %}
          {{ best_seller_text }}
        </div>
      {% endif %}

      <div
        id="{{ product_form_id }}"
        class="upsell-form"
        data-block-id="{{ block_id }}"
      >
        <script type="application/json" id="upsell-product-json">
          {{ upsell_product | json }}
        </script>
        <input
          type="hidden"
          name="id"
          value="{{ upsell_product.first_available_variant.id }}"
        >

        <!-- Left column: Product image -->
        <div class="upsell-product-image-column-{{ block_id }}">
          {% if upsell_product.featured_image != blank %}
            <img
              src="{{ upsell_product.featured_image | image_url: width: 150 }}"
              alt="{{ upsell_product.featured_image.alt | escape }}"
              class="upsell-product-img"
              loading="lazy"
              width=""
              height=""
            >
          {% else %}
            <div class="upsell-product-img placeholder-wrapper">
              {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
            </div>
          {% endif %}
        </div>

        <!-- Middle column: Title and variants -->
        <div class="upsell-product-info-column-{{ block_id }}">
          <div class="upsell-product-header-{{ block_id }}">
            <div class="upsell-product-title upsell-product-title-{{ block_id }}">{{ upsell_product.title }}</div>
          </div>

          {% if show_description and description_text != blank %}
            <div class="upsell-product-description upsell-product-description-{{ block_id }}">
              {{ description_text }}
            </div>
          {% endif %}
          {% unless upsell_show_price %}
            <div class="upsell-product-price-{{ block_id }}">{{ upsell_product.price | money }}</div>
          {% endunless %}

          {% unless upsell_product.has_only_default_variant %}
            <div class="upsell-variant-options">
              {% for option in upsell_product.options_with_values %}
                <select name="options[{{ option.name | escape }}]" class="upsell-variant-select-{{ block_id }}">
                  {% for value in option.values %}
                    <option
                      value="{{ value | escape }}"
                      {% if option.selected_value == value %}
                        selected="selected"
                      {% endif %}
                    >
                      {{ value }}
                    </option>
                  {% endfor %}
                </select>
              {% endfor %}
            </div>
          {% endunless %}
        </div>

        <!-- Right column: Add button -->
        <div class="upsell-product-action-column">
          <button name="upsell-add" class="upsell-button upsell-add-button-{{ block_id }}">
            {%- if upsell_product.price > 0 -%}
              <span class="upsell-button-text-{{ block_id }}">
                {{- upsell_button_text -}}
                {% if show_price %}
                  <span class="upsell-price" style="color: {{ button_text_color }}">
                    {{- upsell_product.price | money -}}
                  </span>
                {% endif %}
              </span>
            {%- else -%}
              <span class="upsell-button-text-{{ block_id }}">
                {{ upsell_button_text }}
              </span>
            {%- endif -%}
          </button>
        </div>
      </div>
    </div>
  </div>

  <style>
    {% if title_color != blank %}
      .upsell-product-title-{{ block_id }}
      , .upsell-product-container .upsell-product-title-{{ block_id }}
      , div.upsell-product-container .upsell-product-title-{{ block_id }} {
        color: {{ title_color }}
         !important;
      }
    {% endif %}
    {% if description_color != blank %}
      .upsell-product-description-{{ block_id }}
      , .upsell-product-container .upsell-product-description-{{ block_id }}
      , div.upsell-product-container .upsell-product-description-{{ block_id }} {
        color: {{ description_color }}
         !important;
      }
    {% endif %}
  </style>
{% endif %}
