<script>
  (function () {
    if (window.__upsellDelegated) return;
    window.__upsellDelegated = true;

    const parser = new DOMParser();

    function formatPrice(cents) {
      const currency = '{{ current_currency }}';
      const price = cents / 100;
      if (currency === 'USD') return '$' + price.toFixed(2);
      if (currency === 'EUR') return '€' + price.toFixed(2).replace('.', ',');
      if (currency === 'GBP') return '£' + price.toFixed(2);
      if (currency === 'CAD') return '$' + price.toFixed(2) + ' CAD';
      return currency + ' ' + price.toFixed(2);
    }

    // VARIANTES — update l'id + le prix sur tout upsell form
    document.addEventListener('change', (e) => {
      const select = e.target.closest('.upsell-form select[name^="options["]');
      if (!select) return;

      const form = select.closest('.upsell-form');
      const selects = form.querySelectorAll('select[name^="options["]');
      const hiddenIdInput = form.querySelector('input[name="id"]');
      const productJsonEl = form.querySelector('#upsell-product-json');
      if (!hiddenIdInput || !productJsonEl) return;

      const productJson = JSON.parse(productJsonEl.textContent || '{}');
      if (!productJson.variants) return;

      const selectedOptions = Array.from(selects).map(s => s.value);
      const selectedVariant = productJson.variants.find(v =>
        selectedOptions.every((opt, i) => v.options[i] === opt)
      );
      if (!selectedVariant) return;

      hiddenIdInput.value = selectedVariant.id;

      const textEl = form.querySelector('[class^="upsell-button-text-"]');
      if (textEl && selectedVariant.price != null) {
        textEl.innerHTML =
          `{{ upsell_button_text | escape }} ` +
          `<span class="upsell-price" style="color: {{ button_text_color | default: '#FFFFFF' }}">${formatPrice(selectedVariant.price)}</span>`;
      }
    });

    // ADD TO CART — délégué
    document.addEventListener('click', (e) => {
      const btn = e.target.closest('.upsell-form button[name="upsell-add"]');
      if (!btn) return;

      e.preventDefault();
      e.stopPropagation();

      const form = btn.closest('.upsell-form');
      const addButton = form.querySelector('[class^="upsell-add-button-"]') || btn;
      const textEl = addButton.querySelector('[class^="upsell-button-text-"]');
      const originalText = textEl ? textEl.textContent : addButton.textContent;

      // loading UI
      addButton.innerHTML = '<span class="button-spinner"></span>';
      addButton.classList.add('is-loading');
      addButton.disabled = true;

      const variantId = form.querySelector('input[name="id"]')?.value;
      if (!variantId) {
        addButton.innerHTML = `<span class="${textEl?.className || ''}">${originalText}</span>`;
        addButton.classList.remove('is-loading');
        addButton.disabled = false;
        return;
      }

      fetch(`${window.routes.cart_add_url}.js`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
        body: JSON.stringify({ items: [{ id: variantId, quantity: 1 }] })
      })
      .then(r => r.ok ? r.json() : r.json().then(err => { throw new Error(err.description || r.statusText); }))
      .then(() => {
        const successText = {{ upsell_success_text | json }};
        addButton.innerHTML = `<span class="${textEl?.className || ''}">${successText ?? originalText}</span>`;
        addButton.classList.remove('is-loading');
        addButton.classList.add('upsell-add-success');

        setTimeout(() => {
          addButton.innerHTML = `<span class="${textEl?.className || ''}">${originalText}</span>`;
          addButton.classList.remove('upsell-add-success');
          addButton.disabled = false;
        }, 1500);

        // rafraîchir compte & drawer
        if (typeof window.updateCartCount === 'function') window.updateCartCount();
        if (typeof window.refreshCart === 'function') window.refreshCart();
        document.dispatchEvent(new CustomEvent('cart:refresh'));
        document.dispatchEvent(new CustomEvent('cart:update'));
        if (window.THEME?.updateCartCount) window.THEME.updateCartCount();
        else if (typeof window.refreshMiniCart === 'function') window.refreshMiniCart();

        return fetch(`${window.routes.cart_url}?view=drawer`)
          .then(res => res.text())
          .then(html => {
            const doc = parser.parseFromString(html, 'text/html');
            const newCartDrawer = doc.querySelector('#CartDrawer');
            const container = document.querySelector('cart-drawer');
            if (container && newCartDrawer && typeof updateCartDrawer === 'function') {
              updateCartDrawer(container, newCartDrawer);
            }
          });
      })
      .catch(err => {
        console.error('upsell add error', err);
        addButton.innerHTML = `<span class="${textEl?.className || ''}">${originalText}</span>`;
        addButton.classList.remove('is-loading');
        addButton.classList.add('upsell-add-error');
        setTimeout(() => {
          addButton.classList.remove('upsell-add-error');
          addButton.disabled = false;
        }, 1500);
      });
    });

    // Optionnel: quand le drawer s’ouvre, on s’assure que les boutons sont cliquables
    document.addEventListener('cart-drawer:open', () => {
      document.querySelectorAll('[class^="upsell-add-button-"]').forEach(b => b.disabled = false);
    });
  })();
</script>
