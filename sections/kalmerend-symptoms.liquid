{% style %}
  .ksym-{{ section.id }} {
    background: {{ section.settings.bg_color }};
    color: {{ section.settings.text_color }};
    padding: {{ section.settings.padding_top }}px 1.25rem {{ section.settings.padding_bottom }}px;
  }
  .ksym-{{ section.id }} .ksym-inner {
    max-width: {{ section.settings.max_width }}px;
    margin: 0 auto;
  }
  .ksym-{{ section.id }} .ksym-eyebrow {
    display: inline-block;
    background: {{ section.settings.accent_color }};
    color: {{ section.settings.eyebrow_text_color }};
    padding: 0.35rem 0.85rem;
    border-radius: 999px;
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    margin-bottom: 1rem;
  }
  .ksym-{{ section.id }} h2 {
    font-size: clamp(1.6rem, 2.8vw, 2.5rem);
    line-height: 1.15;
    margin: 0 0 0.75rem;
    color: {{ section.settings.heading_color }};
    font-weight: 700;
  }
  .ksym-{{ section.id }} .ksym-intro {
    max-width: 720px;
    font-size: 1.05rem;
    line-height: 1.55;
    margin: 0 0 2rem;
    opacity: 0.85;
  }
  .ksym-{{ section.id }} .ksym-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem;
  }
  .ksym-{{ section.id }} .ksym-card {
    background: {{ section.settings.card_bg }};
    border: 1px solid {{ section.settings.card_border }};
    border-radius: 16px;
    padding: 1.4rem 1.1rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 0.85rem;
    transition: transform .25s ease, border-color .25s ease, background-color .25s ease;
  }
  .ksym-{{ section.id }} .ksym-card:hover {
    transform: translateY(-3px);
    border-color: {{ section.settings.accent_color }};
    background: {{ section.settings.card_hover_bg }};
  }
  .ksym-{{ section.id }} .ksym-icon {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    background: {{ section.settings.icon_bg }};
    color: {{ section.settings.icon_color }};
    display: grid;
    place-items: center;
  }
  .ksym-{{ section.id }} .ksym-icon svg, .ksym-{{ section.id }} .ksym-icon img { width: 30px; height: 30px; }
  .ksym-{{ section.id }} .ksym-label {
    font-size: 0.95rem;
    font-weight: 600;
    line-height: 1.3;
  }
  @media (max-width: 989px) {
    .ksym-{{ section.id }} .ksym-grid { grid-template-columns: repeat(3, 1fr); }
  }
  @media (max-width: 749px) {
    .ksym-{{ section.id }} .ksym-grid { grid-template-columns: repeat(2, 1fr); gap: 0.75rem; }
    .ksym-{{ section.id }} .ksym-card { padding: 1rem 0.75rem; }
  }
{% endstyle %}

{%- liquid
  assign default_icons = 'paw,moon,bark,broken-home,trembling,water,running,heartbeat'
  assign icon_list = default_icons | split: ','
-%}

<section class="ksym-{{ section.id }}">
  <div class="ksym-inner">
    {% if section.settings.eyebrow != blank %}
      <span class="ksym-eyebrow">{{ section.settings.eyebrow }}</span>
    {% endif %}
    {% if section.settings.heading != blank %}
      <h2>{{ section.settings.heading }}</h2>
    {% endif %}
    {% if section.settings.intro != blank %}
      <p class="ksym-intro">{{ section.settings.intro }}</p>
    {% endif %}

    <div class="ksym-grid">
      {% for block in section.blocks %}
        <div class="ksym-card" {{ block.shopify_attributes }}>
          <div class="ksym-icon" aria-hidden="true">
            {% if block.settings.icon_image %}
              <img src="{{ block.settings.icon_image | image_url: width: 80 }}" alt="" loading="lazy" width="30" height="30">
            {% else %}
              {% case block.settings.icon %}
                {% when 'paw' %}
                  <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 13c2.5 0 4 2 4 4s-1.6 3-4 3-4-1-4-3 1.5-4 4-4Zm-6.5-3a2 2 0 1 1 0 4 2 2 0 0 1 0-4Zm13 0a2 2 0 1 1 0 4 2 2 0 0 1 0-4ZM9 4a2 2 0 1 1 0 4 2 2 0 0 1 0-4Zm6 0a2 2 0 1 1 0 4 2 2 0 0 1 0-4Z"/></svg>
                {% when 'moon' %}
                  <svg viewBox="0 0 24 24" fill="currentColor"><path d="M21 14.5A8.5 8.5 0 0 1 9.5 3a1 1 0 0 0-1.4-1A10 10 0 1 0 22 15.9a1 1 0 0 0-1-1.4Z"/></svg>
                {% when 'bark' %}
                  <svg viewBox="0 0 24 24" fill="currentColor"><path d="M4 5a3 3 0 0 1 3-3h10a3 3 0 0 1 3 3v8a3 3 0 0 1-3 3h-4l-4 4v-4H7a3 3 0 0 1-3-3V5Z"/></svg>
                {% when 'broken-home' %}
                  <svg viewBox="0 0 24 24" fill="currentColor"><path d="m12 3 9 7v11h-6v-6H9v6H3V10l9-7Zm-1 9 1.5 2-2 2 1.5 2"/></svg>
                {% when 'trembling' %}
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 12h2l2-6 4 12 4-9 2 3h4"/></svg>
                {% when 'water' %}
                  <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2s7 8 7 13a7 7 0 1 1-14 0c0-5 7-13 7-13Z"/></svg>
                {% when 'running' %}
                  <svg viewBox="0 0 24 24" fill="currentColor"><path d="M13 5a2 2 0 1 0 0-4 2 2 0 0 0 0 4Zm-2 17 2-7-3-2-1 5H6l3-9 5-1 4 4 4 1v2l-5-1-2-2-1 5 4 5h-2l-3-3-2 3H9Z"/></svg>
                {% when 'heartbeat' %}
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 12h4l2-5 4 10 2-5h6"/></svg>
                {% else %}
                  <svg viewBox="0 0 24 24" fill="currentColor"><circle cx="12" cy="12" r="9"/></svg>
              {% endcase %}
            {% endif %}
          </div>
          <span class="ksym-label">{{ block.settings.label }}</span>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Kalmerend · Symptomen",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow-tekst", "default": "Herken je dit?" },
    { "type": "text", "id": "heading", "label": "Kop", "default": "Signalen van stress en angst bij honden" },
    { "type": "textarea", "id": "intro", "label": "Intro", "default": "Stress laat zich vaak eerder zien in gedrag dan in geluid. Deze acht signalen wijzen er meestal op dat je hond ondersteuning kan gebruiken bij spannende momenten." },
    { "type": "header", "content": "Kleuren" },
    { "type": "color", "id": "bg_color", "label": "Sectie-achtergrond", "default": "#FFFFFF" },
    { "type": "color", "id": "text_color", "label": "Tekstkleur", "default": "#17433C" },
    { "type": "color", "id": "heading_color", "label": "Kopkleur", "default": "#17433C" },
    { "type": "color", "id": "accent_color", "label": "Accent (eyebrow)", "default": "#C6FA54" },
    { "type": "color", "id": "eyebrow_text_color", "label": "Eyebrow tekstkleur", "default": "#17433C" },
    { "type": "color", "id": "card_bg", "label": "Kaart achtergrond", "default": "#F8FBF5" },
    { "type": "color", "id": "card_hover_bg", "label": "Kaart achtergrond (hover)", "default": "#EFF8E0" },
    { "type": "color", "id": "card_border", "label": "Kaart rand", "default": "#E1ECDD" },
    { "type": "color", "id": "icon_bg", "label": "Icoon achtergrond", "default": "#C6FA54" },
    { "type": "color", "id": "icon_color", "label": "Icoon kleur", "default": "#17433C" },
    { "type": "header", "content": "Spacing" },
    { "type": "range", "id": "max_width", "label": "Max breedte", "min": 800, "max": 1400, "step": 20, "default": 1180 },
    { "type": "range", "id": "padding_top", "label": "Padding boven", "min": 0, "max": 160, "step": 4, "default": 64 },
    { "type": "range", "id": "padding_bottom", "label": "Padding onder", "min": 0, "max": 160, "step": 4, "default": 64 }
  ],
  "blocks": [
    {
      "type": "symptom",
      "name": "Symptoom",
      "settings": [
        { "type": "text", "id": "label", "label": "Label", "default": "Hijgen / Hyperventileren" },
        { "type": "select", "id": "icon", "label": "Icoon", "default": "paw",
          "options": [
            { "value": "paw", "label": "Pootafdruk" },
            { "value": "moon", "label": "Maan / slapen" },
            { "value": "bark", "label": "Tekstballon / blaffen" },
            { "value": "broken-home", "label": "Schade / huis" },
            { "value": "trembling", "label": "Trillen / zigzag" },
            { "value": "water", "label": "Druppel / urine" },
            { "value": "running", "label": "Wegrennen" },
            { "value": "heartbeat", "label": "Hartslag" }
          ]
        },
        { "type": "image_picker", "id": "icon_image", "label": "Eigen icoon (overschrijft selectie)" }
      ]
    }
  ],
  "max_blocks": 12,
  "presets": [
    {
      "name": "Kalmerend · Symptomen",
      "blocks": [
        { "type": "symptom", "settings": { "label": "Hijgen / Hyperventileren", "icon": "heartbeat" } },
        { "type": "symptom", "settings": { "label": "Trillen of bibberen", "icon": "trembling" } },
        { "type": "symptom", "settings": { "label": "Onverklaarbaar blaffen", "icon": "bark" } },
        { "type": "symptom", "settings": { "label": "Rusteloos ijsberen", "icon": "running" } },
        { "type": "symptom", "settings": { "label": "Slaapproblemen", "icon": "moon" } },
        { "type": "symptom", "settings": { "label": "Schade aan meubilair", "icon": "broken-home" } },
        { "type": "symptom", "settings": { "label": "Onzindelijkheid uit angst", "icon": "water" } },
        { "type": "symptom", "settings": { "label": "Verstoppen of weglopen", "icon": "paw" } }
      ]
    }
  ]
}
{% endschema %}
