{% style %}
  .ktrust-{{ section.id }} {
    background: {{ section.settings.bg_color }};
    color: {{ section.settings.text_color }};
    padding: {{ section.settings.padding_top }}px 1.25rem {{ section.settings.padding_bottom }}px;
  }
  .ktrust-{{ section.id }} .ktrust-inner {
    max-width: {{ section.settings.max_width }}px;
    margin: 0 auto;
  }
  .ktrust-{{ section.id }} .ktrust-row {
    display: grid;
    grid-template-columns: repeat({{ section.blocks.size }}, 1fr);
    gap: 0.5rem;
    background: {{ section.settings.card_bg }};
    border: 1px solid {{ section.settings.card_border }};
    border-radius: 16px;
    padding: 1rem;
  }
  .ktrust-{{ section.id }} .ktrust-cell {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 0.5rem;
    padding: 0.85rem 0.6rem;
    border-right: 1px solid {{ section.settings.divider_color }};
  }
  .ktrust-{{ section.id }} .ktrust-cell:last-child { border-right: none; }
  .ktrust-{{ section.id }} .ktrust-icon {
    width: 38px; height: 38px;
    color: {{ section.settings.icon_color }};
    display: grid; place-items: center;
  }
  .ktrust-{{ section.id }} .ktrust-icon svg { width: 100%; height: 100%; }
  .ktrust-{{ section.id }} .ktrust-icon img { width: 100%; height: 100%; object-fit: contain; }
  .ktrust-{{ section.id }} .ktrust-label {
    font-size: 0.82rem;
    line-height: 1.3;
    font-weight: 600;
    color: {{ section.settings.heading_color }};
  }
  @media (max-width: 989px) {
    .ktrust-{{ section.id }} .ktrust-row {
      grid-template-columns: repeat(3, 1fr);
      gap: 0;
    }
    .ktrust-{{ section.id }} .ktrust-cell:nth-child(3n) { border-right: none; }
    .ktrust-{{ section.id }} .ktrust-cell:nth-child(-n+3) { border-bottom: 1px solid {{ section.settings.divider_color }}; }
  }
  @media (max-width: 480px) {
    .ktrust-{{ section.id }} .ktrust-row { grid-template-columns: repeat(2, 1fr); }
    .ktrust-{{ section.id }} .ktrust-cell { border-right: none !important; border-bottom: 1px solid {{ section.settings.divider_color }}; }
    .ktrust-{{ section.id }} .ktrust-cell:nth-last-child(-n+2) { border-bottom: none; }
  }
{% endstyle %}

<section class="ktrust-{{ section.id }}">
  <div class="ktrust-inner">
    <div class="ktrust-row">
      {% for block in section.blocks %}
        <div class="ktrust-cell" {{ block.shopify_attributes }}>
          <span class="ktrust-icon" aria-hidden="true">
            {% if block.settings.icon_image %}
              <img src="{{ block.settings.icon_image | image_url: width: 80 }}" alt="" loading="lazy">
            {% else %}
              {% case block.settings.icon %}
                {% when 'leaf' %}
                  <svg viewBox="0 0 24 24" fill="currentColor"><path d="M5 21c1-9 7-15 16-16-1 9-7 15-16 16Z"/></svg>
                {% when 'truck' %}
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round"><path d="M3 7h11v9H3zM14 10h4l3 3v3h-7"/><circle cx="7" cy="18" r="2" fill="currentColor"/><circle cx="17" cy="18" r="2" fill="currentColor"/></svg>
                {% when 'clock' %}
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/></svg>
                {% when 'shield' %}
                  <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2 4 5v6c0 5 3.5 9.4 8 11 4.5-1.6 8-6 8-11V5l-8-3Zm-1 14-4-4 1.4-1.4L11 13.2l5.6-5.6L18 9l-7 7Z"/></svg>
                {% when 'pin' %}
                  <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2a8 8 0 0 0-8 8c0 6 8 12 8 12s8-6 8-12a8 8 0 0 0-8-8Zm0 11a3 3 0 1 1 0-6 3 3 0 0 1 0 6Z"/></svg>
                {% when 'lab' %}
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round" stroke-linecap="round"><path d="M9 3v6L4 19a2 2 0 0 0 2 3h12a2 2 0 0 0 2-3l-5-10V3M8 3h8M9 13h6"/></svg>
                {% when 'award' %}
                  <svg viewBox="0 0 24 24" fill="currentColor"><circle cx="12" cy="9" r="6"/><path d="M8 13.5 6 22l6-3 6 3-2-8.5"/></svg>
                {% when 'heart' %}
                  <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 21s-7-4.5-9.5-9A5.5 5.5 0 0 1 12 6a5.5 5.5 0 0 1 9.5 6c-2.5 4.5-9.5 9-9.5 9Z"/></svg>
                {% else %}
                  <svg viewBox="0 0 24 24" fill="currentColor"><circle cx="12" cy="12" r="9"/></svg>
              {% endcase %}
            {% endif %}
          </span>
          <span class="ktrust-label">{{ block.settings.label }}</span>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Kalmerend · Vertrouwen",
  "settings": [
    { "type": "header", "content": "Kleuren" },
    { "type": "color", "id": "bg_color", "label": "Sectie-achtergrond", "default": "#FFFFFF" },
    { "type": "color", "id": "text_color", "label": "Tekstkleur", "default": "#17433C" },
    { "type": "color", "id": "heading_color", "label": "Labelkleur", "default": "#17433C" },
    { "type": "color", "id": "card_bg", "label": "Strook achtergrond", "default": "#F4F8F2" },
    { "type": "color", "id": "card_border", "label": "Strook rand", "default": "#E1ECDD" },
    { "type": "color", "id": "divider_color", "label": "Tussenlijntje", "default": "#E1ECDD" },
    { "type": "color", "id": "icon_color", "label": "Icoon kleur", "default": "#17433C" },
    { "type": "header", "content": "Spacing" },
    { "type": "range", "id": "max_width", "label": "Max breedte", "min": 800, "max": 1400, "step": 20, "default": 1180 },
    { "type": "range", "id": "padding_top", "label": "Padding boven", "min": 0, "max": 120, "step": 4, "default": 32 },
    { "type": "range", "id": "padding_bottom", "label": "Padding onder", "min": 0, "max": 120, "step": 4, "default": 32 }
  ],
  "blocks": [
    {
      "type": "trust_item",
      "name": "Vertrouwensblok",
      "settings": [
        { "type": "select", "id": "icon", "label": "Icoon", "default": "leaf",
          "options": [
            { "value": "leaf", "label": "Blad / natuurlijk" },
            { "value": "truck", "label": "Vrachtwagen / bezorging" },
            { "value": "clock", "label": "Klok / snel" },
            { "value": "shield", "label": "Schild / garantie" },
            { "value": "pin", "label": "Pin / Nederland" },
            { "value": "lab", "label": "Laboratorium / getest" },
            { "value": "award", "label": "Medaille" },
            { "value": "heart", "label": "Hart" }
          ]
        },
        { "type": "image_picker", "id": "icon_image", "label": "Eigen icoon (overschrijft selectie)" },
        { "type": "text", "id": "label", "label": "Label", "default": "100% natuurlijk" }
      ]
    }
  ],
  "max_blocks": 8,
  "presets": [
    {
      "name": "Kalmerend · Vertrouwen",
      "blocks": [
        { "type": "trust_item", "settings": { "icon": "leaf", "label": "100% natuurlijk" } },
        { "type": "trust_item", "settings": { "icon": "truck", "label": "Gratis verzending vanaf €49" } },
        { "type": "trust_item", "settings": { "icon": "clock", "label": "Voor 22:00 besteld, morgen in huis" } },
        { "type": "trust_item", "settings": { "icon": "shield", "label": "90 dagen geld-terug" } },
        { "type": "trust_item", "settings": { "icon": "pin", "label": "Gemaakt in Nederland" } },
        { "type": "trust_item", "settings": { "icon": "lab", "label": "Onafhankelijk laboratorium getest" } }
      ]
    }
  ]
}
{% endschema %}
