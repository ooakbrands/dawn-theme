{{ 'component-newsletter.css' | asset_url | stylesheet_tag }}
{{ 'component-list-social.css' | asset_url | stylesheet_tag }}
{{ 'component-localization-form.css' | asset_url | stylesheet_tag }}
{{ 'section-custom-footer.css' | asset_url | stylesheet_tag }}

{%- liquid
  if section.settings.use_theme_colors
    assign newsletter_bg_color = settings.global_section_background_color
    assign newsletter_text_color = settings.global_section_text_color
    assign newsletter_button_color = settings.global_section_accent_1_color
    assign footer_bg_color = settings.global_section_text_color
    assign footer_text_color = settings.global_section_background_color
    assign footer_heading_color = settings.global_section_background_color
    assign footer_border_color = settings.global_section_background_color
    assign footer_menu_color = settings.global_section_background_color
    assign footer_menu_hover_color = settings.global_section_accent_2_color
    assign footer_divider_color = settings.global_section_background_color
    assign localization_label_color = settings.global_section_background_color
  else
    assign newsletter_bg_color = section.settings.newsletter_bg_color | default: '#f8f9fa'
    assign newsletter_text_color = section.settings.newsletter_text_color | default: '#333'
    assign newsletter_button_color = section.settings.newsletter_button_color | default: '#007bff'
    assign footer_bg_color = section.settings.footer_bg_color | default: '#1a1a1a'
    assign footer_text_color = section.settings.footer_text_color | default: '#b0b0b0'
    assign footer_heading_color = section.settings.footer_heading_color | default: '#ffffff'
    assign footer_border_color = section.settings.footer_border_color | default: '#333'
    assign footer_menu_color = section.settings.footer_menu_color | default: '#b0b0b0'
    assign footer_menu_hover_color = section.settings.footer_menu_hover_color | default: '#ffffff'
    assign footer_divider_color = section.settings.footer_divider_color | default: '#666666'
    assign localization_label_color = section.settings.localization_label_color | default: '#b0b0b0'
  endif
  assign footer_heading_size = section.settings.footer_heading_size | default: 18
  assign footer_text_size = section.settings.footer_text_size | default: 14
  assign newsletter_title_size = section.settings.newsletter_title_size | default: 54
  assign newsletter_subtitle_size = section.settings.newsletter_subtitle_size | default: 18
  assign copyright_text_size = section.settings.copyright_text_size | default: 11
  assign localization_label_size = section.settings.localization_label_size | default: 14
-%}

<style>
  .custom-footer {
    --newsletter-bg-color: {{ newsletter_bg_color }};
    --newsletter-text-color: {{ newsletter_text_color }};
    --newsletter-button-color: {{ newsletter_button_color }};
    --footer-bg-color: {{ footer_bg_color }};
    --footer-text-color: {{ footer_text_color }};
    --footer-heading-color: {{ footer_heading_color }};
    --footer-border-color: {{ footer_border_color }};
    --footer-menu-color: {{ footer_menu_color }};
    --footer-menu-hover-color: {{ footer_menu_hover_color }};
    --footer-divider-color: {{ footer_divider_color }};
    --localization-label-color: {{ localization_label_color }};
    --footer-heading-size: {{ footer_heading_size }}px;
    --footer-text-size: {{ footer_text_size }}px;
    --newsletter-title-size: {{ newsletter_title_size }}px;
    --newsletter-subtitle-size: {{ newsletter_subtitle_size }}px;
    --copyright-text-size: {{ copyright_text_size }}px;
    --localization-label-size: {{ localization_label_size }}px;
  }

  /* Load-in animation */
  .page-fade-in {
    opacity: 0;
    transform: translateY(20px);
    animation: fadeInUp 0.8s ease-out forwards;
  }

  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* Add slight delay for staggered effect on multiple sections */
  .page-fade-in:nth-child(2) { animation-delay: 0.1s; }
  .page-fade-in:nth-child(3) { animation-delay: 0.2s; }
  .page-fade-in:nth-child(4) { animation-delay: 0.3s; }
</style>

<div class="custom-footer page-fade-in">
  {%- if section.settings.show_newsletter -%}
    <!-- Newsletter Section -->
    <section class="newsletter-section">
      <div class="newsletter-container">
        {%- if section.settings.newsletter_title != blank -%}
          <h2 class="newsletter-title">{{ section.settings.newsletter_title }}</h2>
        {%- endif -%}
        {%- if section.settings.newsletter_subtitle != blank -%}
          <p class="newsletter-subtitle">{{ section.settings.newsletter_subtitle }}</p>
        {%- endif -%}
        {%- form 'customer', class: 'newsletter-form' -%}
          <input type="hidden" name="contact[tags]" value="newsletter">
          <div class="newsletter-form__field-wrapper">
            <div class="field">
              <input
                id="NewsletterForm--{{ section.id }}"
                type="email"
                name="contact[email]"
                class="field__input"
                value="{{ form.email }}"
                aria-required="true"
                autocorrect="off"
                autocapitalize="off"
                autocomplete="email"
                {% if form.errors %}
                  autofocus
                  aria-invalid="true"
                  aria-describedby="Newsletter-error--{{ section.id }}"
                {% elsif form.posted_successfully? %}
                  aria-describedby="Newsletter-success--{{ section.id }}"
                {% endif %}
                placeholder="{{ section.settings.newsletter_placeholder | default: 'Enter your email address' }}"
                required
              >
              <label class="field__label" for="NewsletterForm--{{ section.id }}">
                {{ section.settings.newsletter_placeholder | default: 'Enter your email address' }}
              </label>
              <button
                type="submit"
                class="newsletter-form__button field__button"
                name="commit"
                id="Subscribe"
                aria-label="{{ section.settings.newsletter_button_text | default: 'Subscribe' }}"
              >
                <span class="svg-wrapper">
                  {{- 'icon-arrow.svg' | inline_asset_content -}}
                </span>
              </button>
            </div>
            {%- if form.errors -%}
              <small class="newsletter-form__message form__message" id="Newsletter-error--{{ section.id }}">
                <span class="svg-wrapper">
                  {%- render 'icon-error' -%}
                </span>
                {{- form.errors.translated_fields.email | capitalize }}
                {{ form.errors.messages.email -}}
              </small>
            {%- endif -%}
          </div>
          {%- if form.posted_successfully? -%}
            <h3
              class="newsletter-form__message newsletter-form__message--success form__message"
              id="Newsletter-success--{{ section.id }}"
              tabindex="-1"
              autofocus
            >
              <span class="svg-wrapper">
                {{- 'icon-success.svg' | inline_asset_content -}}
              </span>
              {{- 'newsletter.success' | t }}
            </h3>
          {%- endif -%}
        {%- endform -%}
      </div>
    </section>
  {%- endif -%}

  <!-- Main Footer -->
  <footer class="footer-main">
    <div class="footer-container">
      <div class="footer-content footer-content--{{ section.settings.footer_columns }}-col">
        
        {%- if section.settings.show_brand_column -%}
          <!-- Brand Column -->
          <div class="footer-brand">
            {%- if section.settings.logo != blank -%}
              <img src="{{ section.settings.logo | image_url: width: 200 }}" 
                   alt="{{ shop.name }}" 
                   class="footer-logo-image"
                   width="{{ section.settings.logo_width | default: 150 }}"
                   height="auto">
            {%- else -%}
              <div class="footer-logo">{{ section.settings.brand_name | default: shop.name }}</div>
            {%- endif -%}
            {%- if section.settings.logo_description != blank -%}
              <p class="footer-logo-description">{{ section.settings.logo_description }}</p>
            {%- endif -%}
            {%- if section.settings.brand_description != blank -%}
              <p class="footer-description">{{ section.settings.brand_description }}</p>
            {%- endif -%}
          </div>
        {%- endif -%}

        {%- for block in section.blocks -%}
          {%- case block.type -%}
            {%- when 'menu_column' -%}
              <div class="footer-column" {{ block.shopify_attributes }}>
                {%- if block.settings.heading != blank -%}
                  <h3>{{ block.settings.heading }}</h3>
                {%- endif -%}
                {%- if block.settings.menu != blank -%}
                  <ul>
                    {%- for link in linklists[block.settings.menu].links -%}
                      <li><a href="{{ link.url }}">{{ link.title }}</a></li>
                    {%- endfor -%}
                  </ul>
                {%- endif -%}
              </div>

            {%- when 'custom_links' -%}
              <div class="footer-column" {{ block.shopify_attributes }}>
                {%- if block.settings.heading != blank -%}
                  <h3>{{ block.settings.heading }}</h3>
                {%- endif -%}
                <ul>
                  {%- if block.settings.link_1_text != blank and block.settings.link_1_url != blank -%}
                    <li><a href="{{ block.settings.link_1_url }}">{{ block.settings.link_1_text }}</a></li>
                  {%- endif -%}
                  {%- if block.settings.link_2_text != blank and block.settings.link_2_url != blank -%}
                    <li><a href="{{ block.settings.link_2_url }}">{{ block.settings.link_2_text }}</a></li>
                  {%- endif -%}
                  {%- if block.settings.link_3_text != blank and block.settings.link_3_url != blank -%}
                    <li><a href="{{ block.settings.link_3_url }}">{{ block.settings.link_3_text }}</a></li>
                  {%- endif -%}
                  {%- if block.settings.link_4_text != blank and block.settings.link_4_url != blank -%}
                    <li><a href="{{ block.settings.link_4_url }}">{{ block.settings.link_4_text }}</a></li>
                  {%- endif -%}
                  {%- if block.settings.link_5_text != blank and block.settings.link_5_url != blank -%}
                    <li><a href="{{ block.settings.link_5_url }}">{{ block.settings.link_5_text }}</a></li>
                  {%- endif -%}
                  {%- if block.settings.link_6_text != blank and block.settings.link_6_url != blank -%}
                    <li><a href="{{ block.settings.link_6_url }}">{{ block.settings.link_6_text }}</a></li>
                  {%- endif -%}
                </ul>
              </div>

            {%- when 'social_column' -%}
              {%- comment -%} Social column will be rendered outside the grid {%- endcomment -%}

            {%- when 'text_column' -%}
              <div class="footer-column" {{ block.shopify_attributes }}>
                {%- if block.settings.heading != blank -%}
                  <h3>{{ block.settings.heading }}</h3>
                {%- endif -%}
                {%- if block.settings.text != blank -%}
                  <div class="footer-text">{{ block.settings.text }}</div>
                {%- endif -%}
              </div>

          {%- endcase -%}
        {%- endfor -%}
      </div>
      
      {%- comment -%} Social Media Section - Outside Grid {%- endcomment -%}
      {%- if section.settings.show_social -%}
        {%- for block in section.blocks -%}
          {%- if block.type == 'social_column' -%}
            <div class="footer-social-section" {{ block.shopify_attributes }}>
              {%- if block.settings.heading != blank -%}
                <h3 class="footer-social-heading">{{ block.settings.heading }}</h3>
              {%- endif -%}
              {%- render 'social-icons', class: 'footer__list-social footer__list-social--full-width' -%}
            </div>
            {%- break -%}
          {%- endif -%}
        {%- endfor -%}
      {%- endif -%}

      {%- if section.settings.show_footer_bottom -%}
        <!-- Footer Bottom -->
        <div class="footer-bottom">
          {%- if section.settings.show_copyright -%}
            <div class="footer-copyright">
              {%- if section.settings.copyright_text != blank -%}
                {{ section.settings.copyright_text }}
              {%- else -%}
                © {{ 'now' | date: '%Y' }} {{ shop.name }}
              {%- endif -%}
            </div>
          {%- endif -%}
          
          {%- if section.settings.show_payment_icons -%}
            <div class="footer-payment-icons">
              {%- for type in shop.enabled_payment_types -%}
                {{ type | payment_type_svg_tag: class: 'footer-payment-icon' }}
              {%- endfor -%}
            </div>
          {%- endif -%}
          
          {%- if section.settings.show_localization -%}
            <div class="footer__localization isolate">
              {%- if section.settings.enable_country_selector and localization.available_countries.size > 1 -%}
                <localization-form>
                  {%- form 'localization', id: 'FooterCountryForm', class: 'localization-form' -%}
                    <div>
                      <h2 class="caption-large text-body" id="FooterCountryLabel">{{ 'localization.country_label' | t }}</h2>
                      {%- render 'country-localization', localPosition: 'FooterCountry' -%}
                    </div>
                  {%- endform -%}
                </localization-form>
              {%- endif -%}

              {%- if section.settings.enable_language_selector and localization.available_languages.size > 1 -%}
                <localization-form>
                  {%- form 'localization', id: 'FooterLanguageForm', class: 'localization-form' -%}
                    <div>
                      <h2 class="caption-large text-body" id="FooterLanguageLabel">
                        {{ 'localization.language_label' | t }}
                      </h2>
                      {%- render 'language-localization', localPosition: 'FooterLanguage' -%}
                    </div>
                  {%- endform -%}
                </localization-form>
              {%- endif -%}
            </div>
          {%- endif -%}
        </div>
      {%- endif -%}
    </div>
  </footer>
</div>

{% schema %}
{
