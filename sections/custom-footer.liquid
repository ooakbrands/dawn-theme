      "label": "Copyright text",
      "info": "Leave blank to use default format"
    },
    {
      "type": "checkbox",
      "id": "show_payment_icons",
      "label": "Show payment icons",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_localization",
      "label": "Show currency and language selector",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "enable_country_selector",
