  "class": "section-custom-footer",
  "max_blocks": 10,
  "settings": [
    {
      "type": "checkbox",
      "id": "use_theme_colors",
      "label": "Use Theme Colors",
      "default": false,
      "info": "Apply the global theme colors to this section"
