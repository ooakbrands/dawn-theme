      "default": "#EF4A65"
    },
    {
      "type": "color",
      "id": "circle_gradient_end",
      "label": "Circle Gradient End Color",
      "default": "#D81B60"
    },
    {
      "type": "range",
      "id": "circle_gradient_angle",
      "min": 0,
