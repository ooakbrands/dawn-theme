{% style %}
  .ktl-{{ section.id }} {
    background: {{ section.settings.bg_color }};
    color: {{ section.settings.text_color }};
    padding: {{ section.settings.padding_top }}px 1.25rem {{ section.settings.padding_bottom }}px;
  }
  .ktl-{{ section.id }} .ktl-inner {
    max-width: {{ section.settings.max_width }}px;
    margin: 0 auto;
  }
  .ktl-{{ section.id }} .ktl-head { text-align: center; margin-bottom: 3rem; }
  .ktl-{{ section.id }} .ktl-eyebrow {
    display: inline-block;
    background: {{ section.settings.accent_color }};
    color: {{ section.settings.eyebrow_text_color }};
    padding: 0.35rem 0.85rem;
    border-radius: 999px;
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    margin-bottom: 0.85rem;
  }
  .ktl-{{ section.id }} h2 {
    font-size: clamp(1.7rem, 3vw, 2.6rem);
    margin: 0 0 0.5rem;
    color: {{ section.settings.heading_color }};
    font-weight: 700;
    line-height: 1.15;
  }
  .ktl-{{ section.id }} .ktl-sub { font-size: 1rem; opacity: 0.8; max-width: 600px; margin: 0 auto; }

  .ktl-{{ section.id }} .ktl-track {
    position: relative;
    display: grid;
    grid-template-columns: repeat({{ section.blocks.size | default: 4 }}, 1fr);
    gap: 1.25rem;
  }
  .ktl-{{ section.id }} .ktl-track::before {
    content: "";
    position: absolute;
    top: 28px;
    left: 8%; right: 8%;
    height: 2px;
    background: linear-gradient(to right, {{ section.settings.line_color }} 0%, {{ section.settings.accent_color }} 50%, {{ section.settings.line_color }} 100%);
    z-index: 0;
  }
  .ktl-{{ section.id }} .ktl-step { position: relative; z-index: 1; text-align: center; }
  .ktl-{{ section.id }} .ktl-dot {
    width: 56px; height: 56px;
    border-radius: 50%;
    background: {{ section.settings.dot_bg }};
    color: {{ section.settings.dot_text }};
    border: 4px solid {{ section.settings.bg_color }};
    box-shadow: 0 0 0 2px {{ section.settings.accent_color }};
    margin: 0 auto 1.1rem;
    display: grid; place-items: center;
    font-weight: 800;
    font-size: 1.1rem;
  }
  .ktl-{{ section.id }} .ktl-step.is-current .ktl-dot {
    background: {{ section.settings.accent_color }};
    color: {{ section.settings.dot_text_current }};
  }
  .ktl-{{ section.id }} .ktl-phase {
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-weight: 700;
    color: {{ section.settings.phase_color }};
    margin-bottom: 0.35rem;
  }
  .ktl-{{ section.id }} .ktl-title {
    font-size: 1.05rem;
    font-weight: 700;
    color: {{ section.settings.heading_color }};
    margin: 0 0 0.5rem;
    line-height: 1.25;
  }
  .ktl-{{ section.id }} .ktl-desc {
    font-size: 0.92rem;
    line-height: 1.55;
    margin: 0;
    opacity: 0.85;
  }

  @media (max-width: 749px) {
    .ktl-{{ section.id }} .ktl-track {
      grid-template-columns: 1fr;
      gap: 0;
    }
    .ktl-{{ section.id }} .ktl-track::before {
      left: 27px;
      right: auto;
      top: 28px;
      bottom: 28px;
      width: 2px;
      height: auto;
      background: linear-gradient(to bottom, {{ section.settings.line_color }} 0%, {{ section.settings.accent_color }} 50%, {{ section.settings.line_color }} 100%);
    }
    .ktl-{{ section.id }} .ktl-step {
      display: grid;
      grid-template-columns: 56px 1fr;
      gap: 1rem;
      text-align: left;
      padding: 0.5rem 0 1.5rem;
    }
    .ktl-{{ section.id }} .ktl-dot { margin: 0; }
    .ktl-{{ section.id }} .ktl-phase, .ktl-{{ section.id }} .ktl-title, .ktl-{{ section.id }} .ktl-desc { padding-top: 0.15rem; }
  }
{% endstyle %}

<section class="ktl-{{ section.id }}">
  <div class="ktl-inner">
    <div class="ktl-head">
      {% if section.settings.eyebrow != blank %}<span class="ktl-eyebrow">{{ section.settings.eyebrow }}</span>{% endif %}
      {% if section.settings.heading != blank %}<h2>{{ section.settings.heading }}</h2>{% endif %}
      {% if section.settings.subheading != blank %}<p class="ktl-sub">{{ section.settings.subheading }}</p>{% endif %}
    </div>

    <div class="ktl-track">
      {% for block in section.blocks %}
        <div class="ktl-step {% if block.settings.is_current %}is-current{% endif %}" {{ block.shopify_attributes }}>
          <div class="ktl-dot">{{ forloop.index }}</div>
          <div>
            {% if block.settings.phase != blank %}<div class="ktl-phase">{{ block.settings.phase }}</div>{% endif %}
            {% if block.settings.title != blank %}<h3 class="ktl-title">{{ block.settings.title }}</h3>{% endif %}
            {% if block.settings.description != blank %}<p class="ktl-desc">{{ block.settings.description }}</p>{% endif %}
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Kalmerend · Tijdlijn",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Wat je kunt verwachten" },
    { "type": "text", "id": "heading", "label": "Kop", "default": "Hoe rust geleidelijk terugkeert" },
    { "type": "text", "id": "subheading", "label": "Subkop", "default": "Een typisch verloop bij dagelijks gebruik. Iedere hond is anders — bij sommige al binnen een week, bij andere na enkele weken." },
    { "type": "header", "content": "Kleuren" },
    { "type": "color", "id": "bg_color", "label": "Sectie-achtergrond", "default": "#FFFFFF" },
    { "type": "color", "id": "text_color", "label": "Tekstkleur", "default": "#17433C" },
    { "type": "color", "id": "heading_color", "label": "Kopkleur", "default": "#17433C" },
    { "type": "color", "id": "accent_color", "label": "Accentkleur", "default": "#C6FA54" },
    { "type": "color", "id": "eyebrow_text_color", "label": "Eyebrow tekstkleur", "default": "#17433C" },
    { "type": "color", "id": "line_color", "label": "Lijnkleur", "default": "#E1ECDD" },
    { "type": "color", "id": "dot_bg", "label": "Stap achtergrond", "default": "#FFFFFF" },
    { "type": "color", "id": "dot_text", "label": "Stap tekst", "default": "#17433C" },
    { "type": "color", "id": "dot_text_current", "label": "Huidige stap tekst", "default": "#17433C" },
    { "type": "color", "id": "phase_color", "label": "Fase-label kleur", "default": "#4C716B" },
    { "type": "header", "content": "Spacing" },
    { "type": "range", "id": "max_width", "label": "Max breedte", "min": 800, "max": 1400, "step": 20, "default": 1180 },
    { "type": "range", "id": "padding_top", "label": "Padding boven", "min": 0, "max": 160, "step": 4, "default": 64 },
    { "type": "range", "id": "padding_bottom", "label": "Padding onder", "min": 0, "max": 160, "step": 4, "default": 64 }
  ],
  "blocks": [
    {
      "type": "phase",
      "name": "Fase",
      "settings": [
        { "type": "text", "id": "phase", "label": "Fase-label", "default": "Week 1–2" },
        { "type": "text", "id": "title", "label": "Titel", "default": "Eerste rustpunten" },
        { "type": "textarea", "id": "description", "label": "Beschrijving", "default": "Je hond reageert minder heftig op spannende momenten. Ademhaling kalmeert sneller en hijgen vermindert." },
        { "type": "checkbox", "id": "is_current", "label": "Markeer als huidige fase", "default": false }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "Kalmerend · Tijdlijn",
      "blocks": [
        { "type": "phase", "settings": { "phase": "Week 1–2", "title": "Eerste rustpunten", "description": "Je hond reageert minder heftig op prikkels. Ademhaling kalmeert sneller en hijgen vermindert merkbaar." } },
        { "type": "phase", "settings": { "phase": "Week 3–5", "title": "Stabieler ritme", "description": "Het basisniveau van onrust daalt. Je hond herstelt sneller na een prikkel en valt makkelijker in slaap." } },
        { "type": "phase", "settings": { "phase": "Maand 2–3", "title": "Diepere rust", "description": "Slaap wordt regelmatiger. Voorspelbare prikkels zoals deurbel of autorit leiden tot minder paniek." } },
        { "type": "phase", "settings": { "phase": "Vanaf maand 3", "title": "De nieuwe norm", "description": "Een merkbaar stabieler ritme door de dag heen. Spannende momenten blijven beter te dragen voor jou en je hond." } }
      ]
    }
  ]
}
{% endschema %}
