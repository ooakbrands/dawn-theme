{% style %}
  .kdose-{{ section.id }} {
    background: {{ section.settings.bg_color }};
    color: {{ section.settings.text_color }};
    padding: {{ section.settings.padding_top }}px 1.25rem {{ section.settings.padding_bottom }}px;
  }
  .kdose-{{ section.id }} .kdose-inner {
    max-width: {{ section.settings.max_width }}px;
    margin: 0 auto;
  }
  .kdose-{{ section.id }} .kdose-head { text-align: center; margin-bottom: 2.25rem; }
  .kdose-{{ section.id }} .kdose-eyebrow {
    display: inline-block;
    background: {{ section.settings.accent_color }};
    color: {{ section.settings.eyebrow_text_color }};
    padding: 0.35rem 0.85rem;
    border-radius: 999px;
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    margin-bottom: 0.85rem;
  }
  .kdose-{{ section.id }} h2 {
    font-size: clamp(1.7rem, 3vw, 2.5rem);
    margin: 0 0 0.5rem;
    color: {{ section.settings.heading_color }};
    font-weight: 700;
    line-height: 1.15;
  }
  .kdose-{{ section.id }} .kdose-sub { font-size: 1rem; opacity: 0.8; max-width: 600px; margin: 0 auto; }

  .kdose-{{ section.id }} .kdose-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem;
    margin-bottom: 1.5rem;
  }
  .kdose-{{ section.id }} .kdose-card {
    background: {{ section.settings.card_bg }};
    border: 1px solid {{ section.settings.card_border }};
    border-radius: 18px;
    padding: 1.5rem 1rem;
    text-align: center;
    transition: border-color .25s, transform .25s, box-shadow .25s;
  }
  .kdose-{{ section.id }} .kdose-card:hover {
    border-color: {{ section.settings.accent_color }};
    transform: translateY(-3px);
    box-shadow: 0 6px 18px rgba(23, 67, 60, 0.08);
  }
  .kdose-{{ section.id }} .kdose-dog {
    width: 80px; height: 80px;
    margin: 0 auto 0.85rem;
    border-radius: 50%;
    background: {{ section.settings.icon_bg }};
    color: {{ section.settings.icon_color }};
    display: grid; place-items: center;
  }
  .kdose-{{ section.id }} .kdose-dog svg { width: 44px; height: 44px; }
  .kdose-{{ section.id }} .kdose-card[data-size="s"] .kdose-dog svg { width: 32px; height: 32px; }
  .kdose-{{ section.id }} .kdose-card[data-size="m"] .kdose-dog svg { width: 40px; height: 40px; }
  .kdose-{{ section.id }} .kdose-card[data-size="l"] .kdose-dog svg { width: 48px; height: 48px; }
  .kdose-{{ section.id }} .kdose-card[data-size="xl"] .kdose-dog svg { width: 56px; height: 56px; }

  .kdose-{{ section.id }} .kdose-weight {
    font-size: 1.1rem;
    font-weight: 700;
    color: {{ section.settings.heading_color }};
    margin-bottom: 0.35rem;
  }
  .kdose-{{ section.id }} .kdose-amount {
    display: inline-flex;
    align-items: baseline;
    gap: 0.25rem;
    background: {{ section.settings.accent_color }};
    color: {{ section.settings.dose_text_color }};
    padding: 0.5rem 0.9rem;
    border-radius: 12px;
    font-weight: 700;
    margin: 0.4rem 0 0.6rem;
    font-size: 1.05rem;
  }
  .kdose-{{ section.id }} .kdose-amount .num { font-size: 1.5rem; line-height: 1; }
  .kdose-{{ section.id }} .kdose-freq {
    font-size: 0.85rem;
    opacity: 0.75;
    line-height: 1.3;
  }

  .kdose-{{ section.id }} .kdose-note {
    background: {{ section.settings.note_bg }};
    border-left: 3px solid {{ section.settings.accent_color }};
    border-radius: 12px;
    padding: 1rem 1.25rem;
    font-size: 0.95rem;
    line-height: 1.55;
  }
  .kdose-{{ section.id }} .kdose-note strong { color: {{ section.settings.heading_color }}; }
  .kdose-{{ section.id }} .kdose-link {
    display: inline-block;
    margin-top: 0.85rem;
    color: {{ section.settings.heading_color }};
    text-decoration: underline;
    text-decoration-thickness: 2px;
    text-underline-offset: 4px;
    font-weight: 600;
  }

  @media (max-width: 989px) {
    .kdose-{{ section.id }} .kdose-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 480px) {
    .kdose-{{ section.id }} .kdose-grid { grid-template-columns: 1fr; }
  }
{% endstyle %}

{%- liquid
  capture dog_svg
    echo '<svg viewBox="0 0 64 64" fill="currentColor" aria-hidden="true"><path d="M14 24c0-4 2-7 6-9l3 5h12l3-5c4 2 6 5 6 9v6h6v6l-4 2v8a4 4 0 0 1-4 4h-4l-2-6h-3v6h-4v-6h-7v6h-4v-6h-3l-2 6h-4a4 4 0 0 1-4-4v-8l-4-2v-6h6v-6Zm9-12 4-4h2l3 4-3 3h-3l-3-3Zm14 0 3-4h2l4 4-3 3h-3l-3-3Z"/></svg>'
  endcapture
-%}

<section class="kdose-{{ section.id }}">
  <div class="kdose-inner">
    <div class="kdose-head">
      {% if section.settings.eyebrow != blank %}<span class="kdose-eyebrow">{{ section.settings.eyebrow }}</span>{% endif %}
      {% if section.settings.heading != blank %}<h2>{{ section.settings.heading }}</h2>{% endif %}
      {% if section.settings.subheading != blank %}<p class="kdose-sub">{{ section.settings.subheading }}</p>{% endif %}
    </div>

    <div class="kdose-grid">
      {% for block in section.blocks %}
        <div class="kdose-card" data-size="{{ block.settings.size }}" {{ block.shopify_attributes }}>
          <div class="kdose-dog">{{ dog_svg }}</div>
          <div class="kdose-weight">{{ block.settings.weight }}</div>
          <div class="kdose-amount"><span class="num">{{ block.settings.amount }}</span><span>{{ block.settings.amount_unit }}</span></div>
          <div class="kdose-freq">{{ block.settings.frequency }}</div>
        </div>
      {% endfor %}
    </div>

    {% if section.settings.note != blank %}
      <div class="kdose-note">
        {{ section.settings.note }}
        {% if section.settings.link_text != blank %}
          <a class="kdose-link" href="{{ section.settings.link_url | default: '#' }}">{{ section.settings.link_text }} →</a>
        {% endif %}
      </div>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Kalmerend · Doseringsgids",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Doseringsgids" },
    { "type": "text", "id": "heading", "label": "Kop", "default": "De juiste dosis voor jouw hond" },
    { "type": "text", "id": "subheading", "label": "Subkop", "default": "Op basis van het gewicht van je hond. Bouw de eerste drie dagen rustig op naar de volledige dagdosering." },
    { "type": "richtext", "id": "note", "label": "Notitie", "default": "<p><strong>Tip:</strong> Geef de snack 30 tot 60 minuten vóór een spannend moment, of dagelijks bij langdurige onrust. Eerste 3 dagen rustig opbouwen.</p>" },
    { "type": "text", "id": "link_text", "label": "Linktekst", "default": "Hond zwaarder dan 40 kg? Bekijk de XL-variant" },
    { "type": "url", "id": "link_url", "label": "Link" },
    { "type": "header", "content": "Kleuren" },
    { "type": "color", "id": "bg_color", "label": "Sectie-achtergrond", "default": "#FFFFFF" },
    { "type": "color", "id": "text_color", "label": "Tekstkleur", "default": "#17433C" },
    { "type": "color", "id": "heading_color", "label": "Kopkleur", "default": "#17433C" },
    { "type": "color", "id": "accent_color", "label": "Accentkleur", "default": "#C6FA54" },
    { "type": "color", "id": "eyebrow_text_color", "label": "Eyebrow tekstkleur", "default": "#17433C" },
    { "type": "color", "id": "card_bg", "label": "Kaart achtergrond", "default": "#F8FBF5" },
    { "type": "color", "id": "card_border", "label": "Kaart rand", "default": "#E1ECDD" },
    { "type": "color", "id": "icon_bg", "label": "Hond icoon achtergrond", "default": "#EFF8E0" },
    { "type": "color", "id": "icon_color", "label": "Hond icoon kleur", "default": "#17433C" },
    { "type": "color", "id": "dose_text_color", "label": "Dosering tekstkleur", "default": "#17433C" },
    { "type": "color", "id": "note_bg", "label": "Notitie achtergrond", "default": "#F4F8F2" },
    { "type": "header", "content": "Spacing" },
    { "type": "range", "id": "max_width", "label": "Max breedte", "min": 800, "max": 1400, "step": 20, "default": 1180 },
    { "type": "range", "id": "padding_top", "label": "Padding boven", "min": 0, "max": 160, "step": 4, "default": 64 },
    { "type": "range", "id": "padding_bottom", "label": "Padding onder", "min": 0, "max": 160, "step": 4, "default": 64 }
  ],
  "blocks": [
    {
      "type": "weight",
      "name": "Gewichtskaart",
      "settings": [
        { "type": "text", "id": "weight", "label": "Gewichtsbereik", "default": "Tot 10 kg" },
        { "type": "text", "id": "amount", "label": "Aantal", "default": "1" },
        { "type": "text", "id": "amount_unit", "label": "Eenheid", "default": "snack" },
        { "type": "text", "id": "frequency", "label": "Frequentie", "default": "1–2× per dag bij stressmomenten" },
        { "type": "select", "id": "size", "label": "Hond grootte (icoon)", "default": "s",
          "options": [
            { "value": "s", "label": "Klein" },
            { "value": "m", "label": "Middel" },
            { "value": "l", "label": "Groot" },
            { "value": "xl", "label": "Extra groot" }
          ]
        }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "Kalmerend · Doseringsgids",
      "blocks": [
        { "type": "weight", "settings": { "weight": "Tot 10 kg", "amount": "1", "amount_unit": "snack", "frequency": "1–2× per dag bij stressmomenten", "size": "s" } },
        { "type": "weight", "settings": { "weight": "10 – 25 kg", "amount": "2", "amount_unit": "snacks", "frequency": "1–2× per dag bij stressmomenten", "size": "m" } },
        { "type": "weight", "settings": { "weight": "25 – 40 kg", "amount": "3", "amount_unit": "snacks", "frequency": "1–2× per dag bij stressmomenten", "size": "l" } },
        { "type": "weight", "settings": { "weight": "Vanaf 40 kg", "amount": "4", "amount_unit": "snacks", "frequency": "1–2× per dag bij stressmomenten", "size": "xl" } }
      ]
    }
  ]
}
{% endschema %}
