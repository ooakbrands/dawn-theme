  .sidebar-filters { position: sticky; top: 80px; align-self: start; }
  .sidebar-filters__inner { 
    {% unless section.settings.remove_sidebar_border %}
      border: 1px solid {% if section.settings.use_theme_colors %}{{ settings.global_section_text_color | color_modify: 'alpha', 0.08 }}{% else %}{{ section.settings.nav_border_color | default: "rgba(0,0,0,.08)" }}{% endif %}; 
    {% else %}
      border: none;
    {% endunless %}
    border-radius: 10px; 
    padding: 16px; 
    background: {% if section.settings.use_theme_colors %}{{ settings.global_section_background_color }}{% else %}{{ section.settings.sidebar_background_color | default: '#ffffff' }}{% endif %}; 
  }
  .sidebar-filters__header { 
    display: flex; 
    justify-content: space-between; 
    align-items: center; 
    margin-bottom: 10px; 
    font-weight: var(--font-weight-bold); 
    letter-spacing: var(--letter-spacing-body);
    color: {% if section.settings.use_theme_colors %}{{ settings.global_section_text_color }}{% else %}{{ section.settings.sidebar_text_color | default: "#000000" }}{% endif %};
  }
  .sidebar-filters__clear { 
    background: none; 
    border: none; 
    color: {% if section.settings.use_theme_colors %}{{ settings.global_section_accent_1_color }}{% else %}{{ section.settings.sidebar_clear_button_color | default: "#000000" }}{% endif %}; 
    text-decoration: underline; 
    cursor: pointer; 
  }
  .sf-group { 
    {% unless section.settings.remove_sidebar_border %}
      border-top: 1px solid {% if section.settings.use_theme_colors %}{{ settings.global_section_text_color | color_modify: 'alpha', 0.06 }}{% else %}{{ section.settings.nav_border_color | color_modify: 'alpha', 0.6 | default: "rgba(0,0,0,.06)" }}{% endif %}; 
    {% else %}
      border-top: none;
    {% endunless %}
    padding-top: 10px; 
    margin-top: 10px; 
    letter-spacing: var(--letter-spacing-body); 
  }
  .sf-group:first-of-type { border-top: 0; padding-top: 10px; margin-top: 10px; }
  .sf-group__title { 
    list-style: none; 
    cursor: pointer; 
    font-weight: var(--font-weight-bold) !important; 
    letter-spacing: var(--letter-spacing-body);
    color: {% if section.settings.use_theme_colors %}{{ settings.global_section_text_color }}{% else %}{{ section.settings.nav_text_color | default: "#000000" }}{% endif %};
  }
  .sf-group__options { display: grid; grid-template-columns: 1fr; gap: 8px; margin-top: 10px; letter-spacing: var(--letter-spacing-body); }
  .sf-group__options--columns { grid-template-columns: 1fr 1fr; }
  .sf-group__options--colors { grid-template-columns: 1fr 1fr; }
  .sf-option { 
    display: flex; 
    align-items: center; 
    gap: 8px; 
    font-size: 14px; 
    letter-spacing: var(--letter-spacing-body);
    color: {% if section.settings.use_theme_colors %}{{ settings.global_section_text_color }}{% else %}{{ section.settings.nav_text_color | default: "#000000" }}{% endif %};
  }
  .sf-input { 
    accent-color: {% if section.settings.use_theme_colors %}{{ settings.global_section_accent_1_color }}{% else %}{{ section.settings.nav_active_color | default: "#000000" }}{% endif %}; 
  }
  
  @media (max-width: 990px) {
    .collection-grid-with-sidebar { grid-template-columns: 1fr; }
    .collection-grid-with-sidebar .collection-nav-sort-bar { margin-bottom: 0 !important; }
    .sidebar-filters { 
      position: relative; 
      top: 0; 
      margin-bottom: 20px;
    }
    .sidebar-filters__inner { 
      border-radius: 8px; 
      padding: 0;
      {% unless section.settings.remove_sidebar_border %}
        border: 1px solid {% if section.settings.use_theme_colors %}{{ settings.global_section_text_color | color_modify: 'alpha', 0.08 }}{% else %}{{ section.settings.nav_border_color | default: "rgba(0,0,0,.08)" }}{% endif %};
      {% else %}
        border: none;
      {% endunless %}
      background: {% if section.settings.use_theme_colors %}{{ settings.global_section_background_color }}{% else %}{{ section.settings.sidebar_background_color | default: '#ffffff' }}{% endif %};
    }
    .sidebar-filters__header { 
      padding: 16px;
      margin-bottom: 0;
      cursor: pointer;
      position: relative;
      display: flex;
      justify-content: space-between;
      align-items: center;
      color: {% if section.settings.use_theme_colors %}{{ settings.global_section_text_color }}{% else %}{{ section.settings.sidebar_text_color | default: "#000000" }}{% endif %};
    }
    .sidebar-filters__header span {
      flex: 1;
      margin-right: 8px;
    }
    .sidebar-filters__clear {
      margin-right: 24px;
      flex-shrink: 0;
