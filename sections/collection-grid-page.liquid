    }
    
    .section-{{ section.id }} .pagination-item--prev,
    .section-{{ section.id }} .pagination-item--next {
      padding: 0 12px;
    }
    
    .section-{{ section.id }} .pagination-info {
      flex-direction: column;
      gap: 8px;
      font-size: 13px;
    }
  }
  
  /* Product image container */
  .section-{{ section.id }} .product-image-container {
    background: {{ section.settings.image_background | default: '#f8f8f8' }};
    position: relative;
    {% unless section.settings.image_aspect_ratio == 'natural' %}
      {% case section.settings.image_aspect_ratio %}
        {% when '1_1' %}aspect-ratio: 1 / 1;
        {% when '2_3' %}aspect-ratio: 2 / 3;
        {% when '3_2' %}aspect-ratio: 3 / 2;
        {% when '4_5' %}aspect-ratio: 4 / 5;
        {% when '16_9' %}aspect-ratio: 16 / 9;
        {% when '3_4' %}aspect-ratio: 3 / 4;
        {% else %}aspect-ratio: auto;
      {% endcase %}
      overflow: hidden;
    {% endunless %}
  }
  
  .section-{{ section.id }} .product-image {
    object-fit: {{ section.settings.image_fit | default: 'contain' }} !important;
    object-position: center center !important;
    {% unless section.settings.image_aspect_ratio == 'natural' %}
      width: 100%;
      height: 100%;
    {% endunless %}
  }
  
  /* Product slider and slides */
  .section-{{ section.id }} .product-slider {
    {% unless section.settings.image_aspect_ratio == 'natural' %}
      width: 100%;
      height: 100%;
    {% endunless %}
  }
  
  .section-{{ section.id }} .product-slide {
    {% unless section.settings.image_aspect_ratio == 'natural' %}
      width: 100%;
      height: 100%;
    {% endunless %}
  }
  
  .section-{{ section.id }} .product-slide img {
    object-fit: {{ section.settings.image_fit | default: 'contain' }} !important;
    object-position: center center !important;
    {% unless section.settings.image_aspect_ratio == 'natural' %}
      width: 100%;
      height: 100%;
    {% endunless %}
  }
  
  /* Sale badge */
  .section-{{ section.id }} .sale-badge {
