    {
      "type": "checkbox",
      "id": "enable_side_filters",
      "label": "Enable side filter menu",
      "default": false,
      "info": "Adds a left sidebar with filter groups (size, color, brand). Filters products on the page without reloading."
    },
    {
      "type": "header",
      "content": "Collection Settings"
