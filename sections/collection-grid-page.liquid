      color: {% if section.settings.use_theme_colors %}{{ settings.global_section_text_color }}{% else %}{{ section.settings.nav_text_color | default: '#000000' }}{% endif %};
    }
    
    .section-{{ section.id }} .sidebar-filters.collapsed .sidebar-filters__header::after {
      transform: translateY(-50%) rotate(-90deg);
    }
    
    .section-{{ section.id }} .sidebar-filters__content {
      max-height: 1000px;
      overflow: visible;
      transition: max-height 0.3s ease, overflow 0.3s ease;
    }
    
    .section-{{ section.id }} .sidebar-filters.collapsed .sidebar-filters__content {
      max-height: 0;
      overflow: hidden;
    }
    
    .section-{{ section.id }} .sf-group {
      padding: 12px 16px;
      margin: 0;
    }
    
    .section-{{ section.id }} .sf-group:first-of-type {
      padding-top: 12px;
      margin-top: 0;
    }
  }
  
  /* Sidebar Filters Apply Button */
  .section-{{ section.id }} .sidebar-filters__apply {
    padding: 16px;
    border-top: 1px solid {% if section.settings.use_theme_colors %}{{ settings.global_section_text_color | color_modify: 'alpha', 0.1 }}{% else %}#e2e8f0{% endif %};
    margin-top: 16px;
  }
  
  .section-{{ section.id }} .sidebar-filters__apply-btn {
    width: 100%;
    cursor: pointer;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border: none;
    outline: none;
  }
</style>

<script>
  // Image slider functionality
  document.addEventListener('DOMContentLoaded', function() {
    {% if section.settings.full_card_clickable %}
      // Full card clickable functionality
      const clickableCards = document.querySelectorAll('.section-{{ section.id }} .product-card.full-card-clickable');
      
      clickableCards.forEach(card => {
        const productUrl = card.getAttribute('data-product-url');
        if (!productUrl) return;
        
        let isSliding = false;
        let startX = 0;
        let startY = 0;
        const slideThreshold = 10; // Minimum distance to consider it a swipe
        
        // Track touch/mouse start for swipe detection
        const handleStart = (e) => {
          isSliding = false;
          const touch = e.touches ? e.touches[0] : e;
          startX = touch.clientX;
          startY = touch.clientY;
        };
        
        // Track movement to detect swipes
        const handleMove = (e) => {
          if (!startX || !startY) return;
          
          const touch = e.touches ? e.touches[0] : e;
          const deltaX = Math.abs(touch.clientX - startX);
          const deltaY = Math.abs(touch.clientY - startY);
          
          // If moved more than threshold, consider it a slide
          if (deltaX > slideThreshold || deltaY > slideThreshold) {
            isSliding = true;
          }
        };
        
        // Handle card click
        const handleCardClick = (e) => {
          // Don't navigate if it was a swipe
          if (isSliding) return;
          
          // Don't navigate if clicking on links, buttons, or form elements
          const clickedElement = e.target;
          if (clickedElement.closest('a, button, input, select, textarea')) {
            return;
          }
          
          // Don't navigate if clicking on slider controls
          if (clickedElement.closest('.product-dots, .dot')) {
            return;
          }
          
          // Navigate to product page
          window.location.href = productUrl;
        };
        
        // Add event listeners
        card.addEventListener('mousedown', handleStart);
        card.addEventListener('mousemove', handleMove);
        card.addEventListener('click', handleCardClick);
        
        card.addEventListener('touchstart', handleStart, { passive: true });
        card.addEventListener('touchmove', handleMove, { passive: true });
        
        // Reset sliding state on touch end
        card.addEventListener('touchend', () => {
          setTimeout(() => { isSliding = false; }, 100);
        }, { passive: true });
        
        card.addEventListener('mouseup', () => {
          setTimeout(() => { isSliding = false; }, 100);
        });
      });
    {% endif %}
    
    const sliders = document.querySelectorAll('.section-{{ section.id }} .product-slider');
    
    sliders.forEach(slider => {
      const wrapper = slider.querySelector('.product-slider-wrapper');
      const slides = slider.querySelectorAll('.product-slide');
      const card = slider.closest('.product-card');
      const dots = card.querySelectorAll('.dot');
      
      if (slides.length <= 1) return; // Skip if there's only one slide
      
      let currentSlide = 0;
      const slideCount = slides.length;
      
      // Initialize dots
      updateDots();
      
      // Touch swipe functionality
      let touchStartX = 0;
      let touchEndX = 0;
      
      slider.addEventListener('touchstart', e => {
        touchStartX = e.changedTouches[0].screenX;
      }, {passive: true});
      
      slider.addEventListener('touchend', e => {
        touchEndX = e.changedTouches[0].screenX;
        handleSwipe();
      }, {passive: true});
      
      // Mouse drag functionality for desktop
      let isDragging = false;
      let startPosX = 0;
      let currentTranslate = 0;
      
      slider.addEventListener('mousedown', e => {
        e.preventDefault();
        isDragging = true;
        startPosX = e.clientX;
        slider.style.cursor = 'grabbing';
      });
      
      slider.addEventListener('mousemove', e => {
        if (!isDragging) return;
        e.preventDefault();
        const moveX = e.clientX - startPosX;
        const slideWidth = slider.offsetWidth;
        
        // Limit movement to prevent excessive drag
        if (Math.abs(moveX) < slideWidth * 0.5) {
          wrapper.style.transform = `translateX(${-currentSlide * 100 + (moveX / slideWidth * 100)}%)`;
        }
      });
      
      document.addEventListener('mouseup', e => {
        if (!isDragging) return;
        
        isDragging = false;
        slider.style.cursor = 'grab';
        
        const moveX = e.clientX - startPosX;
        const threshold = slider.offsetWidth * 0.2; // 20% of slide width
        
        if (moveX < -threshold) {
          // Dragged left - go to next slide
          currentSlide = Math.min(currentSlide + 1, slideCount - 1);
        } else if (moveX > threshold) {
          // Dragged right - go to previous slide
          currentSlide = Math.max(currentSlide - 1, 0);
        }
        
        updateSlider();
      });
      
      document.addEventListener('mouseleave', () => {
        if (isDragging) {
          isDragging = false;
          slider.style.cursor = 'grab';
          updateSlider();
        }
      });
      
      function handleSwipe() {
        const threshold = 50; // Minimum swipe distance
        
        if (touchStartX - touchEndX > threshold) {
          // Swipe left - go to next slide
          currentSlide = Math.min(currentSlide + 1, slideCount - 1);
          updateSlider();
        } else if (touchEndX - touchStartX > threshold) {
          // Swipe right - go to previous slide
          currentSlide = Math.max(currentSlide - 1, 0);
          updateSlider();
        }
      }
      
      // Update slider position
      function updateSlider() {
        wrapper.style.transform = `translateX(-${currentSlide * 100}%)`;
        updateDots();
      }
      
      // Update dots
      function updateDots() {
        if (dots && dots.length) {
          dots.forEach((dot, i) => {
            if (i === currentSlide) {
              dot.classList.add('active');
            } else {
              dot.classList.remove('active');
            }
          });
        }
      }
      
      // Connect dots to slides (if they exist)
      if (dots && dots.length) {
        dots.forEach((dot, i) => {
          dot.addEventListener('click', (e) => {
            e.preventDefault();
            e.stopPropagation();
            currentSlide = i;
            updateSlider();
          });
        });
      }
      });
  
  // Color swatch functionality
  {% if section.settings.show_color_swatches %}
    document.querySelectorAll('.section-{{ section.id }} .color-swatch').forEach(swatch => {
      swatch.addEventListener('click', function(e) {
        e.preventDefault();
        e.stopPropagation();
        
        const productCard = this.closest('.product-card');
        const variantImage = this.getAttribute('data-variant-image');
        const swatches = productCard.querySelectorAll('.color-swatch');
        
        // Remove active class from all swatches in this product
        swatches.forEach(s => s.classList.remove('active'));
        
        // Add active class to clicked swatch
        this.classList.add('active');
        
        // Change product image if variant has an image
        if (variantImage && variantImage !== '') {
          const productImages = productCard.querySelectorAll('.product-image');
          if (productImages.length > 0) {
            // Update the first image (main image)
            productImages[0].src = variantImage;
          }
        }
      });
    });
  {% endif %}
  
  // URL collection detection
    const urlCollectionHandle = {% if url_collection_handle %}'{{ url_collection_handle }}'{% else %}null{% endif %};
    
    // Collection selection functionality
    const collectionLinks = document.querySelectorAll('.section-{{ section.id }} .collection-filter-link');
    const productCards = document.querySelectorAll('.section-{{ section.id }} .product-card');
    
    // Handle initial state based on URL collection or active link
    const activeLink = document.querySelector('.section-{{ section.id }} .collection-filter-link.active');
    if (activeLink) {
      const activeCollection = activeLink.getAttribute('data-collection');
      
      // Only apply JavaScript filtering if not showing all products
      if (activeCollection !== 'all') {
        productCards.forEach(card => {
          const cardCollections = card.getAttribute('data-collection') || '';
          if (cardCollections.includes(activeCollection)) {
            card.style.display = '';
          } else {
            card.style.display = 'none';
          }
        });
      }
    } else {
      // If no active link, show all products by default
      productCards.forEach(card => {
        card.style.display = '';
      });
    }
    
    collectionLinks.forEach(link => {
      link.addEventListener('click', function(e) {
        e.preventDefault();
        
        // Remove active class from all links
        collectionLinks.forEach(l => l.classList.remove('active'));
        
        // Add active class to clicked link
        this.classList.add('active');
        
        const collectionHandle = this.getAttribute('data-collection');
        
        // Show/hide product cards based on collection
        productCards.forEach(card => {
          const cardCollections = card.getAttribute('data-collection') || '';
          
          let shouldShow = false;
          
          if (collectionHandle === 'all') {
            // Always show all products for "Shop All"
            shouldShow = true;
          } else {
            // For specific collections, check if product belongs to that collection
            shouldShow = cardCollections.includes(collectionHandle);
          }
          
          if (shouldShow) {
            card.style.display = '';
          } else {
            card.style.display = 'none';
          }
        });
      });
    });
    
    // Sort functionality
    const sortSelect = document.querySelector('.section-{{ section.id }} .sort-by-dropdown select');
    
    if (sortSelect) {
      sortSelect.addEventListener('change', function() {
        const selectedSort = this.value;
        const productGrid = document.querySelector('.section-{{ section.id }} .product-grid');
        
        // Get only the visible products
        const visibleProducts = Array.from(productCards).filter(card => card.style.display !== 'none');
        
        // Sort products based on selection
        visibleProducts.sort((a, b) => {
          switch(selectedSort) {
            case 'price-ascending':
              return parseFloat(a.getAttribute('data-price')) - parseFloat(b.getAttribute('data-price'));
            case 'price-descending':
              return parseFloat(b.getAttribute('data-price')) - parseFloat(a.getAttribute('data-price'));
            case 'title-ascending':
              return a.getAttribute('data-title').localeCompare(b.getAttribute('data-title'));
            case 'title-descending':
              return b.getAttribute('data-title').localeCompare(a.getAttribute('data-title'));
            case 'created-ascending':
              return new Date(a.getAttribute('data-created')) - new Date(b.getAttribute('data-created'));
            case 'created-descending':
              return new Date(b.getAttribute('data-created')) - new Date(a.getAttribute('data-created'));
            default: // best-selling or default
              return parseInt(a.getAttribute('data-index')) - parseInt(b.getAttribute('data-index'));
          }
        });
        
        // Re-append sorted products to the grid
        visibleProducts.forEach(product => {
          productGrid.appendChild(product);
        });
      });
    }
  });

  // Search functionality
  {% if section.settings.show_search_bar %}
    const searchInput = document.querySelector('.section-{{ section.id }} #product-search-{{ section.id }}');
    const searchClear = document.querySelector('.section-{{ section.id }} .search-clear');
    const productCards = document.querySelectorAll('.section-{{ section.id }} .product-card');
    const sectionElement = document.querySelector('.section-{{ section.id }}');
    
    let searchTimeout;
    
    // Search input handler
    searchInput.addEventListener('input', function(e) {
      const searchTerm = e.target.value.toLowerCase().trim();
      
      // Show/hide clear button
      if (searchTerm.length > 0) {
        searchClear.style.display = 'flex';
        sectionElement.classList.add('searching');
      } else {
        searchClear.style.display = 'none';
        sectionElement.classList.remove('searching');
      }
      
      // Debounce search for better performance
      clearTimeout(searchTimeout);
      searchTimeout = setTimeout(() => {
        performSearch(searchTerm);
      }, 300);
    });
    
    // Clear search handler
    searchClear.addEventListener('click', function() {
      searchInput.value = '';
      searchClear.style.display = 'none';
      sectionElement.classList.remove('searching');
      showAllProducts();
    });
    
    // Perform search function
    function performSearch(searchTerm) {
      if (searchTerm === '') {
        showAllProducts();
        return;
      }
      
      let visibleCount = 0;
      
      productCards.forEach(card => {
        const title = card.getAttribute('data-title')?.toLowerCase() || '';
        const vendor = card.getAttribute('data-vendor')?.toLowerCase() || '';
        const tags = card.getAttribute('data-tags')?.toLowerCase() || '';
        const type = card.getAttribute('data-type')?.toLowerCase() || '';
        
        // Search in title, vendor, tags, and type
        const isMatch = title.includes(searchTerm) || 
                       vendor.includes(searchTerm) || 
                       tags.includes(searchTerm) ||
                       type.includes(searchTerm);
        
        if (isMatch) {
          card.classList.remove('hidden');
          card.style.display = '';
          visibleCount++;
        } else {
          card.classList.add('hidden');
          // Don't set display: none immediately to allow for animation
          setTimeout(() => {
            if (card.classList.contains('hidden')) {
              card.style.display = 'none';
            }
          }, 300);
        }
      });
      
      // Optional: Show "no results" message if needed
      // You can extend this to show a "no results found" message
    }
    
    // Show all products function
    function showAllProducts() {
      productCards.forEach(card => {
        card.classList.remove('hidden');
        card.style.display = '';
      });
    }
    
    // Reset search when collection filter is changed
    const collectionLinks = document.querySelectorAll('.section-{{ section.id }} .collection-filter-link');
    collectionLinks.forEach(link => {
      const originalHandler = link.onclick;
      link.addEventListener('click', function() {
        // Clear search when switching collections
        if (searchInput.value.trim() !== '') {
          searchInput.value = '';
          searchClear.style.display = 'none';
          sectionElement.classList.remove('searching');
          // Let the collection filter handle showing/hiding products
        }
      });
    });
  {% endif %}
</script>

{% if section.settings.enable_side_filters %}
<script>
  (function(){
    const sectionEl = document.currentScript.closest('.shopify-section');
    const sidebar = sectionEl.querySelector('.sidebar-filters');
    if (!sidebar) return;
    const clearBtn = sidebar.querySelector('[data-clear-filters]');
    const cards = sectionEl.querySelectorAll('.product-card');
    
    // Mobile dropdown functionality
    const header = sidebar.querySelector('.sidebar-filters__header');
    const content = sidebar.querySelector('.sidebar-filters__content');
    
    // Initialize as collapsed on mobile
    function initMobileDropdown() {
      if (window.innerWidth <= 767) {
        sidebar.classList.add('collapsed');
      } else {
        sidebar.classList.remove('collapsed');
      }
    }
    
    // Toggle dropdown on header click (mobile only)
    if (header) {
      header.addEventListener('click', function(e) {
        // Only allow dropdown behavior on mobile
        if (window.innerWidth <= 767) {
          // Don't toggle if clicking the clear button or its children
          if (!e.target.matches('.sidebar-filters__clear') && !e.target.closest('.sidebar-filters__clear')) {
            e.preventDefault();
            sidebar.classList.toggle('collapsed');
          }
        }
      });
    }
    
    // Initialize and handle resize
    initMobileDropdown();
    window.addEventListener('resize', initMobileDropdown);
    // Create collection options in sidebar based on section settings
    const sidebarCollections = sidebar.querySelector('[data-sidebar-collections]');
    if (sidebarCollections) {
      // Get collection data from the section settings
      {% if section.settings.show_shop_all_tab %}
        const shopAllItem = document.createElement('label');
        shopAllItem.className = 'sf-option';
        const shopAllInput = document.createElement('input');
        shopAllInput.type = 'checkbox';
        shopAllInput.className = 'sf-input';
        shopAllInput.dataset.filterGroup = 'collection';
        shopAllInput.value = 'all';
        {% if url_collection_handle == null %}
          shopAllInput.checked = true;
        {% endif %}
        const shopAllSpan = document.createElement('span');
        shopAllSpan.textContent = '{{ 'sections.collection_grid.shop_all' | t }}';
        shopAllItem.appendChild(shopAllInput);
        shopAllItem.appendChild(shopAllSpan);
        sidebarCollections.appendChild(shopAllItem);
      {% endif %}
      
      {% if section.settings.show_all_collections %}
        // Add all collections
        {% for collection in collections %}
          {% unless collection.handle == 'all' %}
            const collectionItem{{ forloop.index }} = document.createElement('label');
            collectionItem{{ forloop.index }}.className = 'sf-option';
            const collectionInput{{ forloop.index }} = document.createElement('input');
            collectionInput{{ forloop.index }}.type = 'checkbox';
            collectionInput{{ forloop.index }}.className = 'sf-input';
            collectionInput{{ forloop.index }}.dataset.filterGroup = 'collection';
            collectionInput{{ forloop.index }}.value = '{{ collection.handle }}';
            {% if url_collection_handle == collection.handle %}
              collectionInput{{ forloop.index }}.checked = true;
            {% elsif url_collection_handle == null and forloop.first and section.settings.show_shop_all_tab == false %}
              collectionInput{{ forloop.index }}.checked = true;
            {% endif %}
            const collectionSpan{{ forloop.index }} = document.createElement('span');
            collectionSpan{{ forloop.index }}.textContent = '{{ collection.title }}';
            collectionItem{{ forloop.index }}.appendChild(collectionInput{{ forloop.index }});
            collectionItem{{ forloop.index }}.appendChild(collectionSpan{{ forloop.index }});
            sidebarCollections.appendChild(collectionItem{{ forloop.index }});
          {% endunless %}
        {% endfor %}
      {% else %}
        // Add collections from blocks
        {% for block in section.blocks %}
          {% if block.type == 'collection' and block.settings.collection != blank %}
            const blockCollectionItem{{ forloop.index }} = document.createElement('label');
            blockCollectionItem{{ forloop.index }}.className = 'sf-option';
            const blockCollectionInput{{ forloop.index }} = document.createElement('input');
            blockCollectionInput{{ forloop.index }}.type = 'checkbox';
            blockCollectionInput{{ forloop.index }}.className = 'sf-input';
            blockCollectionInput{{ forloop.index }}.dataset.filterGroup = 'collection';
            blockCollectionInput{{ forloop.index }}.value = '{{ block.settings.collection.handle }}';
            {% assign is_url_collection = false %}
            {% assign is_fallback_active = false %}
            {% if url_collection_handle == block.settings.collection.handle %}
              {% assign is_url_collection = true %}
            {% endif %}
            {% if url_collection_handle == null and forloop.first and section.settings.show_shop_all_tab == false %}
              {% assign is_fallback_active = true %}
            {% endif %}
            {% if is_url_collection or is_fallback_active %}
              blockCollectionInput{{ forloop.index }}.checked = true;
            {% endif %}
            const blockCollectionSpan{{ forloop.index }} = document.createElement('span');
            blockCollectionSpan{{ forloop.index }}.textContent = '{{ block.settings.collection.title }}';
            blockCollectionItem{{ forloop.index }}.appendChild(blockCollectionInput{{ forloop.index }});
            blockCollectionItem{{ forloop.index }}.appendChild(blockCollectionSpan{{ forloop.index }});
            sidebarCollections.appendChild(blockCollectionItem{{ forloop.index }});
          {% endif %}
        {% endfor %}
      {% endif %}
    }

    const inputs = sidebar.querySelectorAll('.sf-input');


    function normalise(str){ return (str||'').toString().toLowerCase().replace(/\s+/g,' ').trim(); }

    function getActive(){
      const groups = {};
      inputs.forEach(i=>{ 
        if(i.checked){ 
          console.log('Checked input:', i.dataset.filterGroup, i.value); // Debug log
          (groups[i.dataset.filterGroup] ||= []).push(i.value); 
        } 
      });
      return groups;
    }

    function matches(card, groups){
      // Enhanced matching for variant options and product attributes
      const vendor = normalise(card.dataset.vendor);
      const tags = (card.dataset.tags||'').toLowerCase();
      const title = normalise(card.dataset.title);
      const type = normalise(card.dataset.type);
      const cardCollections = card.getAttribute('data-collection') || '';

      for (const [group, values] of Object.entries(groups)){
        if (!values.length) continue;
        const any = values.some(v=>{
          const val = v.toLowerCase();
          
          // Match based on filter group type
          if (group === 'collection') {
            // Check if product belongs to this collection
            if (val === 'all') {
              return true; // Show all products for "Shop All"
            } else {
              // Split collections string and check if collection handle is in the array
              const collections = cardCollections.split(' ').filter(c => c.length > 0);
              return collections.includes(val);
            }
          } else if (group === 'size') {
            // Check if size is in title, tags, or variant options
            return title.includes(val) || tags.includes(val);
          } else if (group === 'color') {
            // Check if color is in title, tags, or variant options
            return title.includes(val) || tags.includes(val);
          } else if (group === 'material') {
            // Check if material is in title, tags, or type
            return title.includes(val) || tags.includes(val) || type.includes(val);
          } else if (group === 'style') {
            // Check if style is in title, tags, or type
            return title.includes(val) || tags.includes(val) || type.includes(val);
          } else {
            // Fallback: check all fields
            return vendor.includes(val) || tags.includes(val) || title.includes(val) || type.includes(val);
          }
        });
        if (!any) return false;
      }
      return true;
    }

    function apply(){
      console.log('Apply function called!'); // Debug log
      const groups = getActive();
      console.log('Active groups:', groups); // Debug log
      const hasFilters = Object.values(groups).some(arr=>arr && arr.length);
      console.log('Has filters:', hasFilters); // Debug log
      console.log('Total cards:', cards.length); // Debug log
      
      let visibleCount = 0;
      cards.forEach(card=>{
        if (!hasFilters || matches(card, groups)) {
          card.style.display = '';
          visibleCount++;
        } else {
          card.style.display = 'none';
        }
      });
      console.log('Visible cards after filtering:', visibleCount); // Debug log
    }
    setTimeout(() => {
    apply()
  }, 40)
    
    // Remove automatic filtering on change - now requires Apply button
    // inputs.forEach(i=> i.addEventListener('change', apply));
    
    // Add Apply button event listener
    const applyBtn = sectionEl.querySelector('[data-apply-filters]');
    console.log('Apply button found:', applyBtn); // Debug log
    if (applyBtn) {
      applyBtn.addEventListener('click', function() {
        console.log('Apply button clicked!'); // Debug log
        apply();
      });
    } else {
      console.error('Apply button not found!');
    }
    
    if (clearBtn) clearBtn.addEventListener('click', ()=>{
      inputs.forEach(i=> i.checked = false); apply();
    });
  })();

</script>
{% endif %}

