    }

    .sidebar-filters .sf-group {
      padding: 12px 16px;
      margin: 0;
      {% unless section.settings.remove_sidebar_border %}
        border-top: 1px solid {% if section.settings.use_theme_colors %}{{ settings.global_section_text_color | color_modify: 'alpha', 0.06 }}{% else %}{{ section.settings.nav_border_color | color_modify: 'alpha', 0.6 | default: "rgba(0,0,0,.06)" }}{% endif %};
      {% else %}
        border-top: none;
      {% endunless %}
    }
    .sidebar-filters .sf-group:first-of-type {
      border-top: 0;
      padding: 12px 16px;
    }
  }
  /* Dynamic styles for section */
  .section-{{ section.id }} {
    padding: {{ section.settings.padding_top | default: 40 }}px 0 {{ section.settings.padding_bottom | default: 40 }}px;
    background-color: {% if section.settings.use_theme_colors %}{{ settings.global_section_background_color }}{% else %}{{ section.settings.background_color }}{% endif %};
  }

  /* Search Bar Styles */
  .section-{{ section.id }} .collection-search-bar {
    margin-bottom: 20px;
    max-width: 500px;
    margin-left: auto;
    margin-right: auto;
  }

  .section-{{ section.id }} .search-input-wrapper {
    position: relative;
    display: flex;
    align-items: center;
  }

  .section-{{ section.id }} .product-search-input {
    width: 100%;
    padding: 12px 50px 12px 45px;
    border: 2px solid #e2e8f0;
    border-radius: 8px;
    font-size: 16px;
    font-family: inherit;
    background-color: #ffffff;
    transition: all 0.3s ease;
    outline: none;
  }

  .section-{{ section.id }} .product-search-input:focus {
    border-color: {% if section.settings.use_theme_colors %}{{ settings.global_section_accent_1_color }}{% else %}#3b82f6{% endif %};
    box-shadow: 0 0 0 3px {% if section.settings.use_theme_colors %}{{ settings.global_section_accent_1_color | color_modify: 'alpha', 0.1 }}{% else %}rgba(59, 130, 246, 0.1){% endif %};
  }

  .section-{{ section.id }} .search-icon {
    position: absolute;
    left: 15px;
    color: #64748b;
    pointer-events: none;
    display: flex;
    align-items: center;
  }

  .section-{{ section.id }} .search-clear {
    position: absolute;
    right: 15px;
    background: none;
    border: none;
    color: #64748b;
    cursor: pointer;
    padding: 4px;
    border-radius: 4px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.2s ease;
  }

  .section-{{ section.id }} .search-clear:hover {
    background-color: #f1f5f9;
    color: #334155;
  }

  /* Search states */
  .section-{{ section.id }}.searching .product-card {
    transition: opacity 0.3s ease, transform 0.3s ease;
  }

  .section-{{ section.id }}.searching .product-card.hidden {
    opacity: 0;
    transform: scale(0.95);
    pointer-events: none;
  }

  /* Full card clickable styles */
  .section-{{ section.id }} .product-card.full-card-clickable {
    cursor: pointer;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .section-{{ section.id }} .product-card.full-card-clickable:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 25px rgba(0, 0, 0, 0.15);
  }

  .section-{{ section.id }} .product-card.full-card-clickable:active {
    transform: translateY(0);
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.1);
  }

  /* Ensure interactive elements still work within clickable cards */
  .section-{{ section.id }} .product-card.full-card-clickable a,
  .section-{{ section.id }} .product-card.full-card-clickable button,
  .section-{{ section.id }} .product-card.full-card-clickable .product-dots,
  .section-{{ section.id }} .product-card.full-card-clickable .dot {
    position: relative;
    z-index: 2;
  }
  
  /* Override global star styles with section-specific styling */
  .section-{{ section.id }} .star {
