  padding: 0 !important;
}

/* Enhanced accent text styling - New Hero Section */
.section-{{ section.id }}.custom-hero .section-accent-text {
  /* Always apply basic styling first */
  margin-left: {{ section.settings.accent_text_margin }}px !important;
  padding-right: 4px !important;
  display: inline !important;
  line-height: inherit !important;
  word-wrap: break-word !important;
  overflow-wrap: break-word !important;

  {% if section.settings.use_global_accent_typography %}
    /* Use Global Accent Typography */
    font-family: var(--font-accent-family, var(--font-body-family)) !important;
    font-style: var(--font-accent-style, normal) !important;
    font-weight: var(--font-accent-weight, 400) !important;
    letter-spacing: var(--font-accent-letter-spacing, 0px) !important;
    text-transform: var(--font-accent-text-transform, none) !important;
  {% else %}
  /* Use Section-Specific Accent Typography */
  {% if section.settings.accent_font_family != 'inherit' %}
    {% case section.settings.accent_font_family %}
    {% when 'serif' %}
      font-family: serif !important;
    {% when 'Georgia Pro' %}
      font-family: 'Georgia Pro'
      , Georgia
      , serif !important;
    {% when 'Bodoni Moda' %}
      font-family: 'Bodoni Moda'
      , Georgia
      , serif !important;
    {% when 'Instrument Serif' %}
      font-family: 'Instrument Serif'
      , Georgia
      , serif !important;
    {% when 'DM Serif Text' %}
      font-family: 'DM Serif Text'
      , Georgia
      , serif !important;
    {% when 'Nothing You Could Do' %}
      font-family: 'Nothing You Could Do'
      , cursive !important;
    {% else %}
      font-family: var(--font-body-family) !important;
    {% endcase %}
  {% else %}
    font-family: var(--font-body-family) !important;
  {% endif %}

  {% if section.settings.accent_font_style != 'normal' %}
    font-style: {{ section.settings.accent_font_style }}
     !important;
  {% else %}
    font-style: normal !important;
  {% endif %}

  {% if section.settings.accent_font_weight != 'inherit' %}
    font-weight: {{ section.settings.accent_font_weight }}
     !important;
  {% else %}
    font-weight: inherit !important;
  {% endif %}
{% endif %}

/* Color and Gradient Application */
{%- if section.settings.use_theme_colors -%}
  {%- comment -%} When theme colors are enabled
  , use global accent text gradient {%- endcomment -%}
{% if settings.global_accent_text_gradient_dark != blank %}
  background: {{ settings.global_accent_text_gradient_dark }}
   !important;
  -webkit-background-clip: text !important;
  -webkit-text-fill-color: transparent !important;
  background-clip: text !important;
  text-fill-color: transparent !important;
{% else %}
  color: {{ settings.global_section_accent_1_color | default: '#ef4a65' }}
   !important;
{% endif %}
{%- elsif section.settings.use_accent_gradient and section.settings.accent_text_gradient != blank -%}
{%- comment -%} Use section-specific gradient when theme colors are off {%- endcomment -%}
background: {{ section.settings.accent_text_gradient }}
 !important;
-webkit-background-clip: text !important;
-webkit-text-fill-color: transparent !important;
background-clip: text !important;
text-fill-color: transparent !important;
{%- else -%}
{%- comment -%} Use solid color as fallback {%- endcomment -%}
color: {{ section.settings.heading_accent_color | default: '#ef4a65' }}
 !important;
{%- endif -%}
}

/* Fallback solid color for accent text when gradient is not used */
.section-{{ section.id }}.custom-hero .section-accent-text.no-gradient
, .section-{{ section.id }}.new-hero-accent-text.no-gradient {
  color: {{ section.settings.heading_accent_color | default: '#ef4a65' }}
   !important;
}

/* High specificity override for custom-hero accent text */
.section-{{ section.id }}.custom-hero .custom-hero__title .section-accent-text.custom-hero-accent
