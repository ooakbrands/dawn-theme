{% comment %} Google Fonts for accent text customization {% endcomment %}
{% unless section.settings.use_global_accent_typography %}
  {% if section.settings.accent_font_family != 'inherit' and section.settings.accent_font_family != 'serif' %}
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link
      rel="preconnect"
      href="https://fonts.gstatic.com"
      crossorigin>
    {% case section.settings.accent_font_family %}
      {% when 'Georgia Pro' %}
        <link href="https://fonts.googleapis.com/css2?family=Georgia+Pro:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500;1,600;1,700&display=swap" rel="stylesheet">
      {% when 'Bodoni Moda' %}
        <link href="https://fonts.googleapis.com/css2?family=Bodoni+Moda:ital,opsz,wght@0,6..96,400;0,6..96,500;0,6..96,600;0,6..96,700;0,6..96,800;1,6..96,400;1,6..96,500;1,6..96,600;1,6..96,700;1,6..96,800&display=swap" rel="stylesheet">
      {% when 'Instrument Serif' %}
        <link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&display=swap" rel="stylesheet">
      {% when 'DM Serif Text' %}
        <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Text:ital@0;1&display=swap" rel="stylesheet">
      {% when 'Nothing You Could Do' %}
        <link href="https://fonts.googleapis.com/css2?family=Nothing+You+Could+Do&display=swap" rel="stylesheet">
    {% endcase %}
  {% endif %}
{% endunless %}

{{ 'hero.css' | asset_url | stylesheet_tag }}
{% style %}
  /* Rating block container background styles */
  {% for block in section.blocks %}
    {% if block.type == 'rating' and block.settings.enable_container_background %}
      .custom-hero__rating-wrapper[data-block-id="{{ block.id }}"] {
        background-color: {{ block.settings.container_background_color | default: '#f8f9fa' }}
         !important;
        padding: {{ block.settings.container_padding_vertical | default: 12 }}px {{ block.settings.container_padding_horizontal | default: 20 }}px !important;
        border-radius: {{ block.settings.container_border_radius | default: 8 }}px !important;
        display: inline-block !important;
        width: auto !important;
        {% if block.settings.enable_container_border %}
          border: {{ block.settings.container_border_width | default: 1 }}px solid {{ block.settings.container_border_color | default: '#e9ecef' }}
           !important;
        {% endif %}
      }
    {% endif %}
  {% endfor %}

  /* Rating text margin fix */
  .custom-hero__rating-text p {
    margin: 0;
  }

  /* Block margin customization */
  {% for block in section.blocks %}
    {% case block.type %}
    {% when 'badge' %}
    .custom-hero__badge-wrapper[data-block-id="{{ block.id }}"] {
      margin-top: {{ block.settings.margin_top | default: 0 }}px !important;
      margin-bottom: {{ block.settings.margin_bottom | default: 16 }}px !important;
    }
    .custom-hero__badge-wrapper[data-block-id="{{ block.id }}"] .custom-hero__badge {
      {% if block.settings.enable_container_background %}
        background-color: {{ block.settings.container_background_color | default: '#f8f9fa' }} !important;
        padding: {{ block.settings.container_padding_vertical | default: 8 }}px {{ block.settings.container_padding_horizontal | default: 16 }}px !important;
        border-radius: {{ block.settings.container_border_radius | default: 20 }}px !important;
        display: inline-block !important;
      {% endif %}
      font-size: {{ block.settings.badge_font_size | default: 14 }}px !important;
      letter-spacing: var(--letter-spacing-body) !important;
    }
  {% when 'rating' %}
  .custom-hero__rating-wrapper[data-block-id="{{ block.id }}"] {
    margin-top: {{ block.settings.margin_top | default: 0 }}px !important;
    margin-bottom: {{ block.settings.margin_bottom | default: 16 }}px !important;
  }
{% when 'heading' %}
.section-{{ section.id }}.custom-hero .custom-hero__title[data-block-id="{{ block.id }}"],
.section-{{ section.id }}.custom-hero .custom-hero__title.section-heading[data-block-id="{{ block.id }}"],
.custom-hero__content-wrapper .custom-hero__title[data-block-id="{{ block.id }}"] {
  margin-top: {{ block.settings.margin_top | default: 0 }}px !important;
  margin-bottom: {{ block.settings.margin_bottom | default: 16 }}px !important;
  color: {% if section.settings.use_theme_colors %}{{ settings.global_section_text_color }}
{% else %}{{ section.settings.heading_color }}
{% endif %}
 !important;
}
{% when 'subtitle' %}
.section-{{ section.id }}.custom-hero .custom-hero__subtitle[data-block-id="{{ block.id }}"],
.custom-hero__content-wrapper .custom-hero__subtitle[data-block-id="{{ block.id }}"] {
  margin-top: {{ block.settings.margin_top | default: 0 }}px !important;
  margin-bottom: {{ block.settings.margin_bottom | default: 24 }}px !important;
}
{% when 'benefits' %}
.custom-hero__benefits[data-block-id="{{ block.id }}"] {
  margin-top: {{ block.settings.margin_top | default: 0 }}px !important;
  margin-bottom: {{ block.settings.margin_bottom | default: 24 }}px !important;
}
{% when 'button' %}
.custom-hero__button-wrapper[data-block-id="{{ block.id }}"] {
  margin-top: {{ block.settings.margin_top | default: 0 }}px !important;
  margin-bottom: {{ block.settings.margin_bottom | default: 24 }}px !important;
  {% if block.settings.full_width %}
    width: 100% !important;
  {% endif %}
}
{% if block.settings.full_width %}
  .section-{{ section.id }}.custom-hero .custom-hero__button-wrapper[data-block-id="{{ block.id }}"],
  .custom-hero__content-wrapper .custom-hero__button-wrapper[data-block-id="{{ block.id }}"] {
    width: 100% !important;
    display: block !important;
  }
  .section-{{ section.id }}.custom-hero .custom-hero__button-wrapper[data-block-id="{{ block.id }}"] .custom-hero__button,
  .section-{{ section.id }}.custom-hero .custom-hero__button-wrapper[data-block-id="{{ block.id }}"] .theme-button,
  .custom-hero__content-wrapper .custom-hero__button-wrapper[data-block-id="{{ block.id }}"] .custom-hero__button,
  .custom-hero__content-wrapper .custom-hero__button-wrapper[data-block-id="{{ block.id }}"] .theme-button {
    width: 100% !important;
    display: block !important;
    text-align: center !important;
    max-width: none !important;
  }
{% endif %}
{% if block.settings.full_width_mobile_only %}
  @media (max-width: 768px) {
    .section-{{ section.id }}.custom-hero .custom-hero__button-wrapper[data-block-id="{{ block.id }}"],
    .custom-hero__content-wrapper .custom-hero__button-wrapper[data-block-id="{{ block.id }}"] {
      width: 100% !important;
      display: block !important;
    }
    .custom-hero .custom-hero__button-wrapper[data-block-id="{{ block.id }}"] .custom-hero__button,
    .custom-hero .custom-hero__button-wrapper[data-block-id="{{ block.id }}"] .theme-button,
    .custom-hero__content-wrapper .custom-hero__button-wrapper[data-block-id="{{ block.id }}"] .custom-hero__button,
    .custom-hero__content-wrapper .custom-hero__button-wrapper[data-block-id="{{ block.id }}"] .theme-button {
      width: 100% !important;
      display: block !important;
      text-align: center !important;
      max-width: none !important;
    }
  }
{% endif %}
{% when 'guarantee' %}
.custom-hero__guarantee[data-block-id="{{ block.id }}"] {
  margin-top: {{ block.settings.margin_top | default: 0 }}px !important;
  margin-bottom: {{ block.settings.margin_bottom | default: 0 }}px !important;
  text-align: {{ block.settings.alignment | default: 'center' }} !important;
}
{% endcase %}
{% endfor %}

.section-{{ section.id }}.custom-hero {
  {% if section.settings.use_theme_colors %}
    {% if settings.global_section_use_gradient_background %}
      background: {{ settings.global_section_gradient_background }};
    {% else %}
      background-color: {{ settings.global_section_background_color }};
    {% endif %}
  {% elsif section.settings.enable_gradient %}
    background: {{ section.settings.section_gradient_background }};
  {% else %}
    background-color: {{ section.settings.section_bg }};
  {% endif %}
  padding: {{ section.settings.section_padding_vertical }}px {{ section.settings.section_padding_horizontal }}px;
  width: 100%;
  display: flex;
  justify-content: center;
  align-items: center;
}

@media screen and (max-width: 768px) {
  .section-{{ section.id }}.custom-hero {
    padding: {{ section.settings.section_padding_vertical_mobile }}px {{ section.settings.section_padding_horizontal_mobile }}px;
  }
}

.custom-hero__container {
  {% if section.settings.contain_section %}
    max-width: {{ section.settings.container_max_width }}px;
    margin: 0 auto;
    padding: {{ section.settings.container_padding_top }}px {{ section.settings.container_padding_right }}px {{ section.settings.container_padding_bottom }}px {{ section.settings.container_padding_left }}px;
    border-radius: {{ section.settings.border_radius }}px;
    {% if section.settings.enable_container_gradient %}
      background: {{ section.settings.container_gradient_background }};
    {% else %}
      background-color: {{ section.settings.container_bg_color }};
    {% endif %}
    {% if section.settings.enable_border %}
      border: {{ section.settings.border_width }}px {{ section.settings.border_style }} {{ section.settings.border_color }};
    {% endif %}
    {% if section.settings.enable_shadow %}
      box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
    {% endif %}
    {% if section.settings.fit_image_to_height %}
      overflow: hidden;
    {% endif %}
  {% endif %}
}

@media screen and (max-width: 768px) {
  .custom-hero__container {
    {% if section.settings.contain_section %}
      padding: {{ section.settings.container_padding_top_mobile }}px {{ section.settings.container_padding_right_mobile }}px {{ section.settings.container_padding_bottom_mobile }}px {{ section.settings.container_padding_left_mobile }}px;
    {% endif %}
  }
}

.custom-hero__flex {
  align-items: {% if section.settings.fit_image_to_height %}stretch{% else %}center{% endif %};
  gap: {% if section.settings.fit_image_to_height %}0{% else %}40px{% endif %};

}

@media screen and (max-width: 768px) {
  .custom-hero__flex {
    {% if section.settings.fit_image_to_height %}
      flex-direction: column;
    {% endif %}
  }
}

{% if section.settings.fit_image_to_height %}
  .custom-hero__image-wrapper {
    padding: 0;
    overflow: hidden;
    {% if section.settings.contain_section %}
      /* When container is enabled, image wrapper takes full width */
      flex: 1;
    {% endif %}
  }

  @media screen and (max-width: 768px) {
    .custom-hero__image-wrapper {
      {% if section.settings.contain_section %}
        /* Mobile: Ensure image stays within container boundaries */
        width: 100%;
        max-width: 100%;
        flex: none;
      {% endif %}
    }
  }
{% endif %}

.custom-hero__image {
  border-radius: {% if section.settings.fit_image_to_height %}0{% else %}8px{% endif %};
{% if section.settings.fit_image_to_height %}
  height: 100%;
  object-fit: cover;
  width: 100%;
{% endif %}
}

.custom-hero__video {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
  border-radius: {% if section.settings.fit_image_to_height %}0{% else %}8px{% endif %};
  background-color: {% if section.settings.use_theme_colors %}{{ settings.global_section_background_color }}
{% else %}{{ section.settings.section_bg }}
{% endif %};
  z-index: 2;
}

/* Force hide video controls immediately, even during page load */
.custom-hero__video {
  /* Remove any browser default controls */
  -webkit-appearance: none;
  -moz-appearance: none;
  appearance: none;
}

.custom-hero__video::-webkit-media-controls {
  display: none !important;
  opacity: 0 !important;
  visibility: hidden !important;
}

.custom-hero__video::-webkit-media-controls-panel {
  display: none !important;
  opacity: 0 !important;
  visibility: hidden !important;
}

.custom-hero__video::-webkit-media-controls-play-button {
  display: none !important;
  opacity: 0 !important;
  visibility: hidden !important;
}

.custom-hero__video::-webkit-media-controls-start-playback-button {
  display: none !important;
  opacity: 0 !important;
  visibility: hidden !important;
}

.custom-hero__video::-webkit-media-controls-enclosure {
  display: none !important;
}

.custom-hero__video::-webkit-media-controls-timeline {
  display: none !important;
}

.custom-hero__video::-webkit-media-controls-current-time-display {
  display: none !important;
}

.custom-hero__video::-webkit-media-controls-time-remaining-display {
  display: none !important;
}

.custom-hero__video::-webkit-media-controls-mute-button {
  display: none !important;
}

.custom-hero__video::-webkit-media-controls-toggle-closed-captions-button {
  display: none !important;
}

.custom-hero__video::-webkit-media-controls-volume-slider {
  display: none !important;
}

.custom-hero__video::-webkit-media-controls-fullscreen-button {
  display: none !important;
}

.custom-hero__video::-moz-media-controls {
  display: none !important;
}

.custom-hero__video::-ms-media-controls {
  display: none !important;
}

/* Additional fallback to ensure no controls show */
.custom-hero__video[controls] {
  -webkit-appearance: none !important;
  -moz-appearance: none !important;
  appearance: none !important;
}

/* Hide video initially and fade in when loaded */
.custom-hero__video {
  opacity: 0;
  transition: opacity 0.3s ease-in-out;
}

.custom-hero__video.loaded {
  opacity: 1;
}

/* Video container to handle video and fallback positioning */
.custom-hero__video-container {
  position: relative;
  width: 100%;
  height: 100%;
  background-color: {% if section.settings.use_theme_colors %}{{ settings.global_section_background_color }}
{% else %}{{ section.settings.section_bg }}
{% endif %};
  display: flex;
  align-items: center;
  justify-content: center;
}

/* Loading indicator for video */
.custom-hero__video-container::before {
  content: "";
  position: absolute;
  top: 50%;
  left: 50%;
  width: 40px;
  height: 40px;
  margin: -20px 0 0 -20px;
  border: 2px solid rgba(255, 255, 255, 0.2);
  border-top: 2px solid rgba(255, 255, 255, 0.6);
  border-radius: 50%;
  animation: videoLoadingSpin 1s linear infinite;
  z-index: 1;
  opacity: 1;
  transition: opacity 0.3s ease;
}

/* Hide loading indicator when video loads or errors */
.custom-hero__video-container.video-loaded::before,
.custom-hero__video-container.video-error::before {
  opacity: 0;
}

@keyframes videoLoadingSpin {
  0% {
    transform: rotate(0deg);
  }
  100% {
    transform: rotate(360deg);
  }
}

/* Fallback image - hidden by default, only shows if video fails */
.custom-hero__video-fallback {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
  border-radius: {% if section.settings.fit_image_to_height %}0{% else %}8px{% endif %};
  opacity: 0;
  transition: opacity 0.3s ease-in-out;
  z-index: 1;
}

/* Show fallback image only when video fails to load */
.custom-hero__video-container.video-error .custom-hero__video-fallback {
  opacity: 1;
}

/* Hide video when it fails to load */
.custom-hero__video-container.video-error .custom-hero__video {
  opacity: 0;
}

