<section class="custom-hero section-{{ section.id }} page-fade-in">
  <div class="custom-hero__container">
    <div class="custom-hero__flex custom-hero__flex--image-{{ section.settings.image_position }}">
      <!-- Product Image -->
      <div class="custom-hero__image-wrapper">
        {% if section.settings.hero_video != blank %}
          <!--
            Video Implementation Notes:
            - No poster attribute to prevent image flash
            - Video starts hidden (opacity: 0) and fades in when loaded
            - Fallback image only shows if video fails to load
            - Loading spinner shows while video loads
            - Preload helps with faster loading
          -->
          <link
            rel="preload"
            as="video"
            href="{{ section.settings.hero_video.sources[1].url }}"
            type="video/mp4">

          <div class="custom-hero__video-container">
            <video
              class="custom-hero__video"
              autoplay
              muted
              loop
              playsinline
              preload="auto"
              webkit-playsinline
              x5-playsinline>
              <source src="{{ section.settings.hero_video.sources[1].url }}" type="video/mp4">
            </video>
            <!-- Fallback image that only shows if video fails to load -->
            {% if section.settings.hero_image %}
              {{
                section.settings.hero_image | image_url: width: 800 | image_tag: class: 'custom-hero__video-fallback', loading: 'lazy', alt: section.settings.heading
              }}
            {% endif %}
          </div>
        {% elsif section.settings.hero_image %}
          {{
            section.settings.hero_image | image_url: width: 800 | image_tag: class: 'custom-hero__image', loading: 'lazy', alt: section.settings.heading
          }}
        {% else %}
          {{ 'image' | placeholder_svg_tag: 'custom-hero__image placeholder' }}
        {% endif %}
      </div>

      <!-- Product Content -->
      <div class="custom-hero__content">
        <div class="custom-hero__content-wrapper">
          {% for block in section.blocks %}
            {% case block.type %}
              {% when 'badge' %}
                <div
                  class="custom-hero__badge-wrapper"
                  data-block-id="{{ block.id }}"
                  {{ block.shopify_attributes }}>
                  <div class="custom-hero__badge">{{ block.settings.badge_text }}</div>
                </div>

              {% when 'rating' %}
                <div
                  class="custom-hero__rating-wrapper{% if block.settings.enable_container_background %} has-container-background{% endif %}"
                  data-block-id="{{ block.id }}"
                  {{ block.shopify_attributes }}>
                  <div class="custom-hero__rating-container">
                    {% if block.settings.profile_image_1 != blank or block.settings.profile_image_2 != blank or block.settings.profile_image_3 != blank
                    %}
                      <div class="custom-hero__profile-images">
                        {% if block.settings.profile_image_1 %}
                          {{
                            block.settings.profile_image_1 | image_url: width: 24, height: 24 | image_tag: class: 'custom-hero__profile-image', loading: 'lazy', alt: 'Profile Image'
                          }}
                        {% endif %}
                        {% if block.settings.profile_image_2 %}
                          {{
                            block.settings.profile_image_2 | image_url: width: 24, height: 24 | image_tag: class: 'custom-hero__profile-image', loading: 'lazy', alt: 'Profile Image'
                          }}
                        {% endif %}
                        {% if block.settings.profile_image_3 %}
                          {{
