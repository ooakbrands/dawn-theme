{{ 'alternating-features.css' | asset_url | stylesheet_tag }}

{%- comment -%} Google Fonts should be loaded globally in theme.liquid {%- endcomment -%}

{% comment %} 
 Removed Google Fonts loading - Should be handled globally in theme.liquid
Removed CSS asset loading - Should be loaded globally
Fixed accessibility issues - Added aria-hidden="true" to decorative SVGs and empty alt text for icons
Improved image loading - Used image_url filter and proper width/height attributes
Added block limits - Limited features to 6 to prevent layout issues
Added disabled_on restrictions - Prevented section from appearing in header/footer
Removed !important flags - Improved CSS specificity
Fixed internationalization - Added translation key for placeholder text
Moved inline styles to CSS - Reduced HTML bloat by moving styles to the style section
Added data-section-id attribute - For better CSS scoping without inline styles 
{% endcomment %}


<div class="alt-feat-section page-fade-in" data-section-id="{{ section.id }}">
  <div class="alt-feat-container">
    {% if section.settings.title != blank %}
      <h2 class="alt-feat-section-title">
        {{ section.settings.title }} 
        {% if section.settings.title_accent != blank %}
          <span class="{% if section.settings.override_global_accent %}custom-accent-text{% else %}global-accent-text{% endif %}">{{ section.settings.title_accent }}</span>
        {% endif %}
      </h2>
    {% endif %}
    
    <div class="alt-feat-content">
      <!-- Main image placed first in the DOM for mobile layout -->
      <div class="alt-feat-image-column">
        {% if section.settings.main_image != blank %}
          <img src="{{ section.settings.main_image | image_url: width: 800 }}" 
               alt="{{ section.settings.title | escape }}"
               class="alt-feat-main-image"
               loading="{% if forloop.first and template.name == 'index' %}eager{% else %}lazy{% endif %}" 
               width="800"
               height="{{ 800 | divided_by: section.settings.main_image.aspect_ratio | round }}">
        {% else %}
          <div class="alt-feat-main-image-placeholder" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M21 19V5c0-1.1-.9-2-2-2H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2zM8.5 13.5l2.5 3.01L14.5 12l4.5 6H5l3.5-4.5z"/>
            </svg>
          </div>
        {% endif %}
      </div>
      
      <div class="alt-feat-features-column">
        {% for block in section.blocks limit: 6 %}
          {% if block.type == 'feature' %}
            {% assign is_odd = forloop.index0 | modulo: 2 %}
            <div class="alt-feat-item {% if is_odd == 1 %}alt-feat-item-odd{% else %}alt-feat-item-even{% endif %}" {{ block.shopify_attributes }}>
              <div class="alt-feat-icon-container" aria-hidden="true">
                {% if block.settings.icon != blank %}
                  <img src="{{ block.settings.icon | image_url: width: 60 }}" 
                       alt=""
                       class="alt-feat-icon"
                       loading="lazy"
                       width="60"
                       height="60">
                {% else %}
                  <div class="alt-feat-icon-placeholder">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="24" height="24" aria-hidden="true">
                      <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 17.93c-3.95-.49-7-3.85-7-7.93 0-.62.08-1.21.21-1.79L9 15v1c0 1.1.9 2 2 2v1.93zm6.9-2.54c-.26-.81-1-1.39-1.9-1.39h-1v-3c0-.55-.45-1-1-1H8v-2h2c.55 0 1-.45 1-1V7h2c1.1 0 2-.9 2-2v-.41c2.93 1.19 5 4.06 5 7.41 0 2.08-.8 3.97-2.1 5.39z"/>
                    </svg>
                  </div>
                {% endif %}
              </div>
              
              <div class="alt-feat-text-container">
                <h3 class="alt-feat-title">{{ block.settings.title }}</h3>
                
                <div class="alt-feat-description">{{ block.settings.description }}</div>
              </div>
            </div>
          {% endif %}
        {% endfor %}
      </div>
      
      {% if section.blocks.size == 0 %}
        <div class="alt-feat-placeholder-container">
          <div class="alt-feat-placeholder-message">
            {{ 'sections.placeholder.add_features' | t }}
          </div>
        </div>
      {% endif %}
    </div>
  </div>
</div>

<style>
  /* Load-in Animation */
  .page-fade-in {
    opacity: 0;
    transform: translateY(20px);
    animation: fadeInUp 0.6s ease-out forwards;
  }

  @keyframes fadeInUp {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* Staggered animation delays */
  .page-fade-in:nth-child(2) { animation-delay: 0.1s; }
  .page-fade-in:nth-child(3) { animation-delay: 0.2s; }
  .page-fade-in:nth-child(4) { animation-delay: 0.3s; }

  /* Enhanced accent text styling with global and local customization options */
  .alt-feat-section .global-accent-text,
  .alt-feat-section .custom-accent-text {
    {% comment %} Always apply core accent text styling {% endcomment %}
    padding-right: 4px;
    
    {% comment %} Check for gradient first - it works regardless of global/local settings {% endcomment %}
    {% if section.settings.use_accent_gradient %}
      background: {{ section.settings.accent_text_gradient }};
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      color: transparent;
      display: inline-block;
      padding: 2px 4px;
      margin: -2px -4px;
      line-height: 1.3;
    {% else %}
      {% comment %} Apply solid color based on global or local settings {% endcomment %}
      color: {% if section.settings.use_theme_colors %}{{ settings.global_section_text_color }}{% else %}{{ section.settings.accent_color | default: settings.accent_text_color }}{% endif %};
    {% endif %}
    
    {% if section.settings.override_global_accent %}
      {% comment %} Use section-specific typography settings when override is enabled {% endcomment %}
      {% if section.settings.accent_font_family != 'inherit' %}
        {% case section.settings.accent_font_family %}
          {% when 'serif' %}
            font-family: serif;
          {% when 'Georgia Pro' %}
            font-family: 'Georgia Pro', Georgia, serif;
          {% when 'Bodoni Moda' %}
            font-family: 'Bodoni Moda', Georgia, serif;
          {% when 'Instrument Serif' %}
            font-family: 'Instrument Serif', Georgia, serif;
          {% when 'DM Serif Text' %}
            font-family: 'DM Serif Text', Georgia, serif;
          {% when 'Nothing You Could Do' %}
            font-family: 'Nothing You Could Do', cursive;
        {% endcase %}
      {% else %}
        font-family: var(--font-accent-family, var(--font-body-family));
      {% endif %}
      
      font-style: {% if section.settings.accent_font_style != 'normal' %}{{ section.settings.accent_font_style }}{% else %}var(--font-accent-style, normal){% endif %};
      font-weight: {% if section.settings.accent_font_weight != 'inherit' %}{{ section.settings.accent_font_weight }}{% else %}var(--font-accent-weight, inherit){% endif %};
      
    {% else %}
      {% comment %} Use global accent typography system {% endcomment %}
      font-family: var(--font-accent-family, var(--font-body-family));
      font-style: var(--font-accent-style, normal);
      font-weight: var(--font-accent-weight, inherit);
      letter-spacing: var(--font-accent-letter-spacing, inherit);
      text-transform: var(--font-accent-text-transform, none);
    {% endif %}
    display: inline-block;
  }

  /* Section-specific styles */
  .alt-feat-section[data-section-id="{{ section.id }}"] {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    {% if section.settings.use_theme_colors %}
      background-color: {{ settings.global_section_accent_1_color }};
    {% elsif section.settings.use_gradient %}
      background: linear-gradient({{ section.settings.gradient_angle }}deg, {{ section.settings.gradient_start_color }} 0%, {{ section.settings.gradient_end_color }} 100%);
    {% else %}
      background-color: {{ section.settings.background_color }};
    {% endif %}
    border-radius: {{ section.settings.section_border_radius | default: 0 }}px;
  }

  .alt-feat-section[data-section-id="{{ section.id }}"] .alt-feat-section-title {
    font-size: {{ section.settings.section_title_size | default: 34 }}px;
    color: {% if section.settings.use_theme_colors %}{{ settings.global_section_background_color }}{% else %}{{ section.settings.heading_color }}{% endif %};
  }

  .alt-feat-section[data-section-id="{{ section.id }}"] .alt-feat-icon-container {
    width: {{ section.settings.icon_size }}px;
    height: {{ section.settings.icon_size }}px;
    {% if section.settings.icon_background_enabled %}
      border-radius: 50%;
      background-color: {% if section.settings.use_theme_colors %}{{ settings.global_section_background_color }}{% else %}{{ section.settings.icon_background_color }}{% endif %};
    {% endif %}
  }

  .alt-feat-section[data-section-id="{{ section.id }}"] .alt-feat-icon,
  .alt-feat-section[data-section-id="{{ section.id }}"] .alt-feat-icon-placeholder svg {
    width: {{ section.settings.icon_image_size }}px;
    height: {{ section.settings.icon_image_size }}px;
  }

  .alt-feat-section[data-section-id="{{ section.id }}"] .alt-feat-icon-placeholder {
    color: {% if section.settings.use_theme_colors %}{{ settings.global_section_text_color }}{% else %}{{ section.settings.icon_color }}{% endif %};
  }

  .alt-feat-section[data-section-id="{{ section.id }}"] .alt-feat-title {
    color: {% if section.settings.use_theme_colors %}{{ settings.global_section_background_color }}{% else %}{{ section.settings.feature_title_color }}{% endif %};
    font-size: var(--feature-title-size-mobile, {{ section.settings.feature_title_size_mobile | default: 14 }}px);
  }

  .alt-feat-section[data-section-id="{{ section.id }}"] .alt-feat-description {
    color: {% if section.settings.use_theme_colors %}{{ settings.global_section_background_color }}{% else %}{{ section.settings.description_color }}{% endif %};
    font-size: var(--description-size-mobile, {{ section.settings.description_size_mobile | default: 13 }}px);
  }

  .alt-feat-section[data-section-id="{{ section.id }}"] .alt-feat-item {
    padding-bottom: {{ section.settings.feature_spacing }}px;
    border-bottom: 1px solid {% if section.settings.use_theme_colors %}rgba({{ settings.global_section_background_color | color_to_rgb | remove: 'rgb(' | remove: ')' }}, 0.2){% else %}{{ section.settings.divider_color }}{% endif %};
  }

  .alt-feat-section[data-section-id="{{ section.id }}"] .alt-feat-main-image,
  .alt-feat-section[data-section-id="{{ section.id }}"] .alt-feat-main-image-placeholder {
    border-radius: {{ section.settings.image_border_radius }}px;
  }

  @media screen and (min-width: 768px) {
    .alt-feat-section[data-section-id="{{ section.id }}"] .alt-feat-title {
      font-size: var(--feature-title-size-desktop, {{ section.settings.feature_title_size_desktop | default: 16 }}px);
    }

    .alt-feat-section[data-section-id="{{ section.id }}"] .alt-feat-description {
      font-size: var(--description-size-desktop, {{ section.settings.description_size_desktop | default: 14 }}px);
    }
  }
</style>

{% schema %}
{
  "name": "Alternating Features",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer", "aside"],
    "templates": ["password"]
  },
  "settings": [
    {
      "type": "checkbox",
      "id": "use_theme_colors",
      "label": "Use Theme Colors",
      "default": true,
      "info": "Apply the global theme colors in inverse manner (accent color as background)"
    },
    {
      "type": "header",
      "content": "Section Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Top Padding",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Bottom Padding",
      "default": 60
    },
    {
      "type": "range",
      "id": "section_border_radius",
      "min": 0,
      "max": 50,
      "step": 1,
      "unit": "px",
      "label": "Section Border Radius",
      "default": 0,
      "info": "Adds rounded corners to the entire section"
    },
    {
      "type": "header",
      "content": "Icon Settings"
    },
    {
      "type": "range",
      "id": "icon_size",
      "min": 40,
      "max": 120,
      "step": 10,
      "unit": "px",
      "label": "Icon Container Size",
      "default": 70,
      "info": "Size of the circular icon container"
    },
    {
      "type": "range",
      "id": "icon_image_size",
      "min": 20,
      "max": 80,
      "step": 5,
      "unit": "px",
      "label": "Icon Image Size",
      "default": 35,
      "info": "Size of the icon image within the container"
    },
    {
      "type": "checkbox",
      "id": "icon_background_enabled",
      "label": "Enable Icon Background",
      "default": true,
      "info": "When disabled, icons will appear without the circular background"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Section Title",
      "default": "Our Product"
    },
    {
      "type": "text",
      "id": "title_accent",
      "label": "Section Title Accent",
      "default": "Is Made For You"
    },
    {
      "type": "image_picker",
      "id": "main_image",
      "label": "Main Image"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color",
      "default": "#EF4A65"
    },
    {
      "type": "header",
      "content": "Gradient Background"
    },
    {
      "type": "checkbox",
      "id": "use_gradient",
      "label": "Use Gradient Background",
      "default": false
    },
    {
      "type": "color",
      "id": "gradient_start_color",
      "label": "Gradient Start Color",
      "default": "#EF4A65"
    },
    {
      "type": "color",
      "id": "gradient_end_color",
      "label": "Gradient End Color",
      "default": "#990000"
    },
    {
      "type": "range",
      "id": "gradient_angle",
      "min": 0,
      "max": 360,
      "step": 10,
      "unit": "deg",
      "label": "Gradient Angle",
      "default": 90
    },
    {
      "type": "color",
