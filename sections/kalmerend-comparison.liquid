{% style %}
  .kcomp-{{ section.id }} {
    background: {{ section.settings.bg_color }};
    color: {{ section.settings.text_color }};
    padding: {{ section.settings.padding_top }}px 1.25rem {{ section.settings.padding_bottom }}px;
  }
  .kcomp-{{ section.id }} .kcomp-inner {
    max-width: {{ section.settings.max_width }}px;
    margin: 0 auto;
  }
  .kcomp-{{ section.id }} .kcomp-head { text-align: center; margin-bottom: 2.25rem; }
  .kcomp-{{ section.id }} .kcomp-eyebrow {
    display: inline-block;
    background: {{ section.settings.accent_color }};
    color: {{ section.settings.eyebrow_text_color }};
    padding: 0.35rem 0.85rem;
    border-radius: 999px;
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    margin-bottom: 0.85rem;
  }
  .kcomp-{{ section.id }} h2 {
    font-size: clamp(1.7rem, 3vw, 2.6rem);
    margin: 0 0 0.5rem;
    color: {{ section.settings.heading_color }};
    font-weight: 700;
    line-height: 1.15;
  }
  .kcomp-{{ section.id }} .kcomp-sub {
    font-size: 1rem; opacity: 0.8;
    max-width: 600px; margin: 0 auto;
  }

  .kcomp-{{ section.id }} .kcomp-table {
    background: {{ section.settings.table_bg }};
    border: 1px solid {{ section.settings.border_color }};
    border-radius: 18px;
    overflow: hidden;
  }
  .kcomp-{{ section.id }} .kcomp-grid {
    display: grid;
    grid-template-columns: 1.4fr repeat(3, 1fr);
  }
  .kcomp-{{ section.id }} .kcomp-cell {
    padding: 1rem 1rem;
    border-bottom: 1px solid {{ section.settings.border_color }};
    border-right: 1px solid {{ section.settings.border_color }};
    display: flex;
    align-items: center;
    font-size: 0.95rem;
  }
  .kcomp-{{ section.id }} .kcomp-cell:nth-child(4n) { border-right: none; }
  .kcomp-{{ section.id }} .kcomp-grid > .kcomp-cell:nth-last-child(-n+4) { border-bottom: none; }

  .kcomp-{{ section.id }} .kcomp-row-name {
    background: {{ section.settings.row_name_bg }};
    font-weight: 600;
    color: {{ section.settings.heading_color }};
  }
  .kcomp-{{ section.id }} .kcomp-cell.center { justify-content: center; text-align: center; }

  .kcomp-{{ section.id }} .kcomp-header-cell {
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 0.5rem;
    padding: 1.5rem 1rem;
    font-weight: 700;
  }
  .kcomp-{{ section.id }} .kcomp-header-cell img {
    width: 64px; height: 64px;
    object-fit: contain;
  }
  .kcomp-{{ section.id }} .kcomp-header-cell .placeholder {
    width: 64px; height: 64px;
    border-radius: 50%;
    background: {{ section.settings.row_name_bg }};
  }
  .kcomp-{{ section.id }} .kcomp-header-cell.empty {
    background: {{ section.settings.row_name_bg }};
  }
  .kcomp-{{ section.id }} .kcomp-header-cell.highlight {
    background: {{ section.settings.highlight_bg }};
    color: {{ section.settings.highlight_text }};
  }
  .kcomp-{{ section.id }} .kcomp-col-highlight {
    background: {{ section.settings.highlight_col_bg }};
    color: {{ section.settings.highlight_col_text }};
  }
  .kcomp-{{ section.id }} .kcomp-col-highlight strong { color: {{ section.settings.highlight_col_text }}; }

  .kcomp-{{ section.id }} .kcomp-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 24px; height: 24px;
    border-radius: 50%;
    margin-right: 0.4rem;
    flex-shrink: 0;
  }
  .kcomp-{{ section.id }} .kcomp-icon.yes { background: {{ section.settings.check_bg }}; color: {{ section.settings.check_color }}; }
  .kcomp-{{ section.id }} .kcomp-icon.no  { background: {{ section.settings.cross_bg }}; color: {{ section.settings.cross_color }}; }
  .kcomp-{{ section.id }} .kcomp-icon.maybe { background: {{ section.settings.maybe_bg }}; color: {{ section.settings.maybe_color }}; }

  @media (max-width: 749px) {
    .kcomp-{{ section.id }} .kcomp-grid { grid-template-columns: 1.2fr repeat(3, 1fr); font-size: 0.82rem; }
    .kcomp-{{ section.id }} .kcomp-header-cell { padding: 1rem 0.5rem; font-size: 0.85rem; }
    .kcomp-{{ section.id }} .kcomp-header-cell img, .kcomp-{{ section.id }} .kcomp-header-cell .placeholder { width: 44px; height: 44px; }
    .kcomp-{{ section.id }} .kcomp-cell { padding: 0.75rem 0.5rem; }
  }
{% endstyle %}

{%- liquid
  assign products = section.blocks | where: 'type', 'column'
  assign rows = section.blocks | where: 'type', 'row'
-%}

<section class="kcomp-{{ section.id }}">
  <div class="kcomp-inner">
    <div class="kcomp-head">
      {% if section.settings.eyebrow != blank %}<span class="kcomp-eyebrow">{{ section.settings.eyebrow }}</span>{% endif %}
      {% if section.settings.heading != blank %}<h2>{{ section.settings.heading }}</h2>{% endif %}
      {% if section.settings.subheading != blank %}<p class="kcomp-sub">{{ section.settings.subheading }}</p>{% endif %}
    </div>

    <div class="kcomp-table">
      <div class="kcomp-grid">
        <div class="kcomp-cell kcomp-header-cell empty"></div>
        {% for col in products %}
          <div class="kcomp-cell kcomp-header-cell {% if col.settings.highlight %}highlight{% endif %}">
            {% if col.settings.image %}
              <img src="{{ col.settings.image | image_url: width: 200 }}" alt="{{ col.settings.name | escape }}" loading="lazy">
            {% else %}
              <span class="placeholder" aria-hidden="true"></span>
            {% endif %}
            <span>{{ col.settings.name }}</span>
          </div>
        {% endfor %}

        {% for row in rows %}
          <div class="kcomp-cell kcomp-row-name">{{ row.settings.feature }}</div>
          {% for n in (1..3) %}
            {%- liquid
              case n
                when 1
                  assign val_state = row.settings.col1_state
                  assign val_text = row.settings.col1_text
                when 2
                  assign val_state = row.settings.col2_state
                  assign val_text = row.settings.col2_text
                when 3
                  assign val_state = row.settings.col3_state
                  assign val_text = row.settings.col3_text
              endcase
            -%}
            {%- assign is_highlight = false -%}
            {%- for col in products -%}
              {%- if forloop.index == n and col.settings.highlight -%}{%- assign is_highlight = true -%}{%- endif -%}
            {%- endfor -%}
            <div class="kcomp-cell center {% if is_highlight %}kcomp-col-highlight{% endif %}">
              {% case val_state %}
                {% when 'yes' %}
                  <span class="kcomp-icon yes" aria-hidden="true"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="5 12 10 17 19 7"/></svg></span>
                {% when 'no' %}
                  <span class="kcomp-icon no" aria-hidden="true"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round"><line x1="6" y1="6" x2="18" y2="18"/><line x1="18" y1="6" x2="6" y2="18"/></svg></span>
                {% when 'maybe' %}
                  <span class="kcomp-icon maybe" aria-hidden="true"><svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor"><circle cx="12" cy="12" r="3"/></svg></span>
              {% endcase %}
              <span>{{ val_text }}</span>
            </div>
          {% endfor %}
        {% endfor %}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Kalmerend · Vergelijking",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Vergeleken met andere oplossingen" },
    { "type": "text", "id": "heading", "label": "Kop", "default": "Waarom PetCura Kalmerend beter werkt" },
    { "type": "text", "id": "subheading", "label": "Subkop", "default": "Een eerlijke vergelijking met andere kalmerende producten op de markt — op de punten die er voor je hond echt toe doen." },
    { "type": "header", "content": "Kleuren" },
    { "type": "color", "id": "bg_color", "label": "Sectie-achtergrond", "default": "#F4F8F2" },
    { "type": "color", "id": "text_color", "label": "Tekstkleur", "default": "#17433C" },
    { "type": "color", "id": "heading_color", "label": "Kopkleur", "default": "#17433C" },
    { "type": "color", "id": "accent_color", "label": "Accent (eyebrow)", "default": "#C6FA54" },
    { "type": "color", "id": "eyebrow_text_color", "label": "Eyebrow tekstkleur", "default": "#17433C" },
    { "type": "color", "id": "table_bg", "label": "Tabel achtergrond", "default": "#FFFFFF" },
    { "type": "color", "id": "border_color", "label": "Randkleur", "default": "#E1ECDD" },
    { "type": "color", "id": "row_name_bg", "label": "Linker kolom achtergrond", "default": "#F4F8F2" },
    { "type": "color", "id": "highlight_bg", "label": "Header highlight bg", "default": "#17433C" },
    { "type": "color", "id": "highlight_text", "label": "Header highlight tekst", "default": "#C6FA54" },
    { "type": "color", "id": "highlight_col_bg", "label": "Kolom highlight bg", "default": "#F8FBF5" },
    { "type": "color", "id": "highlight_col_text", "label": "Kolom highlight tekst", "default": "#17433C" },
    { "type": "color", "id": "check_bg", "label": "✓ achtergrond", "default": "#C6FA54" },
    { "type": "color", "id": "check_color", "label": "✓ kleur", "default": "#17433C" },
    { "type": "color", "id": "cross_bg", "label": "✗ achtergrond", "default": "#F1E1DD" },
    { "type": "color", "id": "cross_color", "label": "✗ kleur", "default": "#A8332A" },
    { "type": "color", "id": "maybe_bg", "label": "○ achtergrond", "default": "#F1EBD4" },
    { "type": "color", "id": "maybe_color", "label": "○ kleur", "default": "#7C6A2A" },
    { "type": "header", "content": "Spacing" },
    { "type": "range", "id": "max_width", "label": "Max breedte", "min": 800, "max": 1400, "step": 20, "default": 1100 },
    { "type": "range", "id": "padding_top", "label": "Padding boven", "min": 0, "max": 160, "step": 4, "default": 64 },
    { "type": "range", "id": "padding_bottom", "label": "Padding onder", "min": 0, "max": 160, "step": 4, "default": 64 }
  ],
  "blocks": [
    {
      "type": "column",
      "name": "Productkolom",
      "limit": 3,
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Afbeelding" },
        { "type": "text", "id": "name", "label": "Naam", "default": "PetCura" },
        { "type": "checkbox", "id": "highlight", "label": "Markeer deze kolom (eigen merk)", "default": false }
      ]
    },
    {
      "type": "row",
      "name": "Vergelijkingsrij",
      "settings": [
        { "type": "text", "id": "feature", "label": "Kenmerk", "default": "Werking binnen 30–60 minuten" },
        { "type": "header", "content": "Kolom 1" },
        { "type": "select", "id": "col1_state", "label": "Status", "default": "yes",
          "options": [
            { "value": "yes", "label": "✓ Aanwezig" },
            { "value": "no", "label": "✗ Niet aanwezig" },
            { "value": "maybe", "label": "○ Beperkt" }
          ]
        },
        { "type": "text", "id": "col1_text", "label": "Tekst (optioneel)", "default": "" },
        { "type": "header", "content": "Kolom 2" },
        { "type": "select", "id": "col2_state", "label": "Status", "default": "maybe",
          "options": [
            { "value": "yes", "label": "✓ Aanwezig" },
            { "value": "no", "label": "✗ Niet aanwezig" },
            { "value": "maybe", "label": "○ Beperkt" }
          ]
        },
        { "type": "text", "id": "col2_text", "label": "Tekst (optioneel)", "default": "" },
        { "type": "header", "content": "Kolom 3" },
        { "type": "select", "id": "col3_state", "label": "Status", "default": "no",
          "options": [
            { "value": "yes", "label": "✓ Aanwezig" },
            { "value": "no", "label": "✗ Niet aanwezig" },
            { "value": "maybe", "label": "○ Beperkt" }
          ]
        },
        { "type": "text", "id": "col3_text", "label": "Tekst (optioneel)", "default": "" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Kalmerend · Vergelijking",
      "blocks": [
        { "type": "column", "settings": { "name": "PetCura Kalmerend", "highlight": true } },
        { "type": "column", "settings": { "name": "Kalmerende druppels" } },
        { "type": "column", "settings": { "name": "Andere kauwsnacks" } },
        { "type": "row", "settings": { "feature": "Werking binnen 30–60 minuten", "col1_state": "yes", "col2_state": "maybe", "col2_text": "Variabel", "col3_state": "maybe", "col3_text": "Variabel" } },
        { "type": "row", "settings": { "feature": "L-Theanine 120 mg", "col1_state": "yes", "col2_state": "no", "col3_state": "maybe", "col3_text": "Soms" } },
        { "type": "row", "settings": { "feature": "Valeriaan + Passiebloem complex", "col1_state": "yes", "col2_state": "maybe", "col2_text": "Alleen valeriaan", "col3_state": "maybe" } },
        { "type": "row", "settings": { "feature": "Magnesium + Tryptofaan", "col1_state": "yes", "col2_state": "no", "col3_state": "no" } },
        { "type": "row", "settings": { "feature": "Geen verdovend effect", "col1_state": "yes", "col2_state": "maybe", "col3_state": "yes" } },
        { "type": "row", "settings": { "feature": "Smakelijk in snack-vorm", "col1_state": "yes", "col2_state": "no", "col3_state": "yes" } },
        { "type": "row", "settings": { "feature": "Door dierenartsen samengesteld", "col1_state": "yes", "col2_state": "maybe", "col3_state": "no" } },
        { "type": "row", "settings": { "feature": "Geld-terug-garantie 90 dagen", "col1_state": "yes", "col2_state": "maybe", "col2_text": "14 dagen", "col3_state": "no" } },
        { "type": "row", "settings": { "feature": "Geproduceerd in Nederland", "col1_state": "yes", "col2_state": "no", "col3_state": "maybe" } }
      ]
    }
  ]
}
