    <!DOCTYPE html>
<html lang="nl">
<head>
  <meta charset="UTF-8" />
  <title>Compact Header</title>
  <style>
    html, body {
      margin: 0;
      padding: 0;
      background:#3a3a3a;
      font-family: system-ui, -apple-system, BlinkMacSystemFont, "Helvetica Neue", Arial, sans-serif;
    }

    .header {
      background:#f4f4f4;
      width:100%;
      max-width:900px;
      margin:auto;
      padding:10px 20px; /* kleiner */
      box-sizing:border-box;
      display:flex;
      align-items:center;
      justify-content:space-between;
    }

    .logo-area {
      display:flex;
      align-items:center;
      gap:12px; /* compacter */
    }

    .logo-mark {
      width:42px;
      height:42px;
      background:#4b94ad;
      color:#ffffff;
      font-weight:800;
      display:flex;
      align-items:center;
      justify-content:center;
      font-size:20px; /* kleiner font */
      box-sizing:border-box;
    }

    .logo-text {
      display:flex;
      flex-direction:column;
      line-height:1;
      letter-spacing:0.07em;
      font-weight:800;
      font-size:13px; /* kleiner */
    }

    .logo-text span:first-child {
      margin-bottom:2px;
    }

    .icon-area {
      display:flex;
      align-items:center;
      gap:18px; /* iets minder ruimte */
    }

    /* Search icon kleiner */
    .icon-search {
      position:relative;
      width:16px;
      height:16px;
    }

    .icon-search::before {
      content:"";
      position:absolute;
      width:12px;
      height:12px;
      border:2px solid #000;
      border-radius:50%;
      top:0;
      left:0;
      box-sizing:border-box;
    }

    .icon-search::after {
      content:"";
      position:absolute;
      width:7px;
      height:2px;
      background:#000;
      transform:rotate(45deg);
      right:-2px;
      bottom:0px;
    }

    /* Hamburger menu compacter */
    .icon-menu {
      width:20px;
      height:14px;
      display:flex;
      flex-direction:column;
      justify-content:space-between;
    }

    .icon-menu span {
      display:block;
      height:2px;
      background:#000;
      border-radius:1px;
    }
  </style>
</head>
<body>

<header class="header">
  <div class="logo-area">
    <div class="logo-mark">H</div>
    <div class="logo-text">
      <span>GEZONDHEID</span>
      <span>INSIDER</span>
    </div>
  </div>

  <div class="icon-area">
    <div class="icon-search"></div>
    <div class="icon-menu">
      <span></span>
      <span></span>
      <span></span>
    </div>
  </div>
</header>

</body>
</html>
