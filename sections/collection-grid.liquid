            height: {{ height }}px;
            aspect-ratio: 2 / 3;
          {% when '3_4' %}
            {% assign height = card_width | times: 4 | divided_by: 3 %}
            height: {{ height }}px;
            aspect-ratio: 3 / 4;
          {% when '4_5' %}
            {% assign height = card_width | times: 5 | divided_by: 4 %}
            height: {{ height }}px;
            aspect-ratio: 4 / 5;
          {% else %}
            height: {{ card_width }}px;
            aspect-ratio: 1 / 1;
        {% endcase %}
      }

      @media (max-width: 767px) {
        .section-{{ section.id }}.collection-grid-carousel.equal-height-enabled .product-image-container {
          height: {{ section.settings.mobile_card_height | default: 200 }}px;
          width: 100%;
          max-width: 100%;
        }
      }

      @media (max-width: 484px) {
        .section-{{ section.id }}.collection-grid-carousel.equal-height-enabled .product-image-container {
          {% assign small_mobile_height = section.settings.mobile_card_height | default: 200 | minus: 20 %}
