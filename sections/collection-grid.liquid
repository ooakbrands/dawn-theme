</div>

<style>
  /* Dynamic styles for section */
  .section-{{ section.id }} {
    padding: {{ section.settings.padding_top | default: 40 }}px 0 {{ section.settings.padding_bottom | default: 40 }}px;
    background-color: {% if section.settings.use_theme_colors %}{{ settings.global_section_background_color }}{% else %}{{ section.settings.section_background_color | default: '#ffffff' }}{% endif %};
  }
  

  
  .section-{{ section.id }} .product-carousel {
    display: flex;
    flex-wrap: nowrap;
    gap: 0;
    overflow-x: auto;
    scroll-behavior: smooth;
    padding-bottom: 10px;
  }

  /* Carousel pagination styles */
  {% if section.settings.enable_carousel_pagination %}
  .section-{{ section.id }} .product-carousel {
    overflow-x: hidden;
  }
  
  .section-{{ section.id }} .carousel-page {
    display: none;
    flex-wrap: nowrap;
    gap: 0;
    width: 100%;
  }
  
  .section-{{ section.id }} .carousel-page.active {
    display: flex;
  }
  {% endif %}
  
  .section-{{ section.id }} .product-carousel .product-card {
    flex: 0 0 {{ section.settings.carousel_card_width | default: 240 }}px;
    width: {{ section.settings.carousel_card_width | default: 240 }}px;
    max-width: {{ section.settings.carousel_card_width | default: 240 }}px;
    min-width: {{ section.settings.carousel_card_width | default: 240 }}px;
  }
  
  /* Desktop carousel card width enforcement */
  @media (min-width: 768px) {
    .section-{{ section.id }} .product-carousel .product-card {
      flex: 0 0 {{ section.settings.carousel_card_width | default: 240 }}px;
      width: {{ section.settings.carousel_card_width | default: 240 }}px;
      max-width: {{ section.settings.carousel_card_width | default: 240 }}px;
      min-width: {{ section.settings.carousel_card_width | default: 240 }}px;
    }
    
    /* Prevent next page cards from showing on desktop */
    .section-{{ section.id }} .product-carousel {
      overflow: hidden !important;
    }
    
    .section-{{ section.id }}.collection-grid-carousel .swiper-wrapper {
      overflow: hidden !important;
    }
    
    .section-{{ section.id }}.collection-grid-carousel .swiper-slide {
      overflow: hidden !important;
    }
  }

  /* Mobile responsive carousel card width */
  @media (max-width: 767px) {
    .section-{{ section.id }} .product-carousel .product-card {
      {% assign mobile_width = section.settings.carousel_card_width | default: 240 | minus: 40 %}
      {% if mobile_width < 180 %}
        {% assign mobile_width = 180 %}
      {% endif %}
      flex: 0 0 {{ mobile_width }}px;
      width: {{ mobile_width }}px;
      max-width: {{ mobile_width }}px;
      min-width: {{ mobile_width }}px;
    }
    
    /* Ensure mobile image containers match card width for perfect squares */
    {% unless section.settings.remove_card_styling %}
      {% unless section.settings.image_aspect_ratio == 'natural' %}
        {% if section.settings.image_aspect_ratio == '1_1' %}
          .section-{{ section.id }} .product-image-container {
            width: {{ mobile_width }}px;
            max-width: {{ mobile_width }}px;
            height: {{ mobile_width }}px;
          }
        {% endif %}
      {% endunless %}
    {% else %}
      {% unless section.settings.image_aspect_ratio == 'natural' %}
        {% if section.settings.image_aspect_ratio == '1_1' %}
          .section-{{ section.id }} .product-image-container {
            width: {{ mobile_width }}px;
            max-width: {{ mobile_width }}px;
            height: {{ mobile_width }}px;
          }
        {% endif %}
      {% endunless %}
    {% endunless %}
  }
  
  /* Override global star styles with section-specific styling */
  .section-{{ section.id }} .star {
    width: {{ section.settings.star_size | default: 18 }}px;
    height: {{ section.settings.star_size | default: 18 }}px;
    margin: 0;
    display: inline-block;
    align-content: center;
    margin-right: -3px;
    line-height: 1;
    position: relative;
  }
  
  /* Mobile responsive star sizing */
  @media (max-width: 767px) {
    .section-{{ section.id }} .star {
      width: calc({{ section.settings.star_size | default: 18 }}px + 4px);
      height: calc({{ section.settings.star_size | default: 18 }}px + 4px);
    }
    
    /* Custom mobile card height for all layouts */
    .section-{{ section.id }} .product-image-container {
      {% unless section.settings.image_aspect_ratio == 'natural' %}
        height: {{ section.settings.mobile_card_height | default: 200 }}px !important;
      {% endunless %}
    }
  }
  
  .section-{{ section.id }} .star svg {
    width: 100%;
    height: 100%;
    display: block;
  }
  
  .section-{{ section.id }} .star-filled {
    color: {% if section.settings.use_theme_colors %}{{ settings.global_section_accent_1_color }}{% else %}{{ section.settings.star_color | default: '#FFD700' }}{% endif %};
    opacity: 1;
  }
  
  .section-{{ section.id }} .star-empty {
    color: #e0e0e0;
    opacity: 0.5;
  }
  
  .section-{{ section.id }} .star-half {
    position: relative;
    opacity: 1;
  }
  
  .section-{{ section.id }} .star-half .star-bg {
    position: absolute;
    top: 0;
    left: 0;
    color: #e0e0e0;
    opacity: 1;
  }
  
  .section-{{ section.id }} .star-half .star-fill {
    position: relative;
    z-index: 1;
    color: {% if section.settings.use_theme_colors %}{{ settings.global_section_accent_1_color }}{% else %}{{ section.settings.star_color | default: '#FFD700' }}{% endif %};
    opacity: 1;
  }
  
  .section-{{ section.id }} .section-header {
    margin-bottom: 30px;
  }
  
  .section-{{ section.id }} .section-title-wrapper {
    display: flex;
    align-items: center;
    justify-content: {{ section.settings.heading_alignment | default: 'center' }};
    gap: 20px;
    margin-bottom: 0;
  }
  
  .section-{{ section.id }} .section-heading {
    font-size: {{ section.settings.heading_size | default: 28 }}px;
    font-weight: var(--font-weight-bold);
    color: {% if section.settings.use_theme_colors %}{{ settings.global_section_text_color }}{% else %}{{ section.settings.heading_color | default: '#000000' }}{% endif %} !important;
    margin: 0;
    text-align: {{ section.settings.heading_alignment | default: 'center' }};
  }
  
  .section-{{ section.id }} .view-all-beside-title {
    margin: 0;
  }
  
  .section-{{ section.id }} .view-all-below-title {
    margin: 15px 0 0 0;
    text-align: {{ section.settings.heading_alignment | default: 'center' }};
  }
  
  .section-{{ section.id }} .view-all-bottom {
    margin: 30px 0 0 0;
    text-align: center;
  }
  
  /* Product card dynamic styles - only apply if card styling is not removed */
  {% unless section.settings.remove_card_styling %}
  .section-{{ section.id }} .product-card {
    background: {% if section.settings.use_theme_colors %}{{ settings.global_section_background_color }}{% else %}{{ section.settings.card_background | default: '#ffffff' }}{% endif %};
    border-radius: {{ section.settings.card_radius | default: 8 }}px;
    border: 1px solid {% if section.settings.use_theme_colors %}{{ settings.global_section_text_color | color_modify: 'alpha', 0.1 | default: 'rgb(240, 240, 240)' }}{% else %}{{ section.settings.card_border_color | default: '#E5E7EB' }}{% endif %};
    height: 100%;
    display: flex;
    flex-direction: column;
      {% if section.settings.show_custom_badges or section.settings.show_sale_badge %}
        overflow: visible;
      {% else %}
        overflow: hidden;
        /* Ensure child content cannot spill beyond rounded corners when badges are disabled */
        clip-path: inset(0 round {{ section.settings.card_radius | default: 8 }}px);
      {% endif %}
      position: relative;
  }
  
  /* Product image container */
  .section-{{ section.id }} .product-image-container {
    background: {{ section.settings.image_background | default: '#f8f8f8' }};
    position: relative;
      border-radius: {{ section.settings.card_radius | default: 8 }}px {{ section.settings.card_radius | default: 8 }}px 0 0;
      {% if section.settings.show_custom_badges or section.settings.show_sale_badge %}
        overflow: visible;
      {% else %}
        overflow: hidden;
      {% endif %}
      /* Center image content inside the container */
      display: flex;
      align-items: center;
      justify-content: center;
      /* Ensure container stays within card bounds */
      width: 100%;
      max-width: 100%;
      min-width: 0;
      box-sizing: border-box;
      {% unless section.settings.image_aspect_ratio == 'natural' %}
        {% assign card_width = section.settings.carousel_card_width | default: 240 %}
        {% case section.settings.image_aspect_ratio %}
          {% when '1_1' %}
            height: {{ card_width }}px;
          {% when '2_3' %}
            {% assign height = card_width | times: 3 | divided_by: 2 %}
            height: {{ height }}px;
          {% when '4_5' %}
            {% assign height = card_width | times: 5 | divided_by: 4 %}
            height: {{ height }}px;
          {% when '3_4' %}
            {% assign height = card_width | times: 4 | divided_by: 3 %}
            height: {{ height }}px;
          {% else %}
            height: auto;
        {% endcase %}
        overflow: hidden;
      {% else %}
        height: auto;
      {% endunless %}
  }
  
  .section-{{ section.id }} .product-image {
    object-fit: {{ section.settings.image_fit | default: 'contain' }};
      object-position: center center;
      /* Ensure the image cannot visually extend past rounded corners */
      border-radius: {{ section.settings.card_radius | default: 8 }}px {{ section.settings.card_radius | default: 8 }}px 0 0;
      overflow: hidden;
      /* Ensure image stays within container */
      max-width: 100%;
      max-height: 100%;
      {% if section.settings.image_aspect_ratio == 'natural' %}
        width: auto;
        height: auto;
      {% else %}
        width: 100%;
        height: 100%;
      {% endif %}
    }
  {% else %}
    /* When card styling is removed, ensure minimal styling */
    .section-{{ section.id }} .product-card {
      height: 100%;
      display: flex;
      flex-direction: column;
      position: relative;
    }
    
    .section-{{ section.id }} .product-image-container {
      background: {{ section.settings.image_background | default: '#f8f8f8' }};
      position: relative;
      /* Center image content inside the container */
      display: flex;
      align-items: center;
      justify-content: center;
      /* Ensure container stays within card bounds */
      width: 100%;
      max-width: 100%;
      min-width: 0;
      box-sizing: border-box;
      {% if section.settings.show_custom_badges or section.settings.show_sale_badge %}
        overflow: visible;
      {% else %}
        overflow: hidden;
      {% endif %}
      {% unless section.settings.image_aspect_ratio == 'natural' %}
        {% assign card_width = section.settings.carousel_card_width | default: 240 %}
        {% case section.settings.image_aspect_ratio %}
          {% when '1_1' %}
            height: {{ card_width }}px;
          {% when '2_3' %}
            {% assign height = card_width | times: 1.5 %}
            height: {{ height }}px;
          {% when '4_5' %}
            {% assign height = card_width | times: 1.25 %}
            height: {{ height }}px;
          {% when '3_4' %}
            {% assign height = card_width | times: 1.333 %}
            height: {{ height }}px;
          {% else %}
            height: auto;
        {% endcase %}
      {% else %}
        height: auto;
      {% endunless %}
    }
    
    .section-{{ section.id }} .product-image {
      object-fit: {{ section.settings.image_fit | default: 'contain' }};
      object-position: center center;
      /* Ensure image stays within container */
      max-width: 100%;
      max-height: 100%;
      {% if section.settings.image_aspect_ratio == 'natural' %}
        width: auto;
        height: auto;
      {% else %}
        width: 100%;
        height: 100%;
      {% endif %}
      {% unless section.settings.remove_card_styling %}
        border-radius: {{ section.settings.card_radius | default: 8 }}px {{ section.settings.card_radius | default: 8 }}px 0 0;
        overflow: hidden;
      {% endunless %}
    }
  {% endunless %}



  /* Single image container */
  .section-{{ section.id }} .product-single-image {
    {% unless section.settings.image_aspect_ratio == 'natural' %}
      {% case section.settings.image_aspect_ratio %}
        {% when '1_1' %}aspect-ratio: 1 / 1;
        {% when '2_3' %}aspect-ratio: 2 / 3;
        {% when '4_5' %}aspect-ratio: 4 / 5;
        {% when '3_4' %}aspect-ratio: 3 / 4;
        {% else %}aspect-ratio: auto;
      {% endcase %}
      overflow: hidden;
    {% endunless %}
  }

  /* Product slider and slides */
  .section-{{ section.id }} .product-slider {
    {% unless section.settings.image_aspect_ratio == 'natural' %}
      {% case section.settings.image_aspect_ratio %}
        {% when '1_1' %}aspect-ratio: 1 / 1;
        {% when '2_3' %}aspect-ratio: 2 / 3;
        {% when '4_5' %}aspect-ratio: 4 / 5;
        {% when '3_4' %}aspect-ratio: 3 / 4;
        {% else %}aspect-ratio: auto;
      {% endcase %}
      overflow: hidden;
    {% endunless %}
  }

  .section-{{ section.id }} .product-slide {
    {% unless section.settings.image_aspect_ratio == 'natural' %}
      width: 100%;
      height: 100%;
    {% endunless %}
  }

  /* Fix extra space below natural aspect ratio images on very small screens */
  {% if section.settings.image_aspect_ratio == 'natural' %}
    @media (max-width: 400px) {
      .section-{{ section.id }} .product-image-container {
        align-items: flex-start !important;
        min-height: auto !important;
      }
      
      .section-{{ section.id }} .product-slider {
        align-items: flex-start !important;
        min-height: auto !important;
      }
      
      .section-{{ section.id }} .product-slide {
        align-items: flex-start !important;
        min-height: auto !important;
        display: block !important;
      }
      
      .section-{{ section.id }} .product-image {
        display: block !important;
        vertical-align: top !important;
        line-height: 0 !important;
      }
    }
  {% endif %}

  /* Equal height carousel aspect ratio overrides */
  {% if section.settings.equal_height_cards and section.settings.layout_type == 'carousel' %}
    {% unless section.settings.image_aspect_ratio == 'natural' %}
      .section-{{ section.id }}.collection-grid-carousel.equal-height-enabled .product-image-container {
