{% comment %}
  Block: PC Accordion (Product Details block)
  - Custom Liquid per item (tables/images/icons/metafields if you want, but not required)
  - Dawn compatible
  - Styling options: background, font, margins/paddings, colors, sizes
{% endcomment %}

{%- liquid
  assign bid = block.id
  assign s = block.settings
-%}

<div
  class="pc-accordion pc-accordion--{{ bid }}"
  style="
    --pc-bg: {{ s.bg_color }};
    --pc-border: {{ s.border_color }};
    --pc-title: {{ s.title_color }};
    --pc-icon: {{ s.icon_color }};
    --pc-content: {{ s.content_color }};
    --pc-radius: {{ s.radius }}px;
    --pc-title-size: {{ s.title_size }}px;
    --pc-content-size: {{ s.content_size }}px;
    --pc-pad-y: {{ s.item_padding_y }}px;
    --pc-gap: {{ s.icon_gap }}px;
    --pc-font: {{ s.font_family }};
    margin-top: {{ s.margin_top }}px;
    margin-bottom: {{ s.margin_bottom }}px;
  "
  data-pc-accordion
  data-multiple-open="{{ s.multiple_open }}"
  data-first-open="{{ s.first_open }}"
>
  <div class="pc-accordion__inner" style="padding-top: {{ s.padding_top }}px; padding-bottom: {{ s.padding_bottom }}px;">
    {% if s.heading != blank %}
      <div class="pc-accordion__heading">
        <h2 class="pc-accordion__heading-title">{{ s.heading | escape }}</h2>
      </div>
    {% endif %}

    <div class="pc-accordion__wrap">
      {%- assign items = 0 -%}

      {%- if s.item_1_title != blank or s.item_1_content != blank -%}
        {%- assign items = items | plus: 1 -%}
        {% render 'pc-accordion-item',
          idx: 1,
          open_default: s.first_open,
          show_left_icon: s.show_left_icon,
          title: s.item_1_title,
          icon_svg: s.item_1_svg,
          content: s.item_1_content
        %}
      {%- endif -%}

      {%- if s.item_2_title != blank or s.item_2_content != blank -%}
        {%- assign items = items | plus: 1 -%}
        {% render 'pc-accordion-item',
          idx: 2,
          open_default: false,
          show_left_icon: s.show_left_icon,
          title: s.item_2_title,
          icon_svg: s.item_2_svg,
          content: s.item_2_content
        %}
      {%- endif -%}

      {%- if s.item_3_title != blank or s.item_3_content != blank -%}
        {%- assign items = items | plus: 1 -%}
        {% render 'pc-accordion-item',
          idx: 3,
          open_default: false,
          show_left_icon: s.show_left_icon,
          title: s.item_3_title,
          icon_svg: s.item_3_svg,
          content: s.item_3_content
        %}
      {%- endif -%}

      {%- if s.item_4_title != blank or s.item_4_content != blank -%}
        {%- assign items = items | plus: 1 -%}
        {% render 'pc-accordion-item',
          idx: 4,
          open_default: false,
          show_left_icon: s.show_left_icon,
          title: s.item_4_title,
          icon_svg: s.item_4_svg,
          content: s.item_4_content
        %}
      {%- endif -%}

      {%- if items == 0 -%}
        <div class="pc-accordion__empty rte">
          <p><strong>PC Accordion:</strong> Voeg titles + content toe in de block settings.</p>
        </div>
      {%- endif -%}
    </div>
  </div>

  <style>
    .pc-accordion--{{ bid }}{
      background: var(--pc-bg);
      font-family: var(--pc-font);
      border-radius: var(--pc-radius);
    }

    /* Make sure background covers padding/margins area within block */
    .pc-accordion--{{ bid }} .pc-accordion__inner{
      background: var(--pc-bg);
      border-radius: var(--pc-radius);
      padding-left: 0;
      padding-right: 0;
    }

    .pc-accordion--{{ bid }} .pc-accordion__heading{
      margin-bottom: 14px;
    }
    .pc-accordion--{{ bid }} .pc-accordion__heading-title{
      margin: 0;
      font-size: 20px;
      line-height: 1.2;
      color: var(--pc-title);
      font-weight: 800;
    }

    .pc-accordion--{{ bid }} .pc-accordion__wrap{
      border-top: 1px solid var(--pc-border);
    }

    .pc-accordion--{{ bid }} .pc-acc__item{
      border-bottom: 1px solid var(--pc-border);
    }

    .pc-accordion--{{ bid }} .pc-acc__btn{
      width: 100%;
      border: 0;
      background: transparent;
      cursor: pointer;
      padding: var(--pc-pad-y) 0;
      display: flex;
      align-items: center;
      justify-content: space-between;
      text-align: left;
      color: var(--pc-title);
    }

    .pc-accordion--{{ bid }} .pc-acc__left{
      display: inline-flex;
      align-items: center;
      gap: var(--pc-gap);
      min-width: 0;
      flex: 1 1 auto;
    }

    .pc-accordion--{{ bid }} .pc-acc__lefticon{
      width: 22px;
      height: 22px;
      color: var(--pc-icon);
      display: inline-flex;
      align-items: center;
      justify-content: center;
      flex: 0 0 auto;
    }

    .pc-accordion--{{ bid }} .pc-acc__lefticon svg{
      width: 22px;
      height: 22px;
      display: block;
    }

    .pc-accordion--{{ bid }} .pc-acc__fallback-num{
      width: 22px;
      height: 22px;
      border: 2px solid var(--pc-icon);
      border-radius: 999px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      font-size: 12px;
      font-weight: 800;
      color: var(--pc-icon);
    }

    .pc-accordion--{{ bid }} .pc-acc__title{
      color: var(--pc-title);
      font-size: var(--pc-title-size);
      font-weight: 800;
      line-height: 1.2;
      word-break: break-word;
    }

    .pc-accordion--{{ bid }} .pc-acc__chev{
      color: var(--pc-icon);
      opacity: 0.45;
      transition: transform .25s ease, opacity .25s ease;
      flex: 0 0 auto;
      display: inline-flex;
      align-items: center;
      justify-content: center;
    }

    .pc-accordion--{{ bid }} .pc-acc__item.is-open .pc-acc__chev{
      transform: rotate(180deg);
      opacity: 0.9;
    }

    .pc-accordion--{{ bid }} .pc-acc__panel{
      padding-bottom: 16px;
    }

    .pc-accordion--{{ bid }} .pc-acc__content{
      color: var(--pc-content);
      font-size: var(--pc-content-size);
      line-height: 1.6;
    }

    .pc-accordion--{{ bid }} .pc-acc__content table{
      width: 100%;
      border-collapse: separate;
      border-spacing: 0;
    }

    .pc-accordion--{{ bid }} .pc-acc__content img{
      max-width: 100%;
      height: auto;
    }

    .pc-accordion--{{ bid }} .pc-accordion__empty{
      padding: 12px 0;
      color: var(--pc-content);
      font-size: var(--pc-content-size);
    }
  </style>
</div>

<script>
(function(){
  function init(root){
    if(!root || root.dataset.pcInit === '1') return;
    root.dataset.pcInit = '1';

    var allowMultiple = root.getAttribute('data-multiple-open') === 'true';
    var firstOpen = root.getAttribute('data-first-open') === 'true';

    var items = root.querySelectorAll('.pc-acc__item');
    if(!items.length) return;

    // Ensure first item open if configured
    if(firstOpen){
      var first = items[0];
      openItem(first, items, allowMultiple);
    }

    items.forEach(function(item){
      var btn = item.querySelector('.pc-acc__btn');
      var panel = item.querySelector('.pc-acc__panel');
      if(!btn || !panel) return;

      btn.addEventListener('click', function(){
        var isOpen = item.classList.contains('is-open');

        if(isOpen){
          closeItem(item);
        } else {
          openItem(item, items, allowMultiple);
        }
      });
    });
  }

  function openItem(item, items, allowMultiple){
    if(!allowMultiple){
      items.forEach(function(i){
        if(i !== item) closeItem(i);
      });
    }
    item.classList.add('is-open');
    var btn = item.querySelector('.pc-acc__btn');
    var panel = item.querySelector('.pc-acc__panel');
    if(btn) btn.setAttribute('aria-expanded','true');
    if(panel) panel.hidden = false;
  }

  function closeItem(item){
    item.classList.remove('is-open');
    var btn = item.querySelector('.pc-acc__btn');
    var panel = item.querySelector('.pc-acc__panel');
    if(btn) btn.setAttribute('aria-expanded','false');
    if(panel) panel.hidden = true;
  }

  document.addEventListener('DOMContentLoaded', function(){
    document.querySelectorAll('[data-pc-accordion]').forEach(init);
  });

  document.addEventListener('shopify:section:load', function(e){
    if(!e || !e.target) return;
    e.target.querySelectorAll('[data-pc-accordion]').forEach(init);
  });

  document.addEventListener('shopify:section:select', function(e){
    if(!e || !e.target) return;
    e.target.querySelectorAll('[data-pc-accordion]').forEach(init);
  });
})();
</script>

{% schema %}
{
  "name": "PC Accordion",
  "tag": "div",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading (optional)", "default": "PC" },

    { "type": "checkbox", "id": "first_open", "label": "First item open by default", "default": true },
    { "type": "checkbox", "id": "multiple_open", "label": "Allow multiple items open", "default": false },
    { "type": "checkbox", "id": "show_left_icon", "label": "Show left icon", "default": true },

    { "type": "range", "id": "icon_gap", "label": "Gap icon/title", "min": 6, "max": 24, "step": 1, "default": 10 },
    { "type": "range", "id": "item_padding_y", "label": "Row padding (top/bottom)", "min": 10, "max": 40, "step": 1, "default": 18 },

    { "type": "range", "id": "title_size", "label": "Title font size", "min": 14, "max": 28, "step": 1, "default": 19 },
    { "type": "range", "id": "content_size", "label": "Content font size", "min": 12, "max": 22, "step": 1, "default": 16 },

    {
      "type": "select",
      "id": "font_family",
      "label": "Font family",
      "default": "inherit",
      "options": [
        { "value": "inherit", "label": "Theme default" },
        { "value": "Montserrat, sans-serif", "label": "Montserrat" },
        { "value": "Poppins, sans-serif", "label": "Poppins" },
        { "value": "Inter, sans-serif", "label": "Inter" }
      ]
    },

    { "type": "color", "id": "bg_color", "label": "Background color", "default": "transparent" },
    { "type": "color", "id": "border_color", "label": "Border color", "default": "#d0d6e2" },
    { "type": "color", "id": "title_color", "label": "Title color", "default": "#044d5e" },
    { "type": "color", "id": "icon_color", "label": "Icon color", "default": "#044d5e" },
    { "type": "color", "id": "content_color", "label": "Content color", "default": "#000000" },
    { "type": "range", "id": "radius", "label": "Radius", "min": 0, "max": 24, "step": 1, "default": 0 },

    { "type": "range", "id": "margin_top", "label": "Margin top", "min": 0, "max": 160, "step": 4, "default": 0 },
    { "type": "range", "id": "margin_bottom", "label": "Margin bottom", "min": 0, "max": 160, "step": 4, "default": 0 },
    { "type": "range", "id": "padding_top", "label": "Padding top", "min": 0, "max": 120, "step": 4, "default": 0 },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom", "min": 0, "max": 120, "step": 4, "default": 0 },

    { "type": "header", "content": "Item 1" },
    { "type": "text", "id": "item_1_title", "label": "Title", "default": "Description" },
    { "type": "html", "id": "item_1_svg", "label": "Left icon SVG (optional)", "default": "PC" },
    { "type": "liquid", "id": "item_1_content", "label": "Content (Custom Liquid)", "default": "<p>Place content here (images, tables, icons, etc.).</p>" },

    { "type": "header", "content": "Item 2" },
    { "type": "text", "id": "item_2_title", "label": "Title", "default": "Feeding Guide" },
    { "type": "html", "id": "item_2_svg", "label": "Left icon SVG (optional)", "default": "PC" },
    { "type": "liquid", "id": "item_2_content", "label": "Content (Custom Liquid)", "default": "<p>Place feeding guide here.</p>" },

    { "type": "header", "content": "Item 3" },
    { "type": "text", "id": "item_3_title", "label": "Title", "default": "Ingredients" },
    { "type": "html", "id": "item_3_svg", "label": "Left icon SVG (optional)", "default": "PC" },
    { "type": "liquid", "id": "item_3_content", "label": "Content (Custom Liquid)", "default": "<p>Place ingredients table here.</p>" },

    { "type": "header", "content": "Item 4" },
    { "type": "text", "id": "item_4_title", "label": "Title", "default": "Product info" },
    { "type": "html", "id": "item_4_svg", "label": "Left icon SVG (optional)", "default": "PC" },
    { "type": "liquid", "id": "item_4_content", "label": "Content (Custom Liquid)", "default": "<p>Place additional info here.</p>" }
  ]
}
{% endschema %}