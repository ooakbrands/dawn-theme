{% doc %}
  @prompt
    Generate me a collections section with bars with the name and a icon on the left, with 5 bars under each other
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-collection-bars-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding: {{ block.settings.section_padding }}px 0;
  }

  .ai-collection-bars__container-{{ ai_gen_id }} {
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .ai-collection-bars__list-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.bar_spacing }}px;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .ai-collection-bars__item-{{ ai_gen_id }} {
    display: block;
  }

  .ai-collection-bars__link-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: {{ block.settings.icon_spacing }}px;
    padding: {{ block.settings.bar_padding_vertical }}px {{ block.settings.bar_padding_horizontal }}px;
    background-color: {{ block.settings.bar_background_color }};
    border-radius: {{ block.settings.bar_border_radius }}px;
    text-decoration: none;
    transition: all 0.3s ease;
    border: {{ block.settings.bar_border_width }}px solid {{ block.settings.bar_border_color }};
  }

  .ai-collection-bars__link-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.bar_hover_background_color }};
    transform: translateX({{ block.settings.hover_translate }}px);
  }

  .ai-collection-bars__icon-{{ ai_gen_id }} {
    flex-shrink: 0;
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: {{ block.settings.icon_background_color }};
    border-radius: {{ block.settings.icon_border_radius }}px;
    color: {{ block.settings.icon_color }};
  }

  .ai-collection-bars__icon-{{ ai_gen_id }} svg {
    width: calc({{ block.settings.icon_size }}px * 0.6);
    height: calc({{ block.settings.icon_size }}px * 0.6);
    fill: currentColor;
  }

  .ai-collection-bars__text-{{ ai_gen_id }} {
    flex-grow: 1;
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.text_size }}px;
    font-weight: {{ block.settings.text_weight }};
  }

  .ai-collection-bars__link-{{ ai_gen_id }}:hover .ai-collection-bars__text-{{ ai_gen_id }} {
    color: {{ block.settings.text_hover_color }};
  }

  .ai-collection-bars__arrow-{{ ai_gen_id }} {
    flex-shrink: 0;
    width: 20px;
    height: 20px;
    color: {{ block.settings.arrow_color }};
    transition: transform 0.3s ease;
  }

  .ai-collection-bars__link-{{ ai_gen_id }}:hover .ai-collection-bars__arrow-{{ ai_gen_id }} {
    transform: translateX(5px);
    color: {{ block.settings.arrow_hover_color }};
  }

  .ai-collection-bars__empty-state-{{ ai_gen_id }} {
    text-align: center;
    padding: 40px 20px;
    color: #999;
    font-style: italic;
  }

  @media screen and (max-width: 749px) {
    .ai-collection-bars__link-{{ ai_gen_id }} {
      padding: {{ block.settings.bar_padding_vertical | times: 0.8 }}px {{ block.settings.bar_padding_horizontal | times: 0.8 }}px;
    }

    .ai-collection-bars__icon-{{ ai_gen_id }} {
      width: {{ block.settings.icon_size | times: 0.8 }}px;
      height: {{ block.settings.icon_size | times: 0.8 }}px;
    }

    .ai-collection-bars__text-{{ ai_gen_id }} {
      font-size: {{ block.settings.text_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<collection-bars-{{ ai_gen_id }} class="ai-collection-bars-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-collection-bars__container-{{ ai_gen_id }}">
    {% liquid
      assign has_collections = false
      for i in (1..5)
        assign collection_key = 'collection_' | append: i
        if block.settings[collection_key] != blank
          assign has_collections = true
          break
        endif
      endfor
    %}

    {% if has_collections %}
      <ul class="ai-collection-bars__list-{{ ai_gen_id }}">
        {% for i in (1..5) %}
          {% liquid
            assign collection_key = 'collection_' | append: i
            assign collection = block.settings[collection_key]
          %}

          {% if collection != blank %}
            <li class="ai-collection-bars__item-{{ ai_gen_id }}">
              <a href="{{ collection.url }}" class="ai-collection-bars__link-{{ ai_gen_id }}">
                <div class="ai-collection-bars__icon-{{ ai_gen_id }}">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="3" y="3" width="7" height="7"></rect>
                    <rect x="14" y="3" width="7" height="7"></rect>
                    <rect x="14" y="14" width="7" height="7"></rect>
                    <rect x="3" y="14" width="7" height="7"></rect>
                  </svg>
                </div>
                <span class="ai-collection-bars__text-{{ ai_gen_id }}">{{ collection.title }}</span>
                {% if block.settings.show_arrow %}
                  <svg class="ai-collection-bars__arrow-{{ ai_gen_id }}" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="9 18 15 12 9 6"></polyline>
                  </svg>
                {% endif %}
              </a>
            </li>
          {% endif %}
        {% endfor %}
      </ul>
    {% else %}
      <div class="ai-collection-bars__empty-state-{{ ai_gen_id }}">
        Next, add collections to display
      </div>
    {% endif %}
  </div>
</collection-bars-{{ ai_gen_id }}>

<script>
  (function() {
    class CollectionBars{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.setupAccessibility();
      }

      setupAccessibility() {
        const links = this.querySelectorAll('.ai-collection-bars__link-{{ ai_gen_id }}');
        links.forEach(link => {
          link.setAttribute('role', 'button');
        });
      }
    }

    customElements.define('collection-bars-{{ ai_gen_id }}', CollectionBars{{ ai_gen_id }});
  })();
</script>

