{% doc %}
  @prompt
    Create customizable collection bars with the following features:
    - Each collection bar should have an option to upload a custom icon/image
    - Display collection name/title next to the icon
    - Include a clickable arrow on the right side that is displayed inside a circular background
    - Add shadow effects around each bar for depth
    - Make the bars slim/not too thick in height
    - Bars should be tappable/clickable to navigate to the collection
    - Allow customization of colors for the circular arrow background
    - Responsive design that works well on mobile devices
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-collection-bars-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding: 0;
  }

  .ai-collection-bars__container-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.bar_spacing }}px;
    width: 100%;
  }

  .ai-collection-bar-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: {{ block.settings.bar_padding_vertical }}px {{ block.settings.bar_padding_horizontal }}px;
    background-color: {{ block.settings.bar_background_color }};
    border-radius: {{ block.settings.bar_border_radius }}px;
    box-shadow: {{ block.settings.shadow_horizontal }}px {{ block.settings.shadow_vertical }}px {{ block.settings.shadow_blur }}px rgba(0, 0, 0, {{ block.settings.shadow_opacity | divided_by: 100.0 }});
    text-decoration: none;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
    cursor: pointer;
    min-height: {{ block.settings.bar_height }}px;
  }

  .ai-collection-bar-{{ ai_gen_id }}:hover {
    transform: translateY(-2px);
    box-shadow: {{ block.settings.shadow_horizontal }}px {{ block.settings.shadow_vertical | plus: 2 }}px {{ block.settings.shadow_blur | plus: 4 }}px rgba(0, 0, 0, {{ block.settings.shadow_opacity | divided_by: 100.0 | times: 1.2 }});
  }

  .ai-collection-bar__left-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: {{ block.settings.icon_text_spacing }}px;
    flex: 1;
    min-width: 0;
  }

  .ai-collection-bar__icon-wrapper-{{ ai_gen_id }} {
    flex-shrink: 0;
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    border-radius: {{ block.settings.icon_border_radius }}px;
  }

  .ai-collection-bar__icon-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-collection-bar__icon-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: {{ block.settings.icon_placeholder_bg }};
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-collection-bar__icon-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-collection-bar__title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_font_size }}px;
    font-weight: {{ block.settings.title_font_weight }};
    color: {{ block.settings.title_color }};
    margin: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .ai-collection-bar__arrow-wrapper-{{ ai_gen_id }} {
    flex-shrink: 0;
    width: {{ block.settings.arrow_circle_size }}px;
    height: {{ block.settings.arrow_circle_size }}px;
    background-color: {{ block.settings.arrow_background_color }};
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background-color 0.2s ease;
  }

  .ai-collection-bar-{{ ai_gen_id }}:hover .ai-collection-bar__arrow-wrapper-{{ ai_gen_id }} {
    background-color: {{ block.settings.arrow_background_hover_color }};
  }

  .ai-collection-bar__arrow-{{ ai_gen_id }} {
    width: {{ block.settings.arrow_size }}px;
    height: {{ block.settings.arrow_size }}px;
    stroke: {{ block.settings.arrow_color }};
    stroke-width: 2;
    fill: none;
  }

  .ai-collection-bar__empty-state-{{ ai_gen_id }} {
    text-align: center;
    padding: 40px 20px;
    color: #666;
    font-size: 14px;
  }

  @media screen and (max-width: 749px) {
    .ai-collection-bar__title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_font_size | times: 0.9 }}px;
    }

    .ai-collection-bar__icon-wrapper-{{ ai_gen_id }} {
      width: {{ block.settings.icon_size | times: 0.85 }}px;
      height: {{ block.settings.icon_size | times: 0.85 }}px;
    }

    .ai-collection-bar__arrow-wrapper-{{ ai_gen_id }} {
      width: {{ block.settings.arrow_circle_size | times: 0.85 }}px;
      height: {{ block.settings.arrow_circle_size | times: 0.85 }}px;
    }

    .ai-collection-bar__arrow-{{ ai_gen_id }} {
      width: {{ block.settings.arrow_size | times: 0.85 }}px;
      height: {{ block.settings.arrow_size | times: 0.85 }}px;
    }
  }
{% endstyle %}

<collection-bars-{{ ai_gen_id }} class="ai-collection-bars-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-collection-bars__container-{{ ai_gen_id }}">
    {% liquid
      assign has_any_collection = false
      for i in (1..6)
        assign collection_key = 'collection_' | append: i
        assign icon_key = 'collection_' | append: i | append: '_icon'
        assign collection = block.settings[collection_key]
        if collection != blank
          assign has_any_collection = true
          break
        endif
      endfor
    %}

    {% if has_any_collection %}
      {% for i in (1..6) %}
        {% liquid
          assign collection_key = 'collection_' | append: i
          assign icon_key = 'collection_' | append: i | append: '_icon'
          assign collection = block.settings[collection_key]
          assign icon = block.settings[icon_key]
        %}

        {% if collection != blank %}
          <a
            href="{{ collection.url }}"
            class="ai-collection-bar-{{ ai_gen_id }}"
            aria-label="View {{ collection.title }} collection"
          >
            <div class="ai-collection-bar__left-{{ ai_gen_id }}">
              <div class="ai-collection-bar__icon-wrapper-{{ ai_gen_id }}">
                {% if icon != blank %}
                  <img
                    src="{{ icon | image_url: width: 200 }}"
                    alt="{{ collection.title }}"
                    class="ai-collection-bar__icon-{{ ai_gen_id }}"
                    loading="lazy"
                    width="200"
                    height="200"
                  >
                {% else %}
                  <div class="ai-collection-bar__icon-placeholder-{{ ai_gen_id }}">
                    {{ 'collection' | placeholder_svg_tag }}
                  </div>
                {% endif %}
              </div>

              <h3 class="ai-collection-bar__title-{{ ai_gen_id }}">
                {{ collection.title }}
              </h3>
            </div>

            <div class="ai-collection-bar__arrow-wrapper-{{ ai_gen_id }}">
              <svg
                class="ai-collection-bar__arrow-{{ ai_gen_id }}"
                viewBox="0 0 24 24"
                xmlns="http://www.w3.org/2000/svg"
              >
                <polyline points="9 18 15 12 9 6"></polyline>
              </svg>
            </div>
          </a>
        {% endif %}
      {% endfor %}
    {% else %}
      <div class="ai-collection-bar__empty-state-{{ ai_gen_id }}">
        Next, select collections to display
      </div>
    {% endif %}
  </div>
</collection-bars-{{ ai_gen_id }}>

<script>
  (function() {
    class CollectionBars{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.bars = this.querySelectorAll('.ai-collection-bar-{{ ai_gen_id }}');
        this.setupAccessibility();
      }

      setupAccessibility() {
        this.bars.forEach((bar) => {
          bar.addEventListener('keydown', (e) => {
            if (e.key === 'Enter' || e.key === ' ') {
              e.preventDefault();
              bar.click();
            }
          });
        });
      }
    }

    customElements.define('collection-bars-{{ ai_gen_id }}', CollectionBars{{ ai_gen_id }});
  })();
</script>

